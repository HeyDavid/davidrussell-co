---
/*
  HeroAsteroids — small clickable asteroids drifting behind the hero only.
  Scoped via absolute positioning to the .hero element (Hero.astro adds
  position: relative). Click an asteroid → it bursts into particles +
  reveals a random hidden note as a small toast. Asteroid respawns at
  the hero edge a few seconds later.

  Config flag — set ENABLED to false to disable site-wide:
*/
const ENABLED = true;

// Stubbed hidden notes — David will replace from a JSON later.
const NOTES = [
  "Ship before you're ready, then learn from real feedback.",
  "If marketing is the moat, the moat needs to be deep.",
  "Most websites are afraid of long pages. Don't be.",
  "Trust compounds. Slop dilutes.",
  "The best operators write things down.",
];
---

{ENABLED && (
  <>
    <canvas class="hero-asteroids" id="hero-asteroids" aria-hidden="true"></canvas>
    <div class="hero-asteroid-toast" id="hero-asteroid-toast" role="status" aria-live="polite" hidden></div>
  </>
)}

<style>
  /* Mobile-only static SVG fallback — canvas hidden on coarse pointer,
     CSS-only star dots take over from globals.css. */
  .hero-asteroids {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.95;
  }
  @media (max-width: 760px), (pointer: coarse) {
    .hero-asteroids { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-asteroids { display: none; }
  }

  .hero-asteroid-toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    z-index: 50;
    padding: 14px 22px;
    border-radius: 999px;
    border: 1px solid rgba(91, 141, 239, 0.3);
    background: rgba(20, 21, 24, 0.92);
    backdrop-filter: blur(12px);
    color: var(--star);
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.4;
    max-width: min(520px, calc(100vw - 32px));
    text-align: center;
    opacity: 0;
    transition: opacity 320ms ease, transform 320ms var(--ease-out);
    pointer-events: none;
  }
  .hero-asteroid-toast.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script is:inline define:vars={{ NOTES }}>
  /* Hero asteroids: 4 small drifting rocks confined to the hero region.
     Click within ~14px of any asteroid → particle burst + hidden-note toast.
     Pure canvas; mobile + reduced-motion users see nothing here (the
     globals.css starfield handles the texture for them). */
  (() => {
    const canvas = document.getElementById("hero-asteroids");
    if (!canvas) return;
    const toast = document.getElementById("hero-asteroid-toast");
    const ctx = canvas.getContext("2d", { alpha: true });
    if (!ctx) return;

    let width = 0, height = 0, dpr = 1, frame = 0, raf = 0;
    let asteroids = [];

    const seed = () => {
      const verts = (n) => {
        const out = [];
        for (let i = 0; i < n; i++) {
          const ang = (i / n) * Math.PI * 2;
          const r = 0.75 + Math.random() * 0.45;
          out.push({ x: Math.cos(ang) * r, y: Math.sin(ang) * r });
        }
        return out;
      };
      asteroids = [];
      for (let i = 0; i < 4; i++) {
        asteroids.push({
          x: 0.15 + Math.random() * 0.7,
          y: 0.15 + Math.random() * 0.6,
          vx: (Math.random() - 0.5) * 0.00018,
          vy: (Math.random() - 0.5) * 0.0001,
          r: 7 + Math.random() * 8,
          rot: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.006,
          verts: verts(7 + Math.floor(Math.random() * 3)),
          state: "drift",
          brokenT: 0,
          debris: [],
          respawnAt: 0,
        });
      }
    };

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = Math.max(1, Math.floor(rect.width));
      height = Math.max(1, Math.floor(rect.height));
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const drawAsteroid = (a, alpha) => {
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.beginPath();
      for (let i = 0; i < a.verts.length; i++) {
        const v = a.verts[i];
        const x = v.x * a.r;
        const y = v.y * a.r;
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      }
      ctx.closePath();
      const grad = ctx.createRadialGradient(-a.r * 0.3, -a.r * 0.3, 0, 0, 0, a.r);
      grad.addColorStop(0, "rgba(120, 122, 130, 0.85)");
      grad.addColorStop(1, "rgba(36, 38, 44, 0.85)");
      ctx.fillStyle = grad;
      ctx.fill();
      ctx.strokeStyle = "rgba(20, 20, 24, 0.7)";
      ctx.lineWidth = 0.6;
      ctx.stroke();
      ctx.restore();
    };

    const draw = () => {
      frame += 1;
      ctx.clearRect(0, 0, width, height);

      for (const a of asteroids) {
        if (a.state === "drift") {
          a.x += a.vx;
          a.y += a.vy;
          a.rot += a.rotSpeed;
          if (a.x > 1.05) a.x = -0.05;
          if (a.x < -0.05) a.x = 1.05;
          if (a.y > 0.9) a.y = 0.05;
          if (a.y < -0.05) a.y = 0.85;
          const px = a.x * width;
          const py = a.y * height;
          ctx.save();
          ctx.translate(px, py);
          ctx.rotate(a.rot);
          drawAsteroid(a, 0.85);
          ctx.restore();
        } else if (a.state === "broken") {
          a.brokenT += 1 / 60;
          for (const d of a.debris) {
            d.x += d.vx;
            d.y += d.vy;
            d.vy += 0.008;
            d.rot += d.rotSpeed;
            d.t += 1 / 60;
            const alpha = Math.max(0, 1 - d.t);
            ctx.save();
            ctx.translate(d.x, d.y);
            ctx.rotate(d.rot);
            ctx.globalAlpha = alpha * 0.85;
            ctx.fillStyle = "rgba(90, 92, 100, 1)";
            ctx.beginPath();
            for (let i = 0; i < 5; i++) {
              const ang = (i / 5) * Math.PI * 2;
              const rad = d.r * (0.7 + Math.sin(i * 1.7) * 0.25);
              const x = Math.cos(ang) * rad;
              const y = Math.sin(ang) * rad;
              if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
            }
            ctx.closePath();
            ctx.fill();
            ctx.restore();
          }
          if (a.brokenT >= 1.5 && frame >= a.respawnAt) {
            a.x = Math.random() < 0.5 ? -0.05 : 1.05;
            a.y = 0.1 + Math.random() * 0.6;
            a.vx = (Math.random() - 0.5) * 0.00018;
            a.state = "drift";
            a.brokenT = 0;
            a.debris = [];
          }
        }
      }

      raf = window.requestAnimationFrame(draw);
    };

    const showToast = (note) => {
      if (!toast) return;
      toast.textContent = note;
      toast.hidden = false;
      requestAnimationFrame(() => toast.classList.add("is-visible"));
      window.clearTimeout(toast._t);
      toast._t = window.setTimeout(() => {
        toast.classList.remove("is-visible");
        window.setTimeout(() => { toast.hidden = true; }, 360);
      }, 3400);
    };

    const onClick = (event) => {
      const rect = canvas.getBoundingClientRect();
      const mx = event.clientX - rect.left;
      const my = event.clientY - rect.top;
      // Click must be within the canvas bounds (hero region only)
      if (mx < 0 || mx > width || my < 0 || my > height) return;
      for (const a of asteroids) {
        if (a.state !== "drift") continue;
        const px = a.x * width;
        const py = a.y * height;
        const dist = Math.hypot(mx - px, my - py);
        if (dist < a.r + 14) {
          a.state = "broken";
          a.brokenT = 0;
          a.respawnAt = frame + 180;
          const n = 5 + Math.floor(Math.random() * 3);
          a.debris = [];
          for (let i = 0; i < n; i++) {
            const ang = (i / n) * Math.PI * 2 + Math.random() * 0.6;
            const speed = 0.6 + Math.random() * 1.4;
            a.debris.push({
              x: px,
              y: py,
              vx: Math.cos(ang) * speed,
              vy: Math.sin(ang) * speed - 0.3,
              r: a.r * (0.25 + Math.random() * 0.25),
              t: 0,
              rot: Math.random() * Math.PI * 2,
              rotSpeed: (Math.random() - 0.5) * 0.12,
            });
          }
          // Reveal a random hidden note
          showToast(NOTES[Math.floor(Math.random() * NOTES.length)]);
          event.preventDefault();
          break;
        }
      }
    };

    seed();
    resize();
    draw();
    window.addEventListener("resize", resize, { passive: true });
    // Listen on window so clicks pass through the pointer-events: none canvas
    window.addEventListener("click", onClick);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) window.cancelAnimationFrame(raf);
      else window.requestAnimationFrame(draw);
    });
  })();
</script>
