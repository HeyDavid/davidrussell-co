---
/*
  Starfield v4 — restrained cosmic scene with ambient craft.

  Fewer stars (~180), more variation, plus 2 small ambient ships that
  drift very slowly across the void with blinking lights. Reads as
  "inhabited deep space" instead of "empty backdrop."

  Crossfades with DeepOcean canvas as the user scrolls past 30%.
*/
---

<canvas class="starfield" id="starfield" aria-hidden="true"></canvas>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: var(--starfield-opacity, 1);
    transition: opacity 600ms ease;
  }
</style>

<script>
  (() => {
    type Star = {
      x: number; y: number; r: number;
      color: [number, number, number];
      base: number; twinkle: number;
      spikes: boolean; depth: number;
    };
    type Ship = {
      x: number; y: number;
      vx: number; vy: number;
      blink: number; phase: number;
      lightColor: [number, number, number];
      kind: "satellite" | "capsule";
    };

    const COLORS: { rgb: [number, number, number]; weight: number }[] = [
      { rgb: [184, 200, 255], weight: 15 },
      { rgb: [245, 241, 232], weight: 60 },
      { rgb: [255, 245, 220], weight: 15 },
      { rgb: [255, 207, 166], weight:  7 },
      { rgb: [255, 175, 140], weight:  3 },
    ];
    const WEIGHT_TOTAL = COLORS.reduce((a, c) => a + c.weight, 0);

    const pickColor = (rng: () => number): [number, number, number] => {
      let r = rng() * WEIGHT_TOTAL;
      for (const c of COLORS) {
        r -= c.weight;
        if (r <= 0) return c.rgb;
      }
      return COLORS[1].rgb;
    };

    const mulberry32 = (a: number) => () => {
      a |= 0; a = (a + 0x6D2B79F5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };

    const boot = () => {
      const canvas = document.getElementById("starfield") as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext("2d", { alpha: true });
      if (!ctx) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const pointer = { x: 0.5, y: 0.5 };
      const target = { x: 0.5, y: 0.5 };
      let width = 0, height = 0, dpr = 1, frame = 0, raf = 0;
      let stars: Star[] = [];
      let ships: Ship[] = [];

      const seed = () => {
        const rng = mulberry32(20260523);

        const count = 180;
        stars = new Array(count).fill(0).map(() => {
          const r = 0.3 + Math.pow(rng(), 5) * 2.8;
          const depth = rng();
          const yRand = rng();
          const y = yRand * yRand * 0.85 + rng() * 0.1;
          return {
            x: rng(),
            y,
            r,
            color: pickColor(rng),
            base: 0.25 + rng() * 0.55,
            twinkle: rng() * Math.PI * 2,
            spikes: r > 1.6 && rng() > 0.5,
            depth,
          };
        });

        // Two ambient craft drifting through the void
        ships = [
          {
            x: 0.85, y: 0.18,
            vx: -0.00006, vy: 0.00002,
            blink: 0, phase: 0,
            lightColor: [251, 191, 36], // warm spark yellow — the "invitation" note
            kind: "satellite",
          },
          {
            x: 0.12, y: 0.32,
            vx: 0.00005, vy: -0.00001,
            blink: 0, phase: Math.PI,
            lightColor: [91, 141, 239], // signal blue
            kind: "capsule",
          },
        ];
      };

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = Math.max(1, Math.floor(rect.width));
        height = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const drawShip = (s: Ship, parallaxX: number, parallaxY: number) => {
        const px = s.x * width + parallaxX * 0.3;
        const py = s.y * height + parallaxY * 0.3;

        ctx.save();
        ctx.translate(px, py);

        if (s.kind === "satellite") {
          // Small satellite: central body + two solar-panel wings
          ctx.fillStyle = "rgba(180, 190, 210, 0.55)";
          ctx.fillRect(-2.5, -1.5, 5, 3); // body
          ctx.fillStyle = "rgba(120, 140, 175, 0.4)";
          ctx.fillRect(-8, -1, 4, 2);     // left panel
          ctx.fillRect(4, -1, 4, 2);      // right panel
          // Antenna mast
          ctx.strokeStyle = "rgba(180, 190, 210, 0.35)";
          ctx.lineWidth = 0.6;
          ctx.beginPath();
          ctx.moveTo(0, -1.5);
          ctx.lineTo(0, -4);
          ctx.stroke();
        } else {
          // Capsule: rounded oblong
          ctx.fillStyle = "rgba(180, 190, 210, 0.55)";
          ctx.beginPath();
          ctx.ellipse(0, 0, 4, 1.6, 0, 0, Math.PI * 2);
          ctx.fill();
          // Window
          ctx.fillStyle = "rgba(91, 141, 239, 0.45)";
          ctx.beginPath();
          ctx.arc(-1.5, 0, 0.7, 0, Math.PI * 2);
          ctx.fill();
        }

        // Blinking light — soft pulse with halo
        const pulse = 0.55 + 0.45 * Math.sin(frame * 0.06 + s.phase);
        const [r, g, b] = s.lightColor;
        const lightOffset = s.kind === "satellite" ? 2.5 : 3.5;

        const halo = ctx.createRadialGradient(lightOffset, 0, 0, lightOffset, 0, 8);
        halo.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${pulse * 0.8})`);
        halo.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
        ctx.fillStyle = halo;
        ctx.beginPath();
        ctx.arc(lightOffset, 0, 8, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${0.7 + pulse * 0.3})`;
        ctx.beginPath();
        ctx.arc(lightOffset, 0, 1, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
      };

      const drawStar = (s: Star, alpha: number, parallaxX: number, parallaxY: number) => {
        const px = s.x * width + parallaxX * s.depth;
        const py = s.y * height + parallaxY * s.depth;
        const [r, g, b] = s.color;

        if (s.r > 0.9) {
          const haloR = s.r * (s.spikes ? 7 : 4.5);
          const halo = ctx.createRadialGradient(px, py, 0, px, py, haloR);
          halo.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${alpha * 0.35})`);
          halo.addColorStop(0.35, `rgba(${r}, ${g}, ${b}, ${alpha * 0.10})`);
          halo.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
          ctx.fillStyle = halo;
          ctx.beginPath();
          ctx.arc(px, py, haloR, 0, Math.PI * 2);
          ctx.fill();
        }

        if (s.spikes) {
          const spikeLen = s.r * 7;
          ctx.save();
          ctx.globalAlpha = alpha * 0.6;
          ctx.translate(px, py);
          let g1 = ctx.createLinearGradient(-spikeLen, 0, spikeLen, 0);
          g1.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0)`);
          g1.addColorStop(0.5, `rgba(${r}, ${g}, ${b}, 1)`);
          g1.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
          ctx.fillStyle = g1;
          ctx.fillRect(-spikeLen, -0.5, spikeLen * 2, 1);
          let g2 = ctx.createLinearGradient(0, -spikeLen, 0, spikeLen);
          g2.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0)`);
          g2.addColorStop(0.5, `rgba(${r}, ${g}, ${b}, 1)`);
          g2.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
          ctx.fillStyle = g2;
          ctx.fillRect(-0.5, -spikeLen, 1, spikeLen * 2);
          ctx.restore();
        }

        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        ctx.beginPath();
        ctx.arc(px, py, s.r, 0, Math.PI * 2);
        ctx.fill();
      };

      const draw = () => {
        frame += prefersReduced ? 0 : 0.005;

        pointer.x += (target.x - pointer.x) * 0.05;
        pointer.y += (target.y - pointer.y) * 0.05;

        ctx.clearRect(0, 0, width, height);

        const parallaxX = (pointer.x - 0.5) * 18;
        const parallaxY = (pointer.y - 0.5) * 12;

        // Stars
        for (const s of stars) {
          const tw = prefersReduced ? 0 : Math.sin(frame * (1 + s.depth * 0.6) + s.twinkle) * 0.10;
          const alpha = Math.max(0.06, Math.min(1, s.base + tw));
          drawStar(s, alpha, parallaxX, parallaxY);
        }

        // Ambient craft — slow drift across the void
        if (!prefersReduced) {
          for (const s of ships) {
            s.x += s.vx;
            s.y += s.vy;
            if (s.x > 1.1) s.x = -0.1;
            if (s.x < -0.1) s.x = 1.1;
            if (s.y > 1.1) s.y = -0.1;
            if (s.y < -0.1) s.y = 1.1;
          }
        }
        for (const s of ships) {
          drawShip(s, parallaxX, parallaxY);
        }

        if (!prefersReduced) raf = window.requestAnimationFrame(draw);
      };

      const move = (event: PointerEvent) => {
        target.x = event.clientX / window.innerWidth;
        target.y = event.clientY / window.innerHeight;
      };

      seed();
      resize();
      draw();

      window.addEventListener("resize", resize, { passive: true });
      window.addEventListener("pointermove", move, { passive: true });
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) window.cancelAnimationFrame(raf);
        else if (!prefersReduced) draw();
      });

      const onScroll = () => {
        const doc = document.documentElement;
        const total = Math.max(1, doc.scrollHeight - window.innerHeight);
        const p = Math.max(0, Math.min(1, window.scrollY / total));
        const opacity = p < 0.30 ? 1 : Math.max(0, 1 - (p - 0.30) / 0.28);
        doc.style.setProperty("--starfield-opacity", opacity.toFixed(3));
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(boot, { timeout: 900 });
    } else {
      globalThis.setTimeout(boot, 120);
    }
  })();
</script>
