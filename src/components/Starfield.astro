---
/*
  Starfield — CSS box-shadow technique (the proven crisp approach).

  Three depth layers of stars rendered as box-shadow offsets on a single
  1px element. This is the canonical way to do a dense starfield on the web
  because: (a) stays sub-pixel sharp at any DPR, (b) zero JS overhead, (c)
  GPU-composited as one layer per parallax tier.

  The cosmic gradient lives here too — space at top fading through twilight
  zone to abyssal at the bottom. The fixed-position element covers the
  viewport; opacity adjusts to scroll progress so stars fade as the user
  descends. DeepOcean component sits on top with its particle motes.
*/

const seeded = (i: number, salt: number) => {
  const x = Math.sin(i * 12.9898 + salt * 78.233) * 43758.5453;
  return x - Math.floor(x);
};

/* Build a box-shadow string for N stars within a 2000x2000 grid (we'll
   tile the SVG box so the same shadow set covers any viewport). */
const buildShadows = (count: number, salt: number, color: string) => {
  const parts: string[] = [];
  for (let i = 0; i < count; i++) {
    const x = Math.floor(seeded(i, salt) * 2000);
    // Bias y toward the top half — denser overhead, sparser near the middle
    const yRand = seeded(i, salt + 1.7);
    const y = Math.floor(yRand * yRand * 2000);
    parts.push(`${x}px ${y}px ${color}`);
  }
  return parts.join(", ");
};

const tinyStars   = buildShadows(220, 1.0, "#f5f1e8");
const smallStars  = buildShadows(90,  2.0, "#e9e4d4");
const brightStars = buildShadows(16,  3.0, "#ffffff");
---

<div class="cosmos" aria-hidden="true">
  <div class="cosmos-gradient"></div>
  <div class="stars stars-tiny"></div>
  <div class="stars stars-small"></div>
  <div class="stars stars-bright"></div>
  <div class="shooting-star shooting-star-a"></div>
  <div class="shooting-star shooting-star-b"></div>
</div>

<style define:vars={{ tinyStars, smallStars, brightStars }}>
  .cosmos {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: var(--starfield-opacity, 1);
    transition: opacity 600ms ease;
  }

  /* Vertical cosmic gradient — space at top → ocean at bottom. */
  .cosmos-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 78% 8%, rgba(91, 141, 239, 0.18), transparent 55%),
      radial-gradient(ellipse at 22% 95%, rgba(46, 110, 138, 0.14), transparent 50%),
      linear-gradient(
        180deg,
        #050810 0%,         /* deep space — darker than --void so stars pop */
        #07101e 20%,
        #0a1828 45%,        /* twilight zone */
        #08182a 65%,
        #061824 85%,
        #03121a 100%        /* abyssal */
      );
  }

  /* Star layers — each is a 1px element with N box-shadow offsets defining
     star positions, tiled across the viewport via repeating-background trick.
     We use a 2000x2000 grid then translate so stars repeat seamlessly. */
  .stars {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    border-radius: 50%;
    /* Mask fade — stars dense at top, fading by 60% of viewport height */
    -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 50%, transparent 100%);
            mask-image: linear-gradient(180deg, #000 0%, #000 50%, transparent 100%);
  }
  .stars-tiny {
    box-shadow: var(--tinyStars);
    opacity: 0.85;
  }
  .stars-small {
    box-shadow: var(--smallStars);
    width: 1.4px;
    height: 1.4px;
    opacity: 0.95;
  }
  .stars-bright {
    box-shadow: var(--brightStars);
    width: 2.2px;
    height: 2.2px;
    background: white;
    box-shadow: var(--brightStars), 0 0 0 0 white;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.6));
    animation: twinkle-soft 4.5s ease-in-out infinite;
  }

  @keyframes twinkle-soft {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }

  /* Shooting stars — slim streaks across the upper third on long delays */
  .shooting-star {
    position: absolute;
    width: 110px;
    height: 1.5px;
    background: linear-gradient(90deg, transparent, rgba(245, 241, 232, 0.95));
    border-radius: 1px;
    opacity: 0;
    transform-origin: left center;
    will-change: transform, opacity;
    filter: drop-shadow(0 0 6px rgba(245, 241, 232, 0.6));
  }
  .shooting-star::after {
    content: "";
    position: absolute;
    right: 0;
    top: -1.5px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: white;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.85);
  }
  @keyframes shoot {
    0%   { transform: translate(-15vw, -3vh) rotate(20deg) scaleX(0.4); opacity: 0; }
    5%   { opacity: 0; }
    12%  { opacity: 1; transform: translate(0vw, 2vh) rotate(20deg) scaleX(1); }
    40%  { opacity: 1; }
    55%  { opacity: 0; transform: translate(70vw, 28vh) rotate(20deg) scaleX(1); }
    100% { opacity: 0; transform: translate(70vw, 28vh) rotate(20deg); }
  }
  .shooting-star-a {
    top: 14%;
    left: -15vw;
    animation: shoot 14s ease-in 5s infinite;
  }
  .shooting-star-b {
    top: 26%;
    left: -15vw;
    width: 85px;
    animation: shoot 18s ease-in 11s infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .stars-bright { animation: none; }
    .shooting-star-a, .shooting-star-b { display: none; }
  }
</style>

<script>
  /* Tie cosmic opacity to scroll progress — full at top, fades to 0 by 0.55
     so the DeepOcean layer (which fades in over the same range) takes over. */
  (() => {
    const update = () => {
      const doc = document.documentElement;
      const total = Math.max(1, doc.scrollHeight - window.innerHeight);
      const p = Math.max(0, Math.min(1, window.scrollY / total));
      const opacity = p < 0.30 ? 1 : Math.max(0, 1 - (p - 0.30) / 0.25);
      doc.style.setProperty("--starfield-opacity", opacity.toFixed(3));
    };
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();
  })();
</script>
