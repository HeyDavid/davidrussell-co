---
type Door = { label: string; name: string; desc: string; href: string };

const doors: Door[] = [
  {
    label: "marketing",
    name: "Hire me",
    desc: "Best-in-class websites and funnels for service businesses. I do the math, own the build, and stay accountable to the outcome.",
    href: "/work-with-me/marketing/",
  },
  {
    label: "full-time / contract",
    name: "Recruiting",
    desc: "Open to a few operator-level roles where I can make a real difference. Marketing-led, owner-accountable.",
    href: "/work-with-me/recruiting/",
  },
  {
    label: "early-stage",
    name: "Investing",
    desc: "If you're an operator-founder who needs a thinking partner and a small early check, this is the door for that.",
    href: "/work-with-me/investing/",
  },
];
---

<section class="movement reveal" id="doors" aria-labelledby="doors-title">
  <div class="movement-grid">
    <div class="movement-head">
      <span class="numeral" aria-hidden="true">III</span>
      <span class="kicker">the doors</span>
      <p class="margin-note">Three ways in. <b>Pick one</b> — they don&rsquo;t overlap.</p>
    </div>
    <div class="movement-body">
      <h2 class="movement-title" id="doors-title">Three doors. <em>Pick the one that fits.</em></h2>
      <div class="doors">
        {doors.map((d) => (
          <a class="door" href={d.href}>
            <div class="door-head">
              <span class="door-label">{d.label}</span>
              <span class="door-name">{d.name}</span>
            </div>
            <p class="door-desc">{d.desc}</p>
            <span class="door-cta">Read the terms →</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
