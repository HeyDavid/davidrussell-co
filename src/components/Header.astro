<script>
  (() => {
    const m = document.getElementById("runhead");
    if (!m) return;
    const onScroll = () => {
      if (window.scrollY > 8) m.classList.add("is-scrolled");
      else m.classList.remove("is-scrolled");
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  })();
</script>
