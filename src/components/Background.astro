---
type Record = { name: string; yr: string; why: string };

const records: Record[] = [
  { name: "Marketing operator", yr: "10+ years", why: "Paid, content, brand, productized — most channels, most stages." },
  { name: "Moolaguides", yr: "founder & exit", why: "Built it, grew it to $400K+, sold it." },
  { name: "Syllble", yr: "co-founder", why: "Collaborative fiction publishing. 105+ novels and counting." },
  { name: "Let's Chat", yr: "current", why: "Productized agency for service businesses. Websites, AI, the parts in between." },
  { name: "Maker Margin", yr: "current", why: "Free fee calculator for Etsy sellers. Quietly compounding." },
  { name: "Magic", yr: "20+ years", why: "Card and coin work since I was a kid. Still the best icebreaker I've got." },
];
---

<section class="movement reveal" id="background" aria-labelledby="background-title">
  <div class="movement-grid">
    <div class="movement-head">
      <span class="numeral" aria-hidden="true">IV</span>
      <span class="kicker">the record</span>
      <p class="margin-note">A decade in, two ventures with my name <b>on the door</b>.</p>
    </div>
    <div class="movement-body">
      <h2 class="movement-title" id="background-title">A decade of marketing, and a lot of late nights shipping.</h2>
      <ul class="record">
        {records.map((r) => (
          <li class="record-row">
            <div class="record-name">{r.name}<span class="yr">{r.yr}</span></div>
            <div class="record-why">
              {r.name === "Moolaguides" ? (
                <>Built it, grew it to $400K+, sold it. <a href="https://www.collegemagazine.com/making-moola-cm-interviews-the-moolaguides-team/" target="_blank" rel="noopener">Covered in College Magazine</a>.</>
              ) : r.why}
            </div>
          </li>
        ))}
      </ul>
      <p class="record-note">
        More detail on <a href="https://www.linkedin.com/in/heydavidr/" target="_blank" rel="noopener">LinkedIn</a>.
        The tools and books I actually use live on the <a href="/recommended/">recommended</a> page.
      </p>
    </div>
  </div>
</section>
