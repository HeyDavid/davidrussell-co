---
const proof = [
  {
    figure: "$400K+",
    detail: "Annual sales after growing what started as a Wix site into a full marketplace.",
  },
  {
    figure: "10 years",
    detail: "Marketing operator — paid, content, brand, productized offers, and the messy middle.",
  },
  {
    figure: "Dozens",
    detail: "Industries consulted across, plus a handful of my own startups built and shipped.",
  },
];
---

<section class="entry background-strip" id="background" aria-labelledby="background-title">
  <div class="section-kicker">Background</div>
  <h2 id="background-title">The short version.</h2>
  <p>
    I grew what started as a Wix site into a marketplace doing over $400,000 a year in sales. A decade of marketing experience behind it &mdash; building my own startups and consulting across dozens of industries. Now I'm building best-in-class websites and marketing funnels for operators who want the same.
  </p>

  <ul class="proof-grid" role="list">
    {proof.map((item) => (
      <li class="proof-card">
        <div class="proof-figure">{item.figure}</div>
        <p class="proof-detail">{item.detail}</p>
      </li>
    ))}
  </ul>

  <p class="small-note">
    Longer version on <a href="https://www.linkedin.com/in/heydavidr/">LinkedIn</a>. Tools, books, and people I recommend live on the <a href="/recommended/">recommended page</a>.
  </p>
</section>

<style>
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin: 34px 0 10px;
    list-style: none;
    padding: 0;
  }
  .proof-card {
    padding: 26px 24px 28px;
    border: 1px solid var(--rule);
    background: var(--surface);
    display: grid;
    gap: 14px;
    align-content: start;
  }
  .proof-figure {
    font-family: var(--sans);
    font-size: clamp(40px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--ink);
  }
  .proof-card:first-child .proof-figure {
    color: var(--accent);
  }
  .proof-detail {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.5;
    max-width: 30ch;
  }
  @media (max-width: 720px) {
    .proof-grid { grid-template-columns: 1fr; }
  }
</style>
