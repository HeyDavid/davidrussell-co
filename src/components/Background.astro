---
const proof = [
  { figure: "$400K+",  detail: "Annual sales after growing what started as a Wix site into a full marketplace." },
  { figure: "10 yrs",  detail: "Marketing operator — paid, content, brand, productized." },
  { figure: "Dozens",  detail: "Industries consulted across, plus a handful of my own startups." },
];
---

<section class="entry entry-split background-strip" id="background" aria-labelledby="background-title">
  <div class="entry-head">
    <div class="section-kicker">A little about me</div>
    <h2 id="background-title">The short version.</h2>
    <p class="entry-head-note">Longer version lives on <a href="https://www.linkedin.com/in/heydavidr/">LinkedIn</a>.</p>
  </div>

  <div class="entry-body">
    <p class="background-lede">
      I grew what started as a Wix site into a marketplace doing over <strong>$400,000 a year</strong> in sales. A decade of marketing experience behind it &mdash; building my own startups and consulting across dozens of industries. Now I'm building best-in-class websites and marketing funnels for operators who want the same.
    </p>

    <dl class="proof-strip">
      {proof.map((item, i) => (
        <div class="proof-row">
          <dt class={`proof-figure ${i === 0 ? "proof-figure-hero" : ""}`}>{item.figure}</dt>
          <dd class="proof-detail">{item.detail}</dd>
        </div>
      ))}
    </dl>

    <p class="small-note">
      Tools, books, and people I recommend live on the <a href="/recommended/">recommended page</a>.
    </p>
  </div>
</section>

<style>
  .background-lede {
    font-size: clamp(18px, 1.7vw, 21px);
    line-height: 1.55;
    color: var(--star);
    margin-bottom: 36px;
    max-width: 56ch;
  }
  .background-lede strong {
    color: var(--signal);
    font-weight: 500;
  }
  /* Horizontal strip layout — totally different shape from Featured Work
     card grid. Numbers anchor the left edge, prose flows right. */
  .proof-strip {
    list-style: none;
    margin: 0 0 30px;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .proof-row {
    display: grid;
    grid-template-columns: minmax(140px, 200px) 1fr;
    gap: clamp(20px, 3vw, 36px);
    align-items: baseline;
    padding: 22px 0;
    border-top: 1px solid rgba(91, 141, 239, 0.08);
  }
  .proof-row:first-child { border-top: 0; padding-top: 8px; }
  .proof-row:last-child { padding-bottom: 8px; }
  .proof-figure {
    font-family: var(--sans);
    font-size: clamp(34px, 4vw, 48px);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--star);
    margin: 0;
  }
  .proof-figure-hero {
    color: var(--signal);
  }
  .proof-detail {
    color: var(--mist);
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
    max-width: 38ch;
  }
  .small-note {
    color: var(--mist);
    font-size: 14px;
    font-style: italic;
  }
  @media (max-width: 760px) {
    .proof-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 16px 0;
    }
  }
</style>
