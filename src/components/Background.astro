---
const proof = [
  {
    figure: "$400K+",
    detail: "Annual sales after growing what started as a Wix site into a full marketplace.",
  },
  {
    figure: "10 years",
    detail: "Marketing operator — paid, content, brand, productized offers, and the messy middle.",
  },
  {
    figure: "Dozens",
    detail: "Industries consulted across, plus a handful of my own startups built and shipped.",
  },
];
---

<section class="entry background-strip" id="background" aria-labelledby="background-title">
  <div class="section-kicker">A little about me</div>
  <h2 id="background-title">The short version.</h2>
  <p>
    I grew what started as a Wix site into a marketplace doing over $400,000 a year in sales. A decade of marketing experience behind it &mdash; building my own startups and consulting across dozens of industries. Now I'm building best-in-class websites and marketing funnels for operators who want the same.
  </p>

  <ul class="proof-grid" role="list">
    {proof.map((item) => (
      <li class="proof-card">
        <div class="proof-figure">{item.figure}</div>
        <p class="proof-detail">{item.detail}</p>
      </li>
    ))}
  </ul>

  <p class="small-note">
    Longer version on <a href="https://www.linkedin.com/in/heydavidr/">LinkedIn</a>. Tools, books, and people I recommend live on the <a href="/recommended/">recommended page</a>.
  </p>
</section>

<style>
  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin: 34px 0 10px;
    list-style: none;
    padding: 0;
  }
  .proof-card {
    padding: 26px 24px 28px;
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(13, 36, 56, 0.65), rgba(15, 26, 46, 0.55));
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.04) inset, 0 18px 40px rgba(0, 0, 0, 0.45);
    display: grid;
    gap: 14px;
    align-content: start;
    position: relative;
    overflow: hidden;
    transition: transform 320ms var(--ease-out), border-color 240ms ease, box-shadow 320ms ease;
  }
  .proof-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 0%, rgba(91, 141, 239, 0.14), transparent 70%);
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }
  .proof-card:hover {
    transform: translateY(-3px);
    border-color: rgba(91, 141, 239, 0.4);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06) inset, 0 24px 50px rgba(0, 0, 0, 0.55), 0 0 60px rgba(91, 141, 239, 0.12);
  }
  .proof-card:hover::after { opacity: 1; }
  .proof-figure {
    font-family: var(--sans);
    font-size: clamp(40px, 5vw, 56px);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--ink);
  }
  .proof-card:first-child .proof-figure {
    color: var(--accent);
  }
  .proof-detail {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.5;
    max-width: 30ch;
  }
  @media (max-width: 720px) {
    .proof-grid { grid-template-columns: 1fr; }
  }
</style>
