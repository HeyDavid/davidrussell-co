<section class="hero">
  <div class="hero-byline">
    <div class="hero-portrait">
      <img src="/assets/headshot.jpg" alt="David Russell" />
    </div>
    <div class="hero-byline-text">
      By <strong>David Russell</strong><br />
      Solo founder, South Florida
    </div>
  </div>

  <h1>I build small, <em>sharp</em> ventures and write about what actually works.</h1>

  <p class="hero-lede">
    Ten years marketing. Built and sold <a href="https://www.collegemagazine.com/making-moola-cm-interviews-the-moolaguides-team/">Moolaguides</a>. Co-founded <strong>Syllble Publishing House</strong>, publishing over 115 novels featuring authors around the world. <strong>Maker Margin</strong> is a suite of tools for creative entrepreneurs. <a href="https://letschatmarketing.com">Let&rsquo;s Chat</a> is a productized agency. <a href="https://scamcapital.com">ScamCapital</a> is a scam-education hub. New ideas always in incubation. Reach out if you have investment or business opportunities.
  </p>

  <div class="subscribe">
    <span class="subscribe-label">The newsletter.</span>
    <form class="subscribe-form" id="hero-subscribe">
      <input type="email" name="email" required placeholder="your email" />
      <button type="submit">subscribe &rarr;</button>
    </form>
    <p class="subscribe-status" id="hero-subscribe-status" role="status" aria-live="polite" hidden></p>
  </div>

  <div class="hero-social" aria-label="Find David elsewhere">
    <span>Elsewhere:</span>
    <a href="https://www.linkedin.com/in/heydavidr/" target="_blank" rel="noopener">LinkedIn</a>
    <a href="https://x.com/heydavidr" target="_blank" rel="noopener">X</a>
    <a href="https://www.threads.com/@heydavidr" target="_blank" rel="noopener">Threads</a>
    <a href="https://bsky.app/profile/heydavidr.bsky.social" target="_blank" rel="noopener">Bluesky</a>
    <a href="https://github.com/HeyDavid" target="_blank" rel="noopener">GitHub</a>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById('hero-subscribe') as HTMLFormElement | null;
    const status = document.getElementById('hero-subscribe-status') as HTMLElement | null;
    if (!form || !status) return;
    const BEEHIIV_PUB = 'pub_ed495df0-b44a-47ba-939c-eeb46089e27b';
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input[name="email"]') as HTMLInputElement | null;
      const email = input?.value?.trim();
      if (!email) return;
      const button = form.querySelector('button') as HTMLButtonElement | null;
      if (button) { button.disabled = true; button.textContent = 'subscribing…'; }
      const body = new FormData();
      body.append('email', email);
      body.append('utm_source', 'davidrussell.co');
      body.append('tags', 'dr-subscriber');
      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: 'POST',
        mode: 'no-cors',
        body,
      }).finally(() => {
        form.hidden = true;
        status.hidden = false;
        status.textContent = "On the list. Check your inbox to confirm.";
      });
    });
  })();
</script>
