---
const lanes = [
  {
    label: "Founder",
    href: "/lets-chat/",
    title: "Let's Chat",
    detail: "Productized marketing systems for service businesses.",
  },
  {
    label: "Creator",
    href: "/performing/",
    title: "Performing",
    detail: "Video, voice, and live work with a little bite.",
  },
  {
    label: "Background",
    href: "/background/",
    title: "Operator notes",
    detail: "Ten years in marketing, publishing, tools, and small bets.",
  },
];
---

<section class="hero" aria-labelledby="hero-title">
  <canvas class="deep-field" id="deep-field" aria-hidden="true"></canvas>
  <div class="hero-content">
    <div class="hero-byline">
      <div class="hero-portrait">
        <img src="/assets/headshot.jpg" alt="David Russell" width="96" height="96" fetchpriority="high" />
      </div>
      <div class="hero-byline-text">
        David Russell<br />
        South Florida
      </div>
    </div>

    <h1 id="hero-title">I build useful things, then write down what survived contact with reality.</h1>

    <p class="identity-line">
      CEO of Let's Chat, content creator, indie operator. South Florida.
    </p>

    <div class="lane-grid" aria-label="Ways into the site">
      {lanes.map((lane) => (
        <a class="lane-card" href={lane.href}>
          <span>{lane.label}</span>
          <strong>{lane.title}</strong>
          <small>{lane.detail}</small>
        </a>
      ))}
    </div>
  </div>

  <a class="scroll-cue" href="#featured-work" id="scroll-cue" aria-label="Scroll to keep reading">
    <span>Scroll to keep reading</span>
  </a>
</section>

<script>
  (() => {
    type Star = {
      x: number;
      y: number;
      r: number;
      base: number;      // base alpha
      twinkle: number;   // twinkle phase offset
      depth: number;     // 0 (far) – 1 (near), drives parallax magnitude
    };

    const boot = () => {
      const canvas = document.getElementById("deep-field") as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext("2d", { alpha: true });
      if (!ctx) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const pointer = { x: 0.5, y: 0.5, active: false };
      const target = { x: 0.5, y: 0.5 };
      let width = 0;
      let height = 0;
      let dpr = 1;
      let frame = 0;
      let raf = 0;
      let stars: Star[] = [];

      const seedStars = () => {
        const area = width * height;
        // Density tuned for ~340 stars on a 1280x800 hero
        const count = Math.min(520, Math.max(140, Math.floor(area / 2900)));
        stars = new Array(count).fill(0).map(() => {
          const depth = Math.random();
          const r = depth > 0.85 ? 1.6 + Math.random() * 0.8 : 0.4 + Math.random() * 1.0;
          return {
            x: Math.random(),
            y: Math.random(),
            r,
            base: 0.25 + Math.random() * 0.55 * depth,
            twinkle: Math.random() * Math.PI * 2,
            depth,
          };
        });
      };

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = Math.max(1, Math.floor(rect.width));
        height = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        seedStars();
      };

      const draw = () => {
        frame += prefersReduced ? 0 : 0.008;

        // Easing pointer toward target gives smooth parallax instead of jitter
        pointer.x += (target.x - pointer.x) * 0.06;
        pointer.y += (target.y - pointer.y) * 0.06;

        ctx.clearRect(0, 0, width, height);

        // Faint nebula glow under stars
        const glow = ctx.createRadialGradient(
          width * 0.75, height * 0.15, 0,
          width * 0.75, height * 0.15, Math.max(width, height) * 0.65
        );
        glow.addColorStop(0, "rgba(91, 141, 239, 0.16)");
        glow.addColorStop(0.6, "rgba(91, 141, 239, 0.02)");
        glow.addColorStop(1, "rgba(10, 14, 26, 0)");
        ctx.fillStyle = glow;
        ctx.fillRect(0, 0, width, height);

        // Stars
        const parallaxX = (pointer.x - 0.5) * 28;
        const parallaxY = (pointer.y - 0.5) * 22;

        for (const s of stars) {
          const px = s.x * width + parallaxX * s.depth;
          const py = s.y * height + parallaxY * s.depth;
          const twinkle = prefersReduced ? 0 : Math.sin(frame * 2 + s.twinkle) * 0.18;
          const alpha = Math.max(0.05, Math.min(1, s.base + twinkle));

          // Large stars get a subtle halo
          if (s.r > 1.4) {
            const halo = ctx.createRadialGradient(px, py, 0, px, py, s.r * 4.5);
            halo.addColorStop(0, `rgba(245, 241, 232, ${alpha * 0.35})`);
            halo.addColorStop(1, "rgba(245, 241, 232, 0)");
            ctx.fillStyle = halo;
            ctx.beginPath();
            ctx.arc(px, py, s.r * 4.5, 0, Math.PI * 2);
            ctx.fill();
          }

          ctx.fillStyle = `rgba(245, 241, 232, ${alpha})`;
          ctx.beginPath();
          ctx.arc(px, py, s.r, 0, Math.PI * 2);
          ctx.fill();
        }

        if (!prefersReduced) raf = window.requestAnimationFrame(draw);
      };

      const move = (event: PointerEvent) => {
        const rect = canvas.getBoundingClientRect();
        target.x = (event.clientX - rect.left) / rect.width;
        target.y = (event.clientY - rect.top) / rect.height;
        pointer.active = true;
      };

      resize();
      draw();
      window.addEventListener("resize", resize, { passive: true });
      canvas.addEventListener("pointermove", move, { passive: true });
      canvas.addEventListener("pointerleave", () => {
        target.x = 0.5;
        target.y = 0.5;
        pointer.active = false;
      });
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) window.cancelAnimationFrame(raf);
        else if (!prefersReduced) draw();
      });
    };

    const scrollCue = document.getElementById("scroll-cue");
    const fadeCue = () => scrollCue?.classList.add("is-hidden");
    window.addEventListener("scroll", fadeCue, { once: true, passive: true });

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(boot, { timeout: 900 });
    } else {
      globalThis.setTimeout(boot, 120);
    }
  })();
</script>
