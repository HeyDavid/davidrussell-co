---
import HeroAsteroids from "@/components/HeroAsteroids.astro";
---

<section class="hero" aria-labelledby="hero-title">
  <HeroAsteroids />
  <div class="hero-meta">
    <div class="hero-portrait">
      <img src="/assets/headshot.jpg" alt="David Russell" width="96" height="96" fetchpriority="high" />
    </div>
    <div class="hero-meta-text">
      <span class="hero-meta-name">David Russell</span>
      <span class="hero-meta-loc">South Florida · Operator + writer</span>
    </div>
    <div class="hero-meta-status">
      <span class="status-dot"></span>
      <span class="status-text">Open to a few projects in 2026</span>
    </div>
  </div>

  <h1 class="hero-h1" id="hero-title">
    Hi, I'm <span class="hero-h1-accent">David</span>.
  </h1>

  <p class="hero-tagline">
    I build <em>best-in-class</em> websites and marketing funnels, and write
    about how — and what actually moves the needle.
  </p>

  <div class="hero-credentials">
    <div class="cred-item">
      <span class="cred-value">$400K+</span>
      <span class="cred-label">marketplace I grew</span>
    </div>
    <div class="cred-divider" aria-hidden="true"></div>
    <div class="cred-item">
      <span class="cred-value">10 years</span>
      <span class="cred-label">marketing operator</span>
    </div>
    <div class="cred-divider" aria-hidden="true"></div>
    <div class="cred-item">
      <span class="cred-value">Dozens</span>
      <span class="cred-label">industries consulted</span>
    </div>
  </div>

  <form class="hero-subscribe" id="hero-subscribe-form" aria-labelledby="subscribe-title">
    <label for="hero-email" class="hero-subscribe-label">
      <span id="subscribe-title">Get essays, debates, and flow logs. No schedule, no spam.</span>
    </label>
    <div class="hero-subscribe-row">
      <input
        id="hero-email"
        type="email"
        name="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
      />
      <button type="submit" data-event="newsletter-signup">Subscribe</button>
    </div>
    <p class="hero-subscribe-status" id="hero-subscribe-status" role="status" aria-live="polite" hidden></p>
  </form>

  <div class="hero-secondary-ctas">
    <a href="/work-with-me/marketing/" class="hero-cta-primary">
      <span>Hire me for marketing</span>
      <span class="arrow">→</span>
    </a>
    <div class="hero-cta-quiet">
      <a href="/work-with-me/recruiting/">Open to recruiting</a>
      <span aria-hidden="true">·</span>
      <a href="/work-with-me/investing/">Open to invest opportunities</a>
    </div>
  </div>

  <a class="scroll-cue" href="#work-with-me" id="scroll-cue" aria-label="Scroll to keep reading">
    <span>Keep reading</span>
  </a>
</section>

<style>
  /* Hero — centered narrow column. Content stays left-aligned inside the
     column so reading feels natural, but the column is centered on the
     page so there's no "abandoned right side" empty space. */
  .hero {
    text-align: left;
    max-width: 820px;
    margin: 0 auto;
    position: relative;
  }
  /* Hero content sits above the asteroid canvas */
  .hero-meta,
  .hero-h1,
  .hero-tagline,
  .hero-credentials,
  .hero-subscribe,
  .hero-secondary-ctas {
    position: relative;
    z-index: 2;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px 18px;
    margin-bottom: clamp(36px, 6vw, 64px);
  }
  .hero-portrait {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 24%;
    display: block;
  }
  .hero-meta-text {
    display: grid;
    gap: 2px;
    min-width: 0;
  }
  .hero-meta-name {
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--star);
    letter-spacing: -0.01em;
  }
  .hero-meta-loc {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--mist);
  }
  .hero-meta-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(46, 227, 122, 0.07);
    border: 1px solid rgba(46, 227, 122, 0.18);
    color: var(--star);
    font-size: 12.5px;
    white-space: nowrap;
  }
  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2ee37a;
    box-shadow: 0 0 6px rgba(46, 227, 122, 0.45);
  }

  /* The display title — the lateral move. Two words, declarative, huge.
     "Deep operator." owns the brand thesis without being a SaaS tagline. */
  .hero-h1 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(64px, 11vw, 132px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 0 0 clamp(28px, 4vw, 44px);
    color: var(--star);
    max-width: 14ch;
  }
  .hero-h1-accent {
    color: var(--signal);
  }

  .hero-tagline {
    font-family: var(--sans);
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.012em;
    color: var(--star);
    max-width: 32ch;
    margin-bottom: clamp(36px, 5vw, 56px);
  }
  .hero-tagline em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--signal);
  }

  /* Credentials strip — horizontal, no card chrome, divided by vertical
     rules. This is the only visual where stats appear; the Background
     section won't repeat them as cards. */
  .hero-credentials {
    display: flex;
    align-items: stretch;
    gap: clamp(20px, 3vw, 40px);
    margin-bottom: clamp(40px, 5vw, 56px);
    flex-wrap: wrap;
  }
  .cred-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cred-value {
    font-family: var(--sans);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 500;
    letter-spacing: -0.025em;
    color: var(--star);
  }
  .cred-label {
    font-size: 13px;
    color: var(--mist);
  }
  .cred-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.1);
    align-self: stretch;
  }

  /* Subscribe form — full intent, wider, less crammed */
  .hero-subscribe {
    max-width: 540px;
  }

  /* Secondary CTAs — primary "Hire me" button + two quieter audience links.
     Welsh-style: one dominant action, two quieter alternates underneath. */
  .hero-secondary-ctas {
    margin-top: clamp(28px, 4vw, 40px);
    display: grid;
    gap: 12px;
  }
  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    padding: 12px 20px;
    border-radius: 999px;
    border: 1px solid rgba(91, 141, 239, 0.4);
    background: rgba(91, 141, 239, 0.08);
    color: var(--star);
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    transition: background 220ms ease, border-color 220ms ease, transform 200ms var(--ease-out);
  }
  .hero-cta-primary:hover {
    background: rgba(91, 141, 239, 0.18);
    border-color: rgba(91, 141, 239, 0.6);
  }
  .hero-cta-primary .arrow {
    transition: transform 200ms var(--ease-out);
  }
  .hero-cta-primary:hover .arrow {
    transform: translateX(3px);
  }
  .hero-cta-quiet {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    color: var(--mist);
    font-size: 14px;
  }
  .hero-cta-quiet a {
    color: var(--mist);
    border-bottom: 1px solid rgba(91, 141, 239, 0.25);
  }
  .hero-cta-quiet a:hover {
    color: var(--signal);
    border-bottom-color: var(--signal);
  }
  .hero-cta-quiet span {
    color: var(--smoke);
  }

  @media (max-width: 640px) {
    .hero-meta { grid-template-columns: auto 1fr; gap: 12px 14px; }
    .hero-meta-status { grid-column: 1 / -1; justify-self: start; }
    .cred-divider { display: none; }
    .hero-credentials { gap: 20px; }
  }
</style>

<script>
  /* Scroll cue fades on first scroll */
  (() => {
    const scrollCue = document.getElementById("scroll-cue");
    const fadeCue = () => scrollCue?.classList.add("is-hidden");
    window.addEventListener("scroll", fadeCue, { once: true, passive: true });
  })();

  /* Hero subscribe form */
  (() => {
    const form = document.getElementById("hero-subscribe-form") as HTMLFormElement | null;
    const status = document.getElementById("hero-subscribe-status") as HTMLElement | null;
    if (!form || !status) return;
    const BEEHIIV_PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = String(data.get("email") ?? "").trim();
      if (!email) return;

      const button = form.querySelector("button");
      if (button) {
        button.disabled = true;
        button.textContent = "Sending";
      }

      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("utm_medium", "hero-subscribe");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", "davidrussell.co/hero");

      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: "POST",
        mode: "no-cors",
        body: data,
      }).finally(() => {
        form.reset();
        status.hidden = false;
        status.textContent = "Got it. Check your inbox to confirm.";
        if (button) {
          button.disabled = false;
          button.textContent = "Subscribe";
        }
      });
    });
  })();
</script>
