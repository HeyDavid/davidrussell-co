---
const today = new Date().toLocaleDateString("en-US", { month: "long", year: "numeric" });
---

<section class="cover" aria-labelledby="cover-name">
  <div class="cover-dateline">
    <span>The Field Almanac</span>
    <span class="sep">/</span>
    <span><b>No.&nbsp;01</b></span>
    <span class="sep">/</span>
    <span>Coral Springs, Fla.</span>
    <span class="sep">/</span>
    <span>An operator&rsquo;s running record</span>
    <span class="sep">/</span>
    <span>Updated {today}</span>
  </div>

  <div class="nameplate">
    <h1 id="cover-name">David Russell</h1>
  </div>

  <div class="cover-standfirst">
    <span>Operator · builder · writer</span>
    <span>Marketing for a decade · still curious</span>
  </div>

  <div class="cover-body">
    <div class="cover-col">
      <p class="cover-lede">
        Solo founder in South Florida. I run, I build, and I try to have fun
        about it. A decade in marketing — I grew a Wix site into a
        <strong>$400K+ marketplace</strong> across dozens of industries.
        These days I&rsquo;m shipping <a href="https://letschatmarketing.com" target="_blank" rel="noopener">Let&rsquo;s&nbsp;Chat</a>
        and a few smaller ventures, in plain sight.
      </p>

      <div class="cover-meta">
        <div class="subscribe-line">
          <div class="subscribe-note">Dispatches from the workbench — a few a month, never spam.</div>
          <form class="field-rule" id="hero-subscribe-form" aria-label="Subscribe" onsubmit="return false;">
            <input
              id="hero-email"
              type="email"
              name="email"
              autocomplete="email"
              placeholder="your email"
              aria-label="Email address"
              required
            />
            <button type="submit" data-event="newsletter-signup">Subscribe →</button>
          </form>
          <p class="subscribe-status" id="hero-subscribe-status" role="status" aria-live="polite" hidden></p>
        </div>

        <div class="cover-avail">
          <a href="/work-with-me/marketing/">Available for marketing work</a>
          <span class="sep">·</span>
          <a href="/work-with-me/recruiting/">Open to recruiting</a>
        </div>
      </div>
    </div>

    <figure class="plate">
      <div class="plate-frame">
        <img src="/assets/headshot.jpg" alt="David Russell" width="600" height="750" fetchpriority="high" />
      </div>
      <figcaption class="plate-caption">
        <span><b>Fig. 1</b> — D. Russell</span>
        <span>Coral Springs, 2026</span>
      </figcaption>
    </figure>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById("hero-subscribe-form") as HTMLFormElement | null;
    const status = document.getElementById("hero-subscribe-status") as HTMLElement | null;
    if (!form || !status) return;
    const BEEHIIV_PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = String(data.get("email") ?? "").trim();
      if (!email) return;

      const button = form.querySelector("button");
      if (button) { button.disabled = true; button.textContent = "Sending…"; }

      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("utm_medium", "hero-subscribe");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", "davidrussell.co/hero");

      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: "POST",
        mode: "no-cors",
        body: data,
      }).finally(() => {
        form.reset();
        status.hidden = false;
        status.textContent = "Got it. Check your inbox to confirm.";
        if (button) { button.disabled = false; button.textContent = "Subscribe →"; }
      });
    });
  })();
</script>
