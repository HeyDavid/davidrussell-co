---
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-grid">
    <!-- Photo — LEFT, facing the text -->
    <div class="hero-image">
      <img
        src="/assets/headshot.jpg"
        alt="David Russell"
        width="600"
        height="750"
        fetchpriority="high"
      />
    </div>

    <!-- Text — RIGHT -->
    <div class="hero-text">
      <div class="hero-identity">
        <h1 class="hero-name" id="hero-title">David Russell</h1>
        <p class="hero-loc">South Florida · Operator + writer</p>
      </div>

      <p class="hero-lede">
        Solo founder in South Florida. I run, I build, I try to have fun
        about it. Marketer for a decade. Grew a Wix site into a
        <strong>$400K+ marketplace</strong>. Dozens of industries.
        Currently shipping
        <a href="https://letschatmarketing.com" target="_blank" rel="noopener">Let's Chat</a>
        and a few smaller ventures.
      </p>

      <form
        class="capture"
        id="hero-subscribe-form"
        aria-labelledby="subscribe-title"
        onsubmit="return false;"
      >
        <input
          id="hero-email"
          type="email"
          name="email"
          autocomplete="email"
          placeholder="your email — get new posts first"
          aria-label="Email address"
          required
        />
        <button type="submit" data-event="newsletter-signup">Subscribe</button>
      </form>
      <p
        class="subscribe-status"
        id="hero-subscribe-status"
        role="status"
        aria-live="polite"
        hidden
      ></p>

      <div class="hero-cta-quiet">
        <a href="/work-with-me/marketing/">Available for marketing work</a>
        <span aria-hidden="true">·</span>
        <a href="/work-with-me/recruiting/">Open to recruiting</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(48px, 8vw, 96px) clamp(24px, 5vw, 80px) clamp(48px, 6vw, 80px);
    max-width: var(--max);
    margin: 0 auto;
  }

  /* Asymmetric: photo on left, text on right. Photo looks toward the subscribe form. */
  .hero-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(48px, 7vw, 96px);
    align-items: center;
  }

  .hero-image {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(44, 36, 23, 0.16);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }
  /* Subtle vignette */
  .hero-image::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, rgba(44, 36, 23, 0.08));
    pointer-events: none;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .hero-identity { display: flex; flex-direction: column; gap: 4px; }
  .hero-name {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.06;
    color: var(--ink);
  }
  .hero-loc {
    font-size: 14px;
    color: var(--ink-faint);
  }

  .hero-lede {
    font-size: clamp(17px, 1.8vw, 21px);
    color: var(--ink-soft);
    max-width: 52ch;
    line-height: 1.60;
    margin: 0;
  }
  .hero-lede strong { color: var(--ink); font-weight: 500; }
  .hero-lede a {
    color: var(--ink);
    border-bottom: 1px solid rgba(199, 93, 60, 0.35);
  }
  .hero-lede a:hover { color: var(--accent); border-bottom-color: var(--accent); }

  .hero-cta-quiet {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 14px;
    color: var(--ink-faint);
  }
  .hero-cta-quiet a {
    color: var(--ink-soft);
    border-bottom: 1px solid var(--border);
  }
  .hero-cta-quiet a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .hero-cta-quiet span { color: var(--ink-faint); }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-image {
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>

<script>
  (() => {
    const form = document.getElementById("hero-subscribe-form") as HTMLFormElement | null;
    const status = document.getElementById("hero-subscribe-status") as HTMLElement | null;
    if (!form || !status) return;
    const BEEHIIV_PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = String(data.get("email") ?? "").trim();
      if (!email) return;

      const button = form.querySelector("button");
      if (button) { button.disabled = true; button.textContent = "Sending…"; }

      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("utm_medium", "hero-subscribe");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", "davidrussell.co/hero");

      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: "POST",
        mode: "no-cors",
        body: data,
      }).finally(() => {
        form.reset();
        status.hidden = false;
        status.textContent = "Got it. Check your inbox to confirm.";
        if (button) { button.disabled = false; button.textContent = "Subscribe"; }
      });
    });
  })();
</script>
