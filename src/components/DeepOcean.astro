---
/*
  DeepOcean — second canvas layer that fades in as the user scrolls past the
  hero. Renders slow upward-drifting sea particles (think suspended plankton
  in a midnight-zone dive). Tinted blue-green to differentiate from the
  warm-white stars in the hero. Fixed positioning so it stays anchored to the
  viewport, opacity tied to scroll progress so the transition from "outer
  space" to "deep ocean" reads as one continuous descent.
*/
---

<canvas class="deep-ocean" id="deep-ocean" aria-hidden="true"></canvas>

<script>
  (() => {
    type Mote = {
      x: number;          // 0–1
      y: number;          // 0–1, wraps
      r: number;
      base: number;       // base alpha
      drift: number;      // upward speed
      sway: number;       // lateral sway frequency
      swayPhase: number;
      depth: number;
    };

    const boot = () => {
      const canvas = document.getElementById("deep-ocean") as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext("2d", { alpha: true });
      if (!ctx) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let width = 0, height = 0, dpr = 1, frame = 0, raf = 0;
      let motes: Mote[] = [];
      let scrollProgress = 0; // 0 (at hero) → 1 (at footer)

      const seed = () => {
        const area = width * height;
        const count = Math.min(160, Math.max(48, Math.floor(area / 9000)));
        motes = new Array(count).fill(0).map(() => {
          const depth = Math.random();
          return {
            x: Math.random(),
            y: Math.random(),
            r: 0.3 + Math.random() * 0.9,
            base: 0.12 + Math.random() * 0.32 * depth,
            drift: 0.00006 + Math.random() * 0.00018,
            sway: 0.3 + Math.random() * 0.8,
            swayPhase: Math.random() * Math.PI * 2,
            depth,
          };
        });
      };

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = Math.max(1, Math.floor(rect.width));
        height = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        seed();
      };

      const computeScroll = () => {
        const doc = document.documentElement;
        const scrolled = window.scrollY;
        const total = Math.max(1, doc.scrollHeight - window.innerHeight);
        scrollProgress = Math.max(0, Math.min(1, scrolled / total));
      };

      const draw = () => {
        frame += prefersReduced ? 0 : 1;

        // Fade in past hero (~vh 0.6), full strength by 0.4 scroll
        const heroOut = Math.min(1, Math.max(0, (scrollProgress - 0.06) / 0.34));
        canvas.style.opacity = heroOut.toFixed(3);

        ctx.clearRect(0, 0, width, height);

        if (heroOut <= 0.01) {
          if (!prefersReduced) raf = window.requestAnimationFrame(draw);
          return;
        }

        // Subtle teal-blue caustic glow at the bottom (deeper light scatter)
        const causticGradient = ctx.createRadialGradient(
          width * 0.5, height * 1.05, 0,
          width * 0.5, height * 1.05, Math.max(width, height) * 0.85
        );
        causticGradient.addColorStop(0, "rgba(64, 138, 168, 0.10)");
        causticGradient.addColorStop(0.5, "rgba(46, 110, 138, 0.04)");
        causticGradient.addColorStop(1, "rgba(3, 18, 24, 0)");
        ctx.fillStyle = causticGradient;
        ctx.fillRect(0, 0, width, height);

        for (const m of motes) {
          // Drift upward (slow ascent)
          m.y -= m.drift * (prefersReduced ? 0 : 1);
          if (m.y < -0.02) { m.y = 1.02; m.x = Math.random(); }

          // Lateral sway like organic suspension
          const sway = prefersReduced ? 0 : Math.sin(frame * 0.004 * m.sway + m.swayPhase) * 6;

          const px = m.x * width + sway * m.depth;
          const py = m.y * height;

          const alpha = m.base * (0.55 + heroOut * 0.45);

          // Mote color: pale teal-green, like distant phosphorescence
          ctx.fillStyle = `rgba(150, 220, 220, ${alpha})`;
          ctx.beginPath();
          ctx.arc(px, py, m.r, 0, Math.PI * 2);
          ctx.fill();

          // Brightest motes get a small glow
          if (m.r > 0.85) {
            const halo = ctx.createRadialGradient(px, py, 0, px, py, m.r * 4);
            halo.addColorStop(0, `rgba(150, 220, 220, ${alpha * 0.35})`);
            halo.addColorStop(1, "rgba(150, 220, 220, 0)");
            ctx.fillStyle = halo;
            ctx.beginPath();
            ctx.arc(px, py, m.r * 4, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        if (!prefersReduced) raf = window.requestAnimationFrame(draw);
      };

      resize();
      computeScroll();
      draw();
      window.addEventListener("resize", resize, { passive: true });
      window.addEventListener("scroll", computeScroll, { passive: true });
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) window.cancelAnimationFrame(raf);
        else if (!prefersReduced) draw();
      });
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(boot, { timeout: 1400 });
    } else {
      globalThis.setTimeout(boot, 200);
    }
  })();
</script>

<style>
  .deep-ocean {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 800ms ease;
    mix-blend-mode: screen;
  }
</style>
