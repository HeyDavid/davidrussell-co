---
type Work = {
  name: string;
  url: string;
  href: string;
  note: string;
};

const work: Work[] = [
  {
    name: "Let's Chat",
    url: "letschatmarketing.com",
    href: "https://letschatmarketing.com",
    note: "Productized marketing for service businesses.",
  },
  {
    name: "Maker Margin",
    url: "makermargin.co",
    href: "https://makermargin.co",
    note: "Tools for Etsy sellers and creative operators.",
  },
  {
    name: "Thomas Steed",
    url: "thomassteed.com",
    href: "https://thomassteed.com",
    note: "A personal site with a clean editorial spine.",
  },
];
---

<section class="entry featured-work" id="featured-work" aria-labelledby="featured-title">
  <div class="section-kicker">Featured work</div>
  <h2 id="featured-title">Live things, not screenshots.</h2>
  <p>
    A short selection of current builds and client-style experiments. Each preview is the live site scaled down so the work has to stand on its own.
  </p>

  <div class="preview-grid">
    {work.map((item) => (
      <article class="preview-card">
        <a class="preview-frame" href={item.href} target="_blank" rel="noopener" aria-label={`View ${item.name} live`}>
          <iframe
            data-src={item.href}
            title={`${item.name} live preview`}
            loading="lazy"
            referrerpolicy="no-referrer"
            tabindex="-1"
          ></iframe>
          <span class="preview-overlay">View live</span>
        </a>
        <div class="preview-copy">
          <h3>{item.name}</h3>
          <span>{item.url}</span>
          <p>{item.note}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  (() => {
    const frames = Array.from(document.querySelectorAll<HTMLIFrameElement>(".preview-frame iframe[data-src]"));
    if (frames.length === 0) return;

    const loadFrame = (frame: HTMLIFrameElement) => {
      const src = frame.dataset.src;
      if (!src || frame.src) return;
      frame.src = src;
    };

    if (!("IntersectionObserver" in window)) {
      globalThis.setTimeout(() => frames.forEach(loadFrame), 1800);
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const frame = entry.target as HTMLIFrameElement;
          loadFrame(frame);
          observer.unobserve(frame);
        }
      },
      { rootMargin: "280px 0px" }
    );

    frames.forEach((frame) => observer.observe(frame));
  })();
</script>
