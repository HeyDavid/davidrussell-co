---
type Venture = { name: string; meta: string; live: boolean; desc: string; href: string };

const ventures: Venture[] = [
  {
    name: "Let's Chat",
    meta: "agency",
    live: true,
    desc: "Productized marketing for service businesses. Modern websites, AI receptionists, and the outreach engine behind them.",
    href: "https://letschatmarketing.com",
  },
  {
    name: "Maker Margin",
    meta: "tool",
    live: true,
    desc: "A free Etsy fee calculator. Saves sellers a lot of confusion — and a few thousand dollars.",
    href: "https://makermargin.co",
  },
  {
    name: "ScamCapital",
    meta: "resource",
    live: true,
    desc: "A scam-education hub. Playbooks on common scams, plus an interactive quiz designed to fool you.",
    href: "https://scamcapital.com",
  },
  {
    name: "In the workshop",
    meta: "next",
    live: false,
    desc: "The next small thing. Subscribe up top and you'll see it before anyone else.",
    href: "#",
  },
];
---

<section class="movement reveal" id="building" aria-labelledby="building-title">
  <div class="movement-grid">
    <div class="movement-head">
      <span class="numeral" aria-hidden="true">II</span>
      <span class="kicker">building</span>
      <p class="margin-note">Small, focused ventures. <b>Run in public</b>, not pitched in private.</p>
    </div>
    <div class="movement-body">
      <h2 class="movement-title" id="building-title">What I&rsquo;m working on, in plain sight.</h2>
      <ul class="catalog">
        {ventures.map((v) => (
          <li class={`catalog-row${v.live ? "" : " is-dim"}`}>
            {v.live ? (
              <a class="catalog-line" href={v.href} target="_blank" rel="noopener">
                <span class="catalog-name">{v.name}</span>
                <span class="catalog-leader" aria-hidden="true"></span>
                <span class="catalog-meta">{v.meta} · <span class="live">live</span></span>
              </a>
            ) : (
              <div class="catalog-line">
                <span class="catalog-name">{v.name}</span>
                <span class="catalog-leader" aria-hidden="true"></span>
                <span class="catalog-meta">{v.meta} · soon</span>
              </div>
            )}
            <p class="catalog-desc">{v.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
