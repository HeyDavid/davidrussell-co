---
type Venture = {
  tag: string;
  name: string;
  desc: string;
  href: string;
  live: boolean;
};

const ventures: Venture[] = [
  {
    tag: "Agency",
    name: "Let's Chat",
    desc: "Productized marketing for service businesses. Modern websites, AI receptionists, and the outreach engine behind them.",
    href: "https://letschatmarketing.com",
    live: true,
  },
  {
    tag: "Tool",
    name: "Maker Margin",
    desc: "A free Etsy fee calculator. Saves sellers a lot of confusion — and a few thousand dollars.",
    href: "https://makermargin.co",
    live: true,
  },
  {
    tag: "Resource",
    name: "ScamCapital",
    desc: "A scam-education hub. Playbooks on common scams plus an interactive quiz that's designed to fool you.",
    href: "https://scamcapital.com",
    live: true,
  },
  {
    tag: "Something new",
    name: "In the workshop",
    desc: "The next small thing. Subscribe up top and you'll see it before anyone else.",
    href: "#",
    live: false,
  },
];
---

<section class="card reveal reveal-delay-1" id="building" aria-labelledby="building-title">
  <div class="section-head">
    <span class="section-num" aria-hidden="true">2.</span>
    <span class="section-label">Building</span>
  </div>
  <h2 id="building-title">What I'm working on, in plain sight.</h2>

  <div class="card-grid">
    {ventures.map((v) => (
      <a
        href={v.href}
        class={`venture-card${!v.live ? " venture-card--dim" : ""}`}
        target={v.live ? "_blank" : undefined}
        rel={v.live ? "noopener" : undefined}
        aria-label={`${v.name} — ${v.desc}`}
      >
        <div class="venture-tag">{v.tag}</div>
        <div class="venture-name">{v.name}</div>
        <div class="venture-desc">{v.desc}</div>
      </a>
    ))}
  </div>
</section>

<style>
  .venture-card--dim { opacity: 0.55; pointer-events: none; }
</style>
