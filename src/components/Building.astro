---
type Venture = {
  num: string;
  tag: string;
  href: string;
  name: string;
  url: string;
  desc: string;
  muted?: boolean;
};

const ventures: Venture[] = [
  {
    num: "01",
    tag: "Agency",
    href: "https://letschatmarketing.com",
    name: "Let’s Chat Marketing",
    url: "letschatmarketing.com",
    desc: "A productized marketing agency for service businesses. Modern websites, AI receptionists, sharp consulting. Verticals include Let’s Smile (dental), Let’s Counsel (legal), and Let’s Fix (home services).",
  },
  {
    num: "02",
    tag: "Tools",
    href: "https://makermargin.co",
    name: "Maker Margin",
    url: "makermargin.co",
    desc: "A suite of tools for creative entrepreneurs. Starting with a free Etsy fee calculator. Quietly compounding.",
  },
  {
    num: "03",
    tag: "Resource",
    href: "https://scamcapital.com",
    name: "ScamCapital",
    url: "scamcapital.com",
    desc: "Scam-education hub. Playbooks on the common cons, plus an interactive quiz designed to fool you so the pattern sticks.",
  },
  {
    num: "04",
    tag: "Incubating",
    href: "#hero-subscribe",
    name: "New ideas in incubation",
    url: "subscribe to see them first",
    desc: "The next small thing. Newsletter subscribers see it before anyone else. Open to partners and investors.",
    muted: true,
  },
];
---

<section class="entry" id="building">
  <h2>What I&rsquo;m building right now.</h2>
  <ol class="ventures-list">
    {ventures.map((v) => (
      <li class:list={[v.muted ? "venture-muted" : ""]}>
        <div class="venture-num">{v.num}</div>
        <div class="venture-body">
          <div class="venture-name"><a href={v.href}>{v.name}</a></div>
          <div class="venture-url font-mono">{v.url}</div>
          <div class="venture-desc">{v.desc}</div>
        </div>
        <div class="venture-tag">{v.tag}</div>
      </li>
    ))}
  </ol>
</section>
