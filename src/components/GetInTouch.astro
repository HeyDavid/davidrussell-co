---
---

<section class="movement reveal" id="find-me" aria-labelledby="find-title">
  <div class="movement-grid">
    <div class="movement-head">
      <span class="numeral" aria-hidden="true">V</span>
      <span class="kicker">find me</span>
      <p class="margin-note">Drop a line, or <b>subscribe</b> and read along.</p>
    </div>
    <div class="movement-body">
      <h2 class="movement-title" id="find-title">Doors are open. <em>Most of them, anyway.</em></h2>

      <div class="find-grid">
        <div>
          <p class="find-invite">
            Best way to start a conversation: drop your email below, or just say hello directly.
          </p>
          <div class="socials">
            <a href="mailto:david@letschatmarketing.com">email<span class="arrow">→</span></a>
            <a href="https://www.linkedin.com/in/heydavidr/" target="_blank" rel="noopener">linkedin<span class="arrow">→</span></a>
            <a href="https://x.com/heydavidr" target="_blank" rel="noopener">x / twitter<span class="arrow">→</span></a>
            <a href="https://github.com/HeyDavid" target="_blank" rel="noopener">github<span class="arrow">→</span></a>
          </div>
        </div>

        <form class="contact-form" id="contact-form">
          <label>
            <span class="lab">Email</span>
            <input type="email" name="email" autocomplete="email" placeholder="you@example.com" required />
          </label>
          <label>
            <span class="lab">Message (optional)</span>
            <input type="text" name="message" placeholder="What are you building?" maxlength="160" />
          </label>
          <button type="submit" data-event="newsletter-signup">Subscribe</button>
          <p class="subscribe-status" id="contact-status" role="status" aria-live="polite" hidden></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("contact-status") as HTMLElement | null;
    if (!form || !status) return;

    const BEEHIIV_PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = String(data.get("email") ?? "").trim();
      if (!email) return;

      const button = form.querySelector("button");
      if (button) { button.disabled = true; button.textContent = "Sending…"; }

      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", "davidrussell.co/contact");

      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: "POST",
        mode: "no-cors",
        body: data,
      }).finally(() => {
        form.reset();
        status.hidden = false;
        status.textContent = "Got it. Check your inbox to confirm.";
        if (button) { button.disabled = false; button.textContent = "Subscribe"; }
      });
    });
  })();
</script>
