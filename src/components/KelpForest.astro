---
/*
  KelpForest — swaying vertical fronds in the lower half. Click a frond and
  4–6 tadpoles swim in from random viewport edges, nibble at the kelp for
  a couple seconds, then disperse and fade.

  Standalone canvas for the /deep experimental page.
*/
---

<canvas class="kelp-forest" id="kelp-forest" aria-hidden="true"></canvas>

<style>
  .kelp-forest {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 700ms ease;
  }
</style>

<script>
  (() => {
    type Tadpole = {
      x: number; y: number;
      vx: number; vy: number;
      targetX: number; targetY: number;
      state: "approach" | "nibble" | "leave";
      t: number;       // state timer in seconds-ish
      phase: number;   // wiggle phase
    };
    type Kelp = {
      baseX: number;             // normalized 0–1
      height: number;            // px tall (from bottom)
      width: number;
      swayPhase: number;
      swayAmount: number;        // px lateral sway
      hue: [number, number, number];
      tadpoles: Tadpole[];
      feedingUntil: number;      // frame index
    };

    const boot = () => {
      const canvas = document.getElementById("kelp-forest") as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext("2d", { alpha: true });
      if (!ctx) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let width = 0, height = 0, dpr = 1, frame = 0, raf = 0;
      let kelps: Kelp[] = [];
      let scrollIn = 0;

      const seed = () => {
        kelps = [];
        const count = 6;
        const HUES: [number, number, number][] = [
          [60, 130, 90],   // deep moss green
          [80, 160, 110],  // brighter green
          [50, 110, 100],  // teal-green
          [70, 150, 130],  // sea green
        ];
        for (let i = 0; i < count; i++) {
          const baseX = 0.06 + (i / (count - 1)) * 0.88 + (Math.random() - 0.5) * 0.04;
          kelps.push({
            baseX,
            height: 180 + Math.random() * 220,
            width: 3 + Math.random() * 4,
            swayPhase: Math.random() * Math.PI * 2,
            swayAmount: 14 + Math.random() * 18,
            hue: HUES[Math.floor(Math.random() * HUES.length)],
            tadpoles: [],
            feedingUntil: 0,
          });
        }
      };

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = Math.max(1, Math.floor(rect.width));
        height = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      /* Draw a kelp frond as a wavy vertical bezier-like ribbon. */
      const drawKelp = (k: Kelp) => {
        const baseX = k.baseX * width;
        const baseY = height; // anchor at bottom of viewport
        const tipY = baseY - k.height;
        const sway = prefersReduced ? 0 : Math.sin(frame * 0.008 + k.swayPhase) * k.swayAmount;
        const segments = 8;
        const [r, g, b] = k.hue;

        ctx.save();
        ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, 0.55)`;
        ctx.lineCap = "round";
        ctx.lineJoin = "round";

        // Multiple stroke widths for organic feel
        const widths = [k.width * 1.4, k.width, k.width * 0.6];
        const alphas = [0.18, 0.45, 0.8];

        for (let w = 0; w < widths.length; w++) {
          ctx.lineWidth = widths[w];
          ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${alphas[w] * (0.5 + scrollIn * 0.5)})`;
          ctx.beginPath();
          for (let i = 0; i <= segments; i++) {
            const t = i / segments;
            const y = baseY - k.height * t;
            // Sway increases up the frond + organic phase offset
            const xOffset = Math.sin(frame * 0.008 + k.swayPhase + t * 2.2) * sway * t;
            const x = baseX + xOffset;
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.stroke();
        }

        // Small "leaves" along the frond
        for (let i = 1; i < segments; i += 2) {
          const t = i / segments;
          const y = baseY - k.height * t;
          const xOffset = Math.sin(frame * 0.008 + k.swayPhase + t * 2.2) * sway * t;
          const x = baseX + xOffset;
          const side = i % 4 === 1 ? -1 : 1;
          const leafLen = 8 + Math.sin(i * 1.3) * 3;
          ctx.beginPath();
          ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${0.55 * (0.5 + scrollIn * 0.5)})`;
          ctx.lineWidth = 1.2;
          ctx.moveTo(x, y);
          ctx.quadraticCurveTo(x + side * leafLen * 0.5, y + 2, x + side * leafLen, y - 3);
          ctx.stroke();
        }

        ctx.restore();
      };

      /* Tadpole: small head with a wavy tail. */
      const drawTadpole = (t: Tadpole, scrollAlpha: number) => {
        ctx.save();
        ctx.translate(t.x, t.y);
        const heading = Math.atan2(t.vy, t.vx);
        ctx.rotate(heading);

        const wiggle = Math.sin(frame * 0.18 + t.phase) * 1.5;
        const fade = t.state === "leave" ? Math.max(0, 1 - t.t / 2) : 1;
        const alpha = 0.85 * fade * scrollAlpha;

        // Tail (curved line behind head)
        ctx.strokeStyle = `rgba(180, 220, 220, ${alpha * 0.6})`;
        ctx.lineWidth = 1.2;
        ctx.lineCap = "round";
        ctx.beginPath();
        ctx.moveTo(-1.5, 0);
        ctx.quadraticCurveTo(-4, wiggle, -7, wiggle * 1.4);
        ctx.stroke();

        // Head
        ctx.fillStyle = `rgba(200, 230, 220, ${alpha})`;
        ctx.beginPath();
        ctx.ellipse(0, 0, 2.2, 1.6, 0, 0, Math.PI * 2);
        ctx.fill();

        ctx.restore();
      };

      const spawnTadpoles = (k: Kelp, count: number) => {
        const baseX = k.baseX * width;
        const midY = height - k.height * 0.55;
        for (let i = 0; i < count; i++) {
          // Spawn from random edge of viewport
          const edge = Math.floor(Math.random() * 4);
          let x = 0, y = 0;
          if (edge === 0) { x = -20; y = height * 0.4 + Math.random() * height * 0.55; }
          else if (edge === 1) { x = width + 20; y = height * 0.4 + Math.random() * height * 0.55; }
          else if (edge === 2) { x = Math.random() * width; y = height + 20; }
          else { x = Math.random() * width; y = height * 0.35 + Math.random() * 60; }

          const dx = baseX - x;
          const dy = midY - y;
          const dist = Math.hypot(dx, dy) || 1;
          const speed = 1.0 + Math.random() * 0.8;

          k.tadpoles.push({
            x, y,
            vx: (dx / dist) * speed,
            vy: (dy / dist) * speed,
            targetX: baseX + (Math.random() - 0.5) * 24,
            targetY: midY + (Math.random() - 0.5) * k.height * 0.4,
            state: "approach",
            t: 0,
            phase: Math.random() * Math.PI * 2,
          });
        }
        k.feedingUntil = frame + 240; // ~4s of nibbling
      };

      const updateTadpole = (t: Tadpole, k: Kelp) => {
        if (t.state === "approach") {
          const dx = t.targetX - t.x;
          const dy = t.targetY - t.y;
          const dist = Math.hypot(dx, dy);
          if (dist < 12) {
            t.state = "nibble";
            t.t = 0;
          } else {
            const speed = 1.2;
            t.vx = (dx / dist) * speed;
            t.vy = (dy / dist) * speed;
            t.x += t.vx;
            t.y += t.vy;
          }
        } else if (t.state === "nibble") {
          t.t += 1 / 60;
          // Small random nibble motion
          t.vx = (Math.random() - 0.5) * 1.2;
          t.vy = (Math.random() - 0.5) * 1.2;
          t.x += t.vx * 0.4;
          t.y += t.vy * 0.4;
          if (t.t > 1.8 || frame > k.feedingUntil) {
            // Leave toward a random edge
            const edge = Math.floor(Math.random() * 4);
            let tx = 0, ty = 0;
            if (edge === 0) { tx = -50; ty = t.y; }
            else if (edge === 1) { tx = width + 50; ty = t.y; }
            else if (edge === 2) { tx = t.x; ty = height + 50; }
            else { tx = t.x; ty = -50; }
            const dx = tx - t.x;
            const dy = ty - t.y;
            const dist = Math.hypot(dx, dy) || 1;
            t.vx = (dx / dist) * 1.4;
            t.vy = (dy / dist) * 1.4;
            t.state = "leave";
            t.t = 0;
          }
        } else {
          // Leave
          t.t += 1 / 60;
          t.x += t.vx;
          t.y += t.vy;
        }
      };

      const draw = () => {
        frame += prefersReduced ? 0 : 1;
        ctx.clearRect(0, 0, width, height);

        if (scrollIn <= 0.01) {
          if (!prefersReduced) raf = window.requestAnimationFrame(draw);
          return;
        }

        for (const k of kelps) {
          drawKelp(k);

          // Update + draw tadpoles
          for (let i = k.tadpoles.length - 1; i >= 0; i--) {
            const t = k.tadpoles[i];
            updateTadpole(t, k);
            drawTadpole(t, scrollIn);
            if (t.state === "leave" && t.t > 2) {
              k.tadpoles.splice(i, 1);
            }
          }
        }

        if (!prefersReduced) raf = window.requestAnimationFrame(draw);
      };

      const onClick = (event: MouseEvent) => {
        if (prefersReduced || scrollIn < 0.4) return;
        const mx = event.clientX;
        const my = event.clientY;
        for (const k of kelps) {
          const baseX = k.baseX * width;
          const sway = Math.sin(frame * 0.008 + k.swayPhase) * k.swayAmount;
          // Check if click is near the kelp band (within ~30px horizontal, in vertical range)
          const dx = Math.abs(mx - (baseX + sway * 0.5));
          if (dx < 36 && my > height - k.height - 20 && my < height + 5) {
            spawnTadpoles(k, 4 + Math.floor(Math.random() * 3));
            // Emit a custom event so the page HUD can react
            window.dispatchEvent(new CustomEvent("discovery", { detail: { kind: "kelp" } }));
            break;
          }
        }
      };

      seed();
      resize();
      draw();
      window.addEventListener("resize", resize, { passive: true });
      window.addEventListener("click", onClick);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) window.cancelAnimationFrame(raf);
        else if (!prefersReduced) draw();
      });

      // Fade in based on scroll progress
      const onScroll = () => {
        const doc = document.documentElement;
        const total = Math.max(1, doc.scrollHeight - window.innerHeight);
        const p = Math.max(0, Math.min(1, window.scrollY / total));
        scrollIn = Math.min(1, Math.max(0, (p - 0.30) / 0.28));
        canvas.style.opacity = scrollIn.toFixed(3);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(boot, { timeout: 1300 });
    } else {
      globalThis.setTimeout(boot, 200);
    }
  })();
</script>
