---
/*
  AsteroidField — drifting rocky polygons in the upper half. Click within
  proximity → asteroid shatters into debris that drifts outward, then the
  asteroid respawns at a viewport edge.

  Intended for the /deep experimental page only. Standalone canvas so it
  doesn't burden the main site.
*/
---

<canvas class="asteroid-field" id="asteroid-field" aria-hidden="true"></canvas>

<style>
  .asteroid-field {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: var(--asteroids-opacity, 1);
    transition: opacity 600ms ease;
  }
</style>

<script>
  (() => {
    type Vec = { x: number; y: number };
    type Debris = { x: number; y: number; vx: number; vy: number; r: number; t: number; rot: number; rotSpeed: number };
    type Asteroid = {
      x: number; y: number;          // normalized 0–1
      vx: number; vy: number;
      r: number;                     // base radius (px)
      rot: number;                   // current rotation
      rotSpeed: number;
      vertices: Vec[];               // unit offsets defining irregular shape
      state: "drift" | "broken";
      brokenT: number;               // 0–1 timer when broken
      debris: Debris[];
      respawnAt: number;             // frame when to respawn
    };

    const mulberry32 = (a: number) => () => {
      a |= 0; a = (a + 0x6D2B79F5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };

    const boot = () => {
      const canvas = document.getElementById("asteroid-field") as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext("2d", { alpha: true });
      if (!ctx) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let width = 0, height = 0, dpr = 1, frame = 0, raf = 0;
      let asteroids: Asteroid[] = [];

      const makeVertices = (rng: () => number, count: number): Vec[] => {
        const verts: Vec[] = [];
        for (let i = 0; i < count; i++) {
          const angle = (i / count) * Math.PI * 2;
          const radius = 0.7 + rng() * 0.5; // jaggedness
          verts.push({ x: Math.cos(angle) * radius, y: Math.sin(angle) * radius });
        }
        return verts;
      };

      const seed = () => {
        const rng = mulberry32(42424242);
        asteroids = [];
        for (let i = 0; i < 6; i++) {
          asteroids.push({
            x: rng(),
            y: 0.05 + rng() * 0.35, // upper area
            vx: (rng() - 0.5) * 0.00012,
            vy: (rng() - 0.5) * 0.00006,
            r: 9 + rng() * 16,
            rot: rng() * Math.PI * 2,
            rotSpeed: (rng() - 0.5) * 0.005,
            vertices: makeVertices(rng, 7 + Math.floor(rng() * 3)),
            state: "drift",
            brokenT: 0,
            debris: [],
            respawnAt: 0,
          });
        }
      };

      const resize = () => {
        const rect = canvas.getBoundingClientRect();
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = Math.max(1, Math.floor(rect.width));
        height = Math.max(1, Math.floor(rect.height));
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const drawAsteroidShape = (a: Asteroid, scale: number, alpha: number) => {
        ctx.save();
        ctx.globalAlpha = alpha;
        ctx.beginPath();
        for (let i = 0; i < a.vertices.length; i++) {
          const v = a.vertices[i];
          const x = v.x * a.r * scale;
          const y = v.y * a.r * scale;
          if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        }
        ctx.closePath();
        // Subtle stone gradient
        const grad = ctx.createRadialGradient(-a.r * 0.3, -a.r * 0.3, 0, 0, 0, a.r);
        grad.addColorStop(0, "rgba(110, 110, 118, 0.85)");
        grad.addColorStop(0.7, "rgba(60, 60, 68, 0.85)");
        grad.addColorStop(1, "rgba(30, 30, 35, 0.85)");
        ctx.fillStyle = grad;
        ctx.fill();
        ctx.strokeStyle = "rgba(20, 20, 24, 0.7)";
        ctx.lineWidth = 0.6;
        ctx.stroke();
        ctx.restore();
      };

      const draw = () => {
        frame += prefersReduced ? 0 : 1;
        ctx.clearRect(0, 0, width, height);

        for (const a of asteroids) {
          if (a.state === "drift") {
            if (!prefersReduced) {
              a.x += a.vx;
              a.y += a.vy;
              a.rot += a.rotSpeed;
              if (a.x > 1.1) a.x = -0.1;
              if (a.x < -0.1) a.x = 1.1;
              if (a.y > 0.6) a.y = -0.05;
              if (a.y < -0.1) a.y = 0.5;
            }
            const px = a.x * width;
            const py = a.y * height;
            ctx.save();
            ctx.translate(px, py);
            ctx.rotate(a.rot);
            drawAsteroidShape(a, 1, 0.85);
            ctx.restore();
          } else if (a.state === "broken") {
            a.brokenT += 1 / 90; // 1.5s lifespan
            for (const d of a.debris) {
              d.x += d.vx;
              d.y += d.vy;
              d.vy += 0.01; // light gravity drift
              d.rot += d.rotSpeed;
              d.t += 1 / 90;
              const alpha = Math.max(0, 1 - d.t);
              ctx.save();
              ctx.translate(d.x, d.y);
              ctx.rotate(d.rot);
              ctx.globalAlpha = alpha * 0.85;
              ctx.fillStyle = "rgba(80, 80, 88, 1)";
              ctx.strokeStyle = "rgba(20, 20, 24, 0.7)";
              ctx.lineWidth = 0.5;
              ctx.beginPath();
              for (let i = 0; i < 5; i++) {
                const ang = (i / 5) * Math.PI * 2;
                const rad = d.r * (0.7 + Math.sin(i * 1.7) * 0.25);
                const x = Math.cos(ang) * rad;
                const y = Math.sin(ang) * rad;
                if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
              }
              ctx.closePath();
              ctx.fill();
              ctx.stroke();
              ctx.restore();
            }
            if (a.brokenT >= 1 && frame >= a.respawnAt) {
              // Respawn at edge
              const side = Math.floor(Math.random() * 2);
              a.x = side === 0 ? -0.05 : 1.05;
              a.y = 0.05 + Math.random() * 0.35;
              a.vx = side === 0 ? Math.abs(a.vx) || 0.0001 : -(Math.abs(a.vx) || 0.0001);
              a.state = "drift";
              a.brokenT = 0;
              a.debris = [];
            }
          }
        }

        if (!prefersReduced) raf = window.requestAnimationFrame(draw);
      };

      const onClick = (event: MouseEvent) => {
        if (prefersReduced) return;
        const mx = event.clientX;
        const my = event.clientY;
        for (const a of asteroids) {
          if (a.state !== "drift") continue;
          const px = a.x * width;
          const py = a.y * height;
          const dist = Math.hypot(mx - px, my - py);
          if (dist < a.r + 14) {
            // Shatter
            a.state = "broken";
            a.brokenT = 0;
            a.respawnAt = frame + 180; // wait ~3s before respawn allowed
            window.dispatchEvent(new CustomEvent("discovery", { detail: { kind: "asteroid" } }));
            const pieceCount = 4 + Math.floor(Math.random() * 3);
            a.debris = [];
            for (let i = 0; i < pieceCount; i++) {
              const ang = (i / pieceCount) * Math.PI * 2 + Math.random() * 0.6;
              const speed = 0.6 + Math.random() * 1.4;
              a.debris.push({
                x: px,
                y: py,
                vx: Math.cos(ang) * speed,
                vy: Math.sin(ang) * speed - 0.3,
                r: a.r * (0.25 + Math.random() * 0.25),
                t: 0,
                rot: Math.random() * Math.PI * 2,
                rotSpeed: (Math.random() - 0.5) * 0.12,
              });
            }
            break;
          }
        }
      };

      seed();
      resize();
      draw();
      window.addEventListener("resize", resize, { passive: true });
      window.addEventListener("click", onClick);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) window.cancelAnimationFrame(raf);
        else if (!prefersReduced) draw();
      });

      // Opacity tied to scroll — present in upper half, fades out as we descend
      const onScroll = () => {
        const doc = document.documentElement;
        const total = Math.max(1, doc.scrollHeight - window.innerHeight);
        const p = Math.max(0, Math.min(1, window.scrollY / total));
        const opacity = p < 0.30 ? 1 : Math.max(0, 1 - (p - 0.30) / 0.25);
        doc.style.setProperty("--asteroids-opacity", opacity.toFixed(3));
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    };

    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(boot, { timeout: 1100 });
    } else {
      globalThis.setTimeout(boot, 160);
    }
  })();
</script>
