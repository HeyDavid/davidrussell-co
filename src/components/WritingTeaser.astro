---
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const latest = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<section class="card" id="essays">
  <div class="section-head">
    <p class="label">Writing</p>
  </div>
  <h2>Notes from the workbench. <em>Short, occasional, never spam.</em></h2>

  {latest.length === 0 ? (
    <p class="writing-teaser">
      First essays shipping soon — operator notes on building small ventures, dropping the page-builder stack, what Etsy fees actually cost, and the case for being tiny on purpose. <a href="#hero-subscribe">Subscribe up top</a> to get the first one in your inbox.
    </p>
  ) : (
    <>
      <ul class="writing-list">
        {latest.map((post) => (
          <li>
            <a href={`/writing/${post.id}/`}>
              <div class="post-title">{post.data.title}</div>
              <div class="post-meta">{formatDate(post.data.publishDate)}{post.data.readTime && ` · ${post.data.readTime}`}</div>
              {post.data.description && <div class="post-dek">{post.data.description}</div>}
            </a>
          </li>
        ))}
      </ul>
      <p style="margin-top: 32px;">
        <a href="/writing/" style="border-bottom: 1px solid #c5b8a0; color: #5a5142; font-size: 15px;">All writing &rarr;</a>
      </p>
    </>
  )}
</section>
