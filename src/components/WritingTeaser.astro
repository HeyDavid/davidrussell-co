---
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const latest = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);

const formatMeta = (post: (typeof latest)[number]) =>
  post.data.status === "coming-soon"
    ? "coming soon"
    : post.data.publishDate.toLocaleDateString("en-US", { year: "numeric", month: "short" });
---

<section class="entry" id="writing" aria-labelledby="writing-title">
  <div class="section-kicker">Writing</div>
  <h2 id="writing-title">Drafts with a point of view.</h2>

  <ul class="writing-list">
    {latest.map((post) => (
      <li>
        <a href={`/writing/${post.id}/`}>
          <div class="post-meta">
            <span class="format-tag" data-format={post.data.format}>{post.data.format}</span>
            <span class="post-date">{formatMeta(post)}{post.data.readTime ? ` · ${post.data.readTime}` : ""}</span>
          </div>
          <div class="post-title">{post.data.title}</div>
          {post.data.description && <div class="post-dek">{post.data.description}</div>}
        </a>
      </li>
    ))}
  </ul>
  <p class="all-writing"><a href="/writing/">All writing</a></p>
</section>

<style>
  .post-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: flex-end;
  }
  .post-date {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: -0.005em;
    text-transform: none;
    color: var(--mist);
  }
</style>
