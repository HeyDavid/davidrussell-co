---
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const latest = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 4);

const dateOf = (post: (typeof latest)[number]) =>
  post.data.status === "coming-soon"
    ? "coming soon"
    : post.data.publishDate.toLocaleDateString("en-US", { year: "numeric", month: "short" });
---

<section class="movement reveal" id="writing" aria-labelledby="writing-title">
  <div class="movement-grid">
    <div class="movement-head">
      <span class="numeral" aria-hidden="true">I</span>
      <span class="kicker">writing</span>
      <p class="margin-note">Short, occasional, <b>never spam</b>. Notes, logs, the odd argument.</p>
    </div>
    <div class="movement-body">
      <h2 class="movement-title" id="writing-title">Notes from the workbench.</h2>
      <ul class="entries">
        {latest.map((post) => (
          <li class="entry">
            <a href={`/writing/${post.id}/`}>
              <div class="entry-dateline">
                <span class="entry-format">{post.data.format}</span>
                <span class="sep">·</span>
                <span>{dateOf(post)}</span>
                {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
              </div>
              <div class="entry-title">{post.data.title}</div>
              {post.data.description && <div class="entry-dek">{post.data.description}</div>}
            </a>
          </li>
        ))}
      </ul>
      <p class="movement-more"><a href="/writing/">The full index →</a></p>
    </div>
  </div>
</section>
