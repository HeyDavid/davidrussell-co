---
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const latest = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short" }).toUpperCase();
---

<section class="entry" id="writing">
  <span class="entry-num">iii.</span>
  <h2>Writing &mdash; <em>short, occasional, never spam.</em></h2>

  {latest.length === 0 ? (
    <p class="writing-teaser">
      First essays shipping soon &mdash; operator notes on building small ventures, what Etsy fees actually cost, what AI is doing to service businesses, and the case for being tiny on purpose. <a href="#hero-subscribe">Subscribe up top</a> and you&rsquo;ll get the first one.
    </p>
  ) : (
    <>
      <ul class="writing-list">
        {latest.map((post) => (
          <li>
            <a href={`/writing/${post.id}/`}>
              <div class="post-title">{post.data.title}</div>
              <div class="post-meta">{formatDate(post.data.publishDate)}{post.data.readTime && ` · ${post.data.readTime}`}</div>
              {post.data.description && <div class="post-dek">{post.data.description}</div>}
            </a>
          </li>
        ))}
      </ul>
      <p class="all-writing"><a href="/writing/">All writing &rarr;</a></p>
    </>
  )}
</section>
