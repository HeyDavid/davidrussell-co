---
import "@/styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "David Russell",
  description = "CEO of Let's Chat, content creator, indie operator in South Florida.",
  image = "/og.png",
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://davidrussell.co").toString();
const socialImage = new URL(image, Astro.site ?? "https://davidrussell.co").toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content={socialImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={socialImage}>
{noindex && <meta name="robots" content="noindex">}
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
<link rel="mask-icon" href="/assets/favicon.svg" color="#5b8def">
<meta name="theme-color" content="#0a0e1a">
<meta name="msapplication-TileColor" content="#0a0e1a">
<meta name="color-scheme" content="dark">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&family=Caveat:wght@400;500;600&display=swap" rel="stylesheet">
<!--
  Analytics: Cloudflare Web Analytics (manual beacon mode, since davidrussell.co
  is direct GitHub Pages, not proxied through Cloudflare).

  Get the token at: https://one.dash.cloudflare.com/?to=/:account/web-analytics
  → Add a site → davidrussell.co → copy the JWT in the snippet → paste below.

  The beacon below is harmless without a real token — it just won't record. Once
  the token is in place, pageviews start flowing to the CF dashboard immediately.

  Custom events (newsletter signups, outbound clicks, etc.) are not part of
  CF Web Analytics free tier — those will be wired separately via a Cloudflare
  Worker + KV/D1 layer when we build the custom analytics layer.
-->
<script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "__CLOUDFLARE_BEACON_TOKEN__"}'></script>
<title>{title}</title>
</head>
<body>

<!-- Site shell -->
<div class="page">
  <!-- Primary content slot -->
  <slot />
</div>

</body>
</html>
