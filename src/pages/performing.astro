---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const acts = [
  { tag: "magic", name: "Close-up & stage", desc: "Card and coin work, parlor sets, occasional private events around South Florida. 20+ years at it — the best icebreaker I've got." },
  { tag: "music", name: "Guitar & vocals", desc: "Acoustic, mostly. Original work and the songs people want to hear." },
  { tag: "comedy & acting", name: "Reels & reactions", desc: "Short-form on Instagram. Sketches, real moments, the stuff that makes the internet feel less broken." },
  { tag: "speaking", name: "In the works", desc: "Talks on building small ventures, AI tooling, and what 10+ years of marketing taught me. Drop me a line if you're curating.", muted: true },
];
---

<BaseLayout
  title="The other half · David Russell"
  description="Magic, music, and the occasional stage."
  noindex={true}
>
  <Header />
  <main>
    <article class="work">
      <a href="/" class="back">← Home</a>

      <header class="work-head">
        <div class="dateline"><b>The other half</b></div>
        <h1>Magic, music, and the <em>occasional stage</em>.</h1>
        <p class="work-lede">
          Before the ventures, there was a kid doing card tricks in a backyard.
          That kid is still here. Somewhere along the way he picked up a guitar,
          a microphone, and a taste for getting in front of a room.
        </p>
      </header>

      <section class="work-block">
        <h2>The sideline.</h2>
        <ul class="record">
          {acts.map((a) => (
            <li class="record-row" style={a.muted ? "opacity:0.62;" : undefined}>
              <div class="record-name">{a.name}<span class="yr">{a.tag}</span></div>
              <div class="record-why">{a.desc}</div>
            </li>
          ))}
        </ul>
        <p class="work-note">
          Best place to follow this side of things:
          <a href="https://instagram.com/heydavidr" target="_blank" rel="noopener">@heydavidr on Instagram</a>.
        </p>
      </section>
    </article>
  </main>
  <Footer />
</BaseLayout>
