---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing", ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      newer: i > 0 ? sorted[i - 1] : null,
      older: i < sorted.length - 1 ? sorted[i + 1] : null,
      related: sorted
        .filter((p) => p.id !== post.id)
        .filter((p) => {
          const sharedTags = (p.data.tags ?? []).some((t) =>
            (post.data.tags ?? []).includes(t)
          );
          return sharedTags;
        })
        .slice(0, 3),
    },
  }));
}

const { post, newer, older, related } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const metaDate =
  post.data.status === "coming-soon"
    ? "draft — coming soon"
    : formatDate(post.data.publishDate);
---

<BaseLayout
  title={`${post.data.title} — David Russell`}
  description={post.data.description ?? "Short, occasional, never spam."}
>
  <Header />
  <main>
    <article class="reading essay-read">
      <a href="/writing/" class="back">← All writing</a>

      <header class="essay-head">
        <div class="essay-meta">
          <span class="essay-format">{post.data.format}</span>
          <span class="sep">·</span>
          <span>{metaDate.toLowerCase()}</span>
          {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
        </div>
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="essay-dek">{post.data.description}</p>}
      </header>

      <div class="post-body">
        <Content />
      </div>

      <aside class="essay-subscribe" aria-labelledby="inline-sub">
        <h3 id="inline-sub">Get the next one in your inbox.</h3>
        <p class="essay-subscribe-note">Short notes, essays, the occasional argument. No schedule, no spam.</p>
        <form class="ws-sub" id="essay-subscribe-form">
          <input type="email" name="email" autocomplete="email" placeholder="your email" aria-label="Email address" required />
          <button type="submit" data-event="newsletter-signup">Subscribe</button>
        </form>
        <p class="subscribe-status" id="essay-subscribe-status" role="status" aria-live="polite" hidden></p>
      </aside>

      {related.length > 0 && (
        <section class="essay-related">
          <div class="essay-sec-label">Filed nearby</div>
          <ul>
            {related.map((p) => (
              <li>
                <a href={`/writing/${p.id}/`}>
                  <span class="rel-format">{p.data.format}</span>
                  <span class="rel-title">{p.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {(newer || older) && (
        <nav class="essay-nav" aria-label="Post navigation">
          {older ? (
            <a class="essay-nav-link prev" href={`/writing/${older.id}/`}>
              <span class="nav-lab">← Older</span>
              <span class="nav-title">{older.data.title}</span>
            </a>
          ) : <span></span>}
          {newer && (
            <a class="essay-nav-link next" href={`/writing/${newer.id}/`}>
              <span class="nav-lab">Newer →</span>
              <span class="nav-title">{newer.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  (function(){
    var form = document.getElementById("essay-subscribe-form");
    var status = document.getElementById("essay-subscribe-status");
    if (!form || !status) return;
    var PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";
    form.addEventListener("submit", function(event){
      event.preventDefault();
      var input = form.querySelector("input");
      var email = (input.value || "").trim();
      if (!email) return;
      var button = form.querySelector("button");
      if (button) { button.disabled = true; button.textContent = "Sending…"; }
      var data = new FormData();
      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("utm_medium", "essay-inline");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", window.location.pathname);
      fetch("https://embeds.beehiiv.com/" + PUB, { method:"POST", mode:"no-cors", body:data }).finally(function(){
        form.reset();
        status.hidden = false;
        status.textContent = "Submitted. Check your inbox to confirm.";
        if (button) { button.disabled = false; button.textContent = "Subscribe"; }
      });
    });
  })();
</script>

<style>
  .essay-read{max-width:680px;margin:0 auto;padding:clamp(34px,6vw,72px) var(--pad) clamp(72px,10vw,120px)}
  .essay-head{margin-bottom:clamp(30px,5vw,48px)}
  .essay-meta{display:flex;gap:10px;align-items:baseline;flex-wrap:wrap;font-size:13.5px;font-weight:500;color:var(--faint);margin-bottom:16px}
  .essay-meta .essay-format{color:var(--cobalt);font-weight:600}
  .essay-meta .sep{color:var(--line-strong)}
  .essay-head h1{font-family:var(--disp);font-weight:700;font-size:clamp(36px,6vw,58px);letter-spacing:-.035em;line-height:1.02;color:var(--ink);margin-bottom:16px}
  .essay-dek{font-family:var(--grot);font-size:clamp(18px,2vw,22px);line-height:1.5;color:var(--ink-soft);max-width:54ch}
  .essay-read .post-body{font-size:19px;line-height:1.78}
  .essay-read .post-body>p:first-of-type::first-letter{initial-letter:3;-webkit-initial-letter:3;font-weight:700;color:var(--cobalt);margin-right:.08em;font-family:var(--disp)}
  .essay-read .post-body h2{font-size:28px}

  .essay-subscribe{margin:clamp(52px,8vw,76px) 0 clamp(44px,6vw,60px);padding:clamp(26px,4vw,34px) 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .essay-subscribe h3{font-family:var(--disp);font-weight:700;font-size:clamp(22px,2.6vw,28px);letter-spacing:-.02em;color:var(--ink);margin-bottom:6px}
  .essay-subscribe-note{font-size:14.5px;color:var(--dim);margin-bottom:16px}
  .ws-sub{display:flex;background:var(--card);border:1.5px solid var(--line);border-radius:100px;padding:6px 6px 6px 22px;max-width:440px;transition:border-color .3s,box-shadow .3s}
  .ws-sub:focus-within{border-color:var(--cobalt);box-shadow:0 0 0 4px rgba(47,43,240,.12)}
  .ws-sub input{flex:1;min-width:0;border:0;background:transparent;outline:none;font:inherit;font-size:16px;color:var(--ink)}
  .ws-sub input::placeholder{color:var(--faint)}
  .ws-sub button{border:0;background:var(--ink);color:var(--paper);border-radius:100px;padding:11px 22px;font-weight:600;font-size:15px;cursor:pointer;white-space:nowrap;transition:background .3s}
  .ws-sub button:hover{background:var(--cobalt)}
  .ws-sub button:disabled{opacity:.6;cursor:default}
  .subscribe-status{font-size:14px;color:var(--cobalt);font-weight:600;margin-top:12px}

  .essay-related{margin-bottom:clamp(44px,6vw,56px)}
  .essay-sec-label{font-size:13px;font-weight:600;color:var(--cobalt);margin-bottom:6px}
  .essay-related ul{list-style:none}
  .essay-related li{border-top:1px solid var(--line-soft)}
  .essay-related li:first-child{border-top:0}
  .essay-related a{display:flex;align-items:baseline;gap:14px;padding:14px 0;transition:padding-left .3s var(--ease)}
  .essay-related a:hover{padding-left:6px}
  .rel-format{font-size:12px;font-weight:600;color:var(--cobalt);white-space:nowrap}
  .rel-title{font-family:var(--disp);font-weight:600;font-size:18px;color:var(--ink);letter-spacing:-.01em}
  .essay-related a:hover .rel-title{color:var(--cobalt)}

  .essay-nav{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .essay-nav-link{display:grid;gap:6px;padding:18px 0;border-top:1px solid var(--line);transition:color .3s}
  .essay-nav-link.next{text-align:right}
  .nav-lab{font-size:12px;font-weight:600;color:var(--faint)}
  .nav-title{font-family:var(--disp);font-weight:600;font-size:17px;color:var(--ink);line-height:1.25;letter-spacing:-.01em}
  .essay-nav-link:hover .nav-title{color:var(--cobalt)}
  @media(max-width:600px){.essay-nav{grid-template-columns:1fr}.essay-nav-link.next{text-align:left}}
</style>
