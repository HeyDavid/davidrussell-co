---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }).toUpperCase();

const metaLine =
  post.data.status === "coming-soon"
    ? "DRAFT - COMING SOON"
    : formatDate(post.data.publishDate);
---

<BaseLayout
  title={`${post.data.title} - David Russell`}
  description={post.data.description ?? "Short, occasional, never spam."}
>
  <Header />
  <main>
    <article class="essay">
      <a href="/writing/" class="back">Back to all writing</a>
      <h1>{post.data.title}</h1>
      <p class="post-meta-line font-mono">
        {metaLine}{post.data.readTime ? ` / ${post.data.readTime}` : ""}
      </p>
      <div class="post-body">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
