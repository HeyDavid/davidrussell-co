---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing", ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      // Reverse-chrono: next = newer (smaller index), prev = older (larger index)
      newer: i > 0 ? sorted[i - 1] : null,
      older: i < sorted.length - 1 ? sorted[i + 1] : null,
      related: sorted
        .filter((p) => p.id !== post.id)
        .filter((p) => {
          const sharedTags = (p.data.tags ?? []).some((t) =>
            (post.data.tags ?? []).includes(t)
          );
          return sharedTags;
        })
        .slice(0, 3),
    },
  }));
}

const { post, newer, older, related } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const metaLine =
  post.data.status === "coming-soon"
    ? "Draft — coming soon"
    : formatDate(post.data.publishDate);
---

<BaseLayout
  title={`${post.data.title} - David Russell`}
  description={post.data.description ?? "Short, occasional, never spam."}
>
  <Header />
  <main>
    <article class="essay essay-v2">
      <a href="/writing/" class="back">← All writing</a>

      <header class="essay-head">
        <p class="post-meta-line">
          <span class="format-tag" data-format={post.data.format}>{post.data.format}</span>
          <span class="meta-line">{metaLine.toLowerCase()}{post.data.readTime ? ` · ${post.data.readTime}` : ""}</span>
        </p>
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="essay-dek">{post.data.description}</p>}
      </header>

      <div class="post-body">
        <Content />
      </div>

      {/* Inline subscribe — appears after the body, before related posts */}
      <aside class="essay-subscribe" aria-labelledby="inline-sub">
        <h3 id="inline-sub">Get the next one in your inbox.</h3>
        <p>Short notes, essays, occasional debate. No schedule, no spam.</p>
        <form class="essay-subscribe-form" id="essay-subscribe-form">
          <input type="email" name="email" autocomplete="email" placeholder="you@example.com" required />
          <button type="submit" data-event="newsletter-signup">Subscribe</button>
          <p class="essay-subscribe-status" id="essay-subscribe-status" role="status" aria-live="polite" hidden></p>
        </form>
      </aside>

      {/* Related posts */}
      {related.length > 0 && (
        <section class="essay-related">
          <h3>More like this</h3>
          <ul>
            {related.map((p) => (
              <li>
                <a href={`/writing/${p.id}/`}>
                  <span class="format-tag" data-format={p.data.format}>{p.data.format}</span>
                  <span class="related-title">{p.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {/* Prev / next navigation */}
      {(newer || older) && (
        <nav class="essay-nav" aria-label="Post navigation">
          {older && (
            <a class="essay-nav-link essay-nav-prev" href={`/writing/${older.id}/`}>
              <span class="essay-nav-label">← Older</span>
              <span class="essay-nav-title">{older.data.title}</span>
            </a>
          )}
          {newer && (
            <a class="essay-nav-link essay-nav-next" href={`/writing/${newer.id}/`}>
              <span class="essay-nav-label">Newer →</span>
              <span class="essay-nav-title">{newer.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<script>
  /* Inline subscribe form on essay pages */
  (() => {
    const form = document.getElementById("essay-subscribe-form") as HTMLFormElement | null;
    const status = document.getElementById("essay-subscribe-status") as HTMLElement | null;
    if (!form || !status) return;
    const BEEHIIV_PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = String(data.get("email") ?? "").trim();
      if (!email) return;

      const button = form.querySelector("button");
      if (button) { button.disabled = true; button.textContent = "Sending"; }

      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("utm_medium", "essay-inline");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", window.location.pathname);

      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: "POST", mode: "no-cors", body: data,
      }).finally(() => {
        form.reset();
        status.hidden = false;
        status.textContent = "Got it. Check your inbox to confirm.";
        if (button) { button.disabled = false; button.textContent = "Subscribe"; }
      });
    });
  })();
</script>

<style>
  /* Ferriss-style reading column — 680px max, generous body type. */
  .essay-v2 {
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 88px) clamp(20px, 4vw, 28px) clamp(80px, 12vw, 140px);
  }
  .essay-v2 .back {
    display: inline-block;
    margin-bottom: 56px;
    color: var(--mist);
    font-size: 14px;
    border: 0;
  }
  .essay-v2 .back:hover { color: var(--signal); }

  .essay-head { margin-bottom: clamp(40px, 6vw, 64px); }
  .essay-v2 .post-meta-line {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .essay-v2 h1 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 6vw, 60px);
    letter-spacing: -0.02em;
    line-height: 1.04;
    color: var(--star);
    margin-bottom: 18px;
  }
  .essay-dek {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.55;
    color: var(--mist);
    max-width: 56ch;
  }

  /* Post body — generous reading type */
  .essay-v2 .post-body {
    color: var(--star);
    font-size: 19px;
    line-height: 1.78;
  }
  .essay-v2 .post-body p,
  .essay-v2 .post-body ul,
  .essay-v2 .post-body ol { margin-bottom: 24px; }
  .essay-v2 .post-body h2 {
    margin: 48px 0 16px;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 30px;
    line-height: 1.15;
    color: var(--star);
  }
  .essay-v2 .post-body h3 {
    margin: 36px 0 12px;
    font-family: var(--sans);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--star);
  }
  .essay-v2 .post-body ul,
  .essay-v2 .post-body ol { padding-left: 24px; }
  .essay-v2 .post-body blockquote {
    margin: 32px 0;
    padding-left: 22px;
    border-left: 3px solid var(--signal);
    color: var(--mist);
    font-style: italic;
    font-family: var(--serif);
    font-size: 21px;
    line-height: 1.55;
  }
  .essay-v2 .post-body em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--star);
  }
  .essay-v2 .post-body a {
    color: var(--signal);
    border-bottom: 1px solid rgba(91, 141, 239, 0.35);
  }
  .essay-v2 .post-body a:hover {
    border-bottom-color: var(--signal);
  }

  /* Inline subscribe block */
  .essay-subscribe {
    margin: clamp(56px, 8vw, 80px) 0 clamp(48px, 6vw, 64px);
    padding: clamp(28px, 4vw, 40px);
    border: 1px solid rgba(91, 141, 239, 0.15);
    border-radius: 14px;
    background: rgba(91, 141, 239, 0.04);
  }
  .essay-subscribe h3 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(22px, 2.6vw, 28px);
    color: var(--star);
    margin-bottom: 8px;
    letter-spacing: -0.015em;
  }
  .essay-subscribe p {
    color: var(--mist);
    font-size: 15px;
    line-height: 1.5;
    margin-bottom: 18px;
  }
  .essay-subscribe-form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
  }
  .essay-subscribe-form input {
    min-height: 46px;
    padding: 0 14px;
    border: 1px solid var(--rule-strong);
    border-radius: 10px;
    background: rgba(10, 14, 26, 0.5);
    color: var(--star);
    font-size: 15px;
    outline: none;
    transition: border-color 200ms ease, background 200ms ease;
  }
  .essay-subscribe-form input::placeholder { color: var(--smoke); }
  .essay-subscribe-form input:focus {
    border-color: var(--signal);
    background: rgba(91, 141, 239, 0.06);
  }
  .essay-subscribe-form button {
    min-height: 46px;
    padding: 0 20px;
    border: 0;
    border-radius: 10px;
    background: var(--signal);
    color: var(--void);
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background 200ms ease;
  }
  .essay-subscribe-form button:hover {
    background: color-mix(in srgb, var(--signal) 88%, white);
  }
  .essay-subscribe-status {
    grid-column: 1 / -1;
    color: var(--signal);
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    margin: 6px 0 0;
  }

  /* Related posts */
  .essay-related {
    margin-bottom: clamp(48px, 6vw, 64px);
  }
  .essay-related h3 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    color: var(--star);
    margin-bottom: 18px;
  }
  .essay-related ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .essay-related li {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .essay-related li:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .essay-related a {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 16px 0;
    border: 0;
    transition: padding 220ms var(--ease-out), color 200ms ease;
  }
  .essay-related a:hover {
    padding-left: 6px;
  }
  .related-title {
    font-family: var(--sans);
    font-size: 17px;
    font-weight: 500;
    color: var(--star);
    letter-spacing: -0.01em;
  }
  .essay-related a:hover .related-title {
    color: var(--signal);
  }

  /* Prev/next navigation */
  .essay-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .essay-nav-link {
    display: grid;
    gap: 6px;
    padding: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(20, 21, 24, 0.5);
    transition: border-color 240ms ease, background 240ms ease;
  }
  .essay-nav-link:hover {
    border-color: rgba(91, 141, 239, 0.3);
    background: rgba(20, 21, 24, 0.7);
  }
  .essay-nav-prev:only-child { grid-column: 1 / 2; }
  .essay-nav-next {
    text-align: right;
  }
  .essay-nav-label {
    color: var(--mist);
    font-size: 13px;
  }
  .essay-nav-title {
    color: var(--star);
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .essay-nav { grid-template-columns: 1fr; }
    .essay-nav-next { text-align: left; }
    .essay-subscribe-form { grid-template-columns: 1fr; }
  }
</style>
