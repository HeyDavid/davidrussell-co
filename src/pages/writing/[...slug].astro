---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("writing", ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      newer: i > 0 ? sorted[i - 1] : null,
      older: i < sorted.length - 1 ? sorted[i + 1] : null,
      related: sorted
        .filter((p) => p.id !== post.id)
        .filter((p) => {
          const sharedTags = (p.data.tags ?? []).some((t) =>
            (post.data.tags ?? []).includes(t)
          );
          return sharedTags;
        })
        .slice(0, 3),
    },
  }));
}

const { post, newer, older, related } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const metaDate =
  post.data.status === "coming-soon"
    ? "draft — coming soon"
    : formatDate(post.data.publishDate);
---

<BaseLayout
  title={`${post.data.title} — David Russell`}
  description={post.data.description ?? "Short, occasional, never spam."}
>
  <Header />
  <main>
    <article class="reading essay-read">
      <a href="/writing/" class="back">← All writing</a>

      <header class="essay-head">
        <div class="essay-meta">
          <span class="essay-format">{post.data.format}</span>
          <span class="sep">·</span>
          <span>{metaDate.toLowerCase()}</span>
          {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
        </div>
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="essay-dek">{post.data.description}</p>}
      </header>

      <div class="post-body">
        <Content />
      </div>

      <aside class="essay-subscribe" aria-labelledby="inline-sub">
        <h3 id="inline-sub">Get the next one in your inbox.</h3>
        <p class="essay-subscribe-note">Short notes, essays, the occasional argument. No schedule, no spam.</p>
        <form class="field-rule" id="essay-subscribe-form">
          <input type="email" name="email" autocomplete="email" placeholder="you@example.com" required />
          <button type="submit" data-event="newsletter-signup">Subscribe →</button>
        </form>
        <p class="subscribe-status" id="essay-subscribe-status" role="status" aria-live="polite" hidden></p>
      </aside>

      {related.length > 0 && (
        <section class="essay-related">
          <div class="essay-sec-label">Filed nearby</div>
          <ul>
            {related.map((p) => (
              <li>
                <a href={`/writing/${p.id}/`}>
                  <span class="rel-format">{p.data.format}</span>
                  <span class="rel-title">{p.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {(newer || older) && (
        <nav class="essay-nav" aria-label="Post navigation">
          {older ? (
            <a class="essay-nav-link prev" href={`/writing/${older.id}/`}>
              <span class="nav-lab">← Older</span>
              <span class="nav-title">{older.data.title}</span>
            </a>
          ) : <span></span>}
          {newer && (
            <a class="essay-nav-link next" href={`/writing/${newer.id}/`}>
              <span class="nav-lab">Newer →</span>
              <span class="nav-title">{newer.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<script>
  (() => {
    const form = document.getElementById("essay-subscribe-form") as HTMLFormElement | null;
    const status = document.getElementById("essay-subscribe-status") as HTMLElement | null;
    if (!form || !status) return;
    const BEEHIIV_PUB = "pub_ed495df0-b44a-47ba-939c-eeb46089e27b";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const email = String(data.get("email") ?? "").trim();
      if (!email) return;

      const button = form.querySelector("button");
      if (button) { button.disabled = true; button.textContent = "Sending…"; }

      data.set("email", email);
      data.set("utm_source", "davidrussell.co");
      data.set("utm_medium", "essay-inline");
      data.set("tags", "dr-subscriber");
      data.set("referring_site", window.location.pathname);

      fetch(`https://embeds.beehiiv.com/${BEEHIIV_PUB}`, {
        method: "POST", mode: "no-cors", body: data,
      }).finally(() => {
        form.reset();
        status.hidden = false;
        status.textContent = "Got it. Check your inbox to confirm.";
        if (button) { button.disabled = false; button.textContent = "Subscribe →"; }
      });
    });
  })();
</script>

<style>
  .essay-read {
    max-width: 680px;
    margin: 0 auto;
    padding: clamp(36px, 6vw, 72px) var(--pad) clamp(72px, 10vw, 120px);
  }
  .essay-read .back {
    display: inline-block;
    margin-bottom: clamp(36px, 6vw, 60px);
    border: 0;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink-faint);
  }
  .essay-read .back:hover { color: var(--oxblood); }

  .essay-head { margin-bottom: clamp(32px, 5vw, 52px); }
  .essay-meta {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-faint);
    display: flex;
    gap: 10px;
    align-items: baseline;
    flex-wrap: wrap;
    margin-bottom: 18px;
    letter-spacing: 0.01em;
  }
  .essay-meta .essay-format { color: var(--oxblood); }
  .essay-meta .sep { color: var(--rule-strong); }
  .essay-head h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(36px, 6vw, 58px);
    letter-spacing: -0.028em;
    line-height: 1.02;
    color: var(--ink);
    margin-bottom: 18px;
  }
  .essay-dek {
    font-family: var(--serif);
    font-size: clamp(18px, 2.1vw, 22px);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 54ch;
  }

  /* Reading body — generous, with a drop cap on the opening paragraph */
  .essay-read .post-body { font-size: 19px; line-height: 1.78; }
  .essay-read .post-body > p:first-of-type::first-letter {
    initial-letter: 3;
    -webkit-initial-letter: 3;
    font-weight: 600;
    color: var(--oxblood);
    margin-right: 0.08em;
  }
  .essay-read .post-body h2 {
    font-size: 28px;
    margin: 46px 0 14px;
    letter-spacing: -0.02em;
  }

  /* Inline subscribe — ruled, not a colored box */
  .essay-subscribe {
    margin: clamp(52px, 8vw, 76px) 0 clamp(44px, 6vw, 60px);
    padding: clamp(24px, 4vw, 32px) 0;
    border-top: 2px solid var(--rule-ink);
    border-bottom: 1px solid var(--rule-ink);
  }
  .essay-subscribe h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(22px, 2.6vw, 28px);
    letter-spacing: -0.018em;
    color: var(--ink);
    margin-bottom: 6px;
  }
  .essay-subscribe-note { font-family: var(--mono); font-size: 12px; color: var(--ink-faint); margin-bottom: 16px; }
  .essay-subscribe .field-rule { max-width: 420px; }

  /* Related */
  .essay-related { margin-bottom: clamp(44px, 6vw, 56px); }
  .essay-sec-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; color: var(--ink-faint); margin-bottom: 6px; }
  .essay-related ul { list-style: none; }
  .essay-related li { border-top: 1px solid var(--rule-soft); }
  .essay-related li:first-child { border-top: 0; }
  .essay-related a {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 14px 0;
    border: 0;
    transition: padding-left var(--dur) var(--ease);
  }
  .essay-related a:hover { padding-left: 6px; }
  .rel-format { font-family: var(--mono); font-size: 11px; color: var(--oxblood); white-space: nowrap; }
  .rel-title { font-family: var(--serif); font-size: 18px; color: var(--ink); letter-spacing: -0.01em; }
  .essay-related a:hover .rel-title { color: var(--oxblood); }

  /* Prev / next */
  .essay-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .essay-nav-link {
    display: grid;
    gap: 6px;
    padding: 18px 0;
    border: 0;
    border-top: 1px solid var(--rule-ink);
    transition: color var(--dur) var(--ease);
  }
  .essay-nav-link.next { text-align: right; }
  .nav-lab { font-family: var(--mono); font-size: 11.5px; color: var(--ink-faint); }
  .nav-title { font-family: var(--serif); font-size: 17px; color: var(--ink); line-height: 1.25; letter-spacing: -0.01em; }
  .essay-nav-link:hover .nav-title { color: var(--oxblood); }

  @media (max-width: 600px) {
    .essay-nav { grid-template-columns: 1fr; }
    .essay-nav-link.next { text-align: left; }
  }
</style>
