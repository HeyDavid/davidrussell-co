---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const formatMeta = (post: (typeof posts)[number]) =>
  post.data.status === "coming-soon" ? "coming soon" : formatDate(post.data.publishDate);

// Build a list of formats actually in use, for the filter chips
const formats = Array.from(new Set(posts.map((p) => p.data.format)));
const hasPosts = posts.length > 0;
---

<BaseLayout
  title="Writing — David Russell"
  description="Operator notes, essays, debates, and flow logs. Short, occasional, never spam."
>
  <Header />
  <main>
    <article class="writing-index">
      <a href="/" class="back">← Home</a>

      <header class="writing-head">
        <h1>Writing.</h1>
        <p class="writing-lede">
          Operator notes, essays, debates, and flow logs. Anything from a
          one-line scrap to a 3,000-word essay. Filter by format below.
        </p>
      </header>

      {hasPosts && (
        <div class="filter-chips" role="tablist" aria-label="Filter by format">
          <button class="chip is-active" data-filter="all" role="tab" aria-selected="true">All</button>
          {formats.map((f) => (
            <button class="chip" data-filter={f} role="tab" aria-selected="false">
              <span class="chip-dot" data-format={f}></span>
              <span>{f}</span>
            </button>
          ))}
        </div>
      )}

      {!hasPosts && (
        <p class="empty-note">
          First essay shipping soon. <a href="/#subscribe">Subscribe on the home page</a> and you'll be first to read it.
        </p>
      )}

      {hasPosts && (
        <ul class="writing-feed">
          {posts.map((post) => (
            <li class="feed-item" data-format={post.data.format}>
              <a href={`/writing/${post.id}/`}>
                <div class="feed-meta">
                  <span class="format-tag" data-format={post.data.format}>{post.data.format}</span>
                  <span class="feed-date">{formatMeta(post)}</span>
                  {post.data.readTime && <span class="feed-read">{post.data.readTime}</span>}
                </div>
                <h2 class="feed-title">{post.data.title}</h2>
                {post.data.description && <p class="feed-dek">{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<script>
  /* Format filter chips — toggle visibility of feed items. */
  (() => {
    const chips = document.querySelectorAll<HTMLButtonElement>(".chip");
    const items = document.querySelectorAll<HTMLElement>(".feed-item");
    if (!chips.length) return;

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const filter = chip.dataset.filter;
        chips.forEach((c) => {
          c.classList.toggle("is-active", c === chip);
          c.setAttribute("aria-selected", c === chip ? "true" : "false");
        });
        items.forEach((item) => {
          const show = filter === "all" || item.dataset.format === filter;
          item.style.display = show ? "" : "none";
        });
      });
    });
  })();
</script>

<style>
  .writing-index {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 88px) clamp(20px, 4vw, 28px) clamp(80px, 12vw, 140px);
  }
  .writing-index .back {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--mist);
    font-size: 14px;
    border: 0;
  }
  .writing-index .back:hover { color: var(--signal); }

  .writing-head { margin-bottom: 36px; }
  .writing-head h1 {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(48px, 7vw, 80px);
    letter-spacing: -0.02em;
    line-height: 1.02;
    color: var(--star);
    margin-bottom: 18px;
  }
  .writing-lede {
    font-size: clamp(17px, 1.8vw, 20px);
    line-height: 1.55;
    color: var(--mist);
    max-width: 52ch;
  }

  /* Filter chips — Godin-quiet, not loud */
  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
    color: var(--mist);
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 400;
    cursor: pointer;
    transition: border-color 200ms ease, color 200ms ease, background 200ms ease;
  }
  .chip:hover {
    border-color: rgba(91, 141, 239, 0.3);
    color: var(--star);
  }
  .chip.is-active {
    background: rgba(91, 141, 239, 0.1);
    border-color: rgba(91, 141, 239, 0.4);
    color: var(--star);
  }
  .chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .chip-dot[data-format="essay"] { background: #c4d3ff; }
  .chip-dot[data-format="debate"] { background: var(--spark); }
  .chip-dot[data-format="note"] { background: #9ec5e8; }
  .chip-dot[data-format="log"] { background: #8ee0c2; }
  .chip-dot[data-format="scrap"] { background: #d8b4ff; }

  /* Feed — clean reverse-chrono. No sidebar, no clutter. */
  .writing-feed {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .feed-item {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .feed-item:first-child {
    border-top: 0;
  }
  .feed-item a {
    display: grid;
    gap: 8px;
    padding: 28px 0;
    border: 0;
    transition: padding 220ms var(--ease-out);
  }
  .feed-item a:hover {
    padding-left: 6px;
  }
  .feed-meta {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }
  .feed-date, .feed-read {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--mist);
  }
  .feed-read::before {
    content: "·";
    margin-right: 14px;
    color: var(--smoke);
  }
  .feed-title {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 34px);
    letter-spacing: -0.015em;
    line-height: 1.15;
    color: var(--star);
    transition: color 200ms ease;
  }
  .feed-item a:hover .feed-title {
    color: var(--signal);
  }
  .feed-dek {
    color: var(--mist);
    font-size: 16px;
    line-height: 1.55;
    max-width: 60ch;
  }

  .empty-note {
    font-size: 17px;
    color: var(--mist);
    padding: 24px 0;
    border-top: 1px solid var(--rule);
  }
  .empty-note a {
    border-bottom: 1px solid var(--rule-strong);
    color: var(--star);
  }
</style>
