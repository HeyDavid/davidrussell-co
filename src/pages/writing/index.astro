---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<BaseLayout
  title="Writing — David Russell"
  description="Notes from the workbench. Short, occasional, never spam."
>
  <Header />
  <main class="writing-page">
    <div class="writing-index">
      <a href="/" class="back-link">&larr; Back to home</a>
      <h1>Writing</h1>
      <p class="lede">Notes from the workbench. Operator-level thinking on small ventures, AI tooling, what marketing actually moves the needle. Short, occasional, never spam.</p>

      {posts.length === 0 ? (
        <p class="empty">
          First essay shipping soon. <a href="/#hero-subscribe" style="border-bottom:1px solid #c5b8a0;">Subscribe up top</a> to be the first to read it.
        </p>
      ) : (
        <ul class="writing-list">
          {posts.map((post) => (
            <li>
              <a href={`/writing/${post.id}/`}>
                <div class="post-title">{post.data.title}</div>
                <div class="post-meta">{formatDate(post.data.publishDate)}{post.data.readTime && ` · ${post.data.readTime}`}</div>
                {post.data.description && <div class="post-dek">{post.data.description}</div>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</BaseLayout>
