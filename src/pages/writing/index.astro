---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const dateOf = (post: (typeof posts)[number]) =>
  post.data.status === "coming-soon" ? "coming soon" : formatDate(post.data.publishDate);

const hasPosts = posts.length > 0;
---

<BaseLayout
  title="Writing — David Russell"
  description="Operator notes, essays, debates, and flow logs. Short, occasional, never spam."
>
  <Header />
  <main>
    <article class="reading">
      <a href="/" class="back">← The almanac</a>

      <header class="reading-head">
        <div class="dateline">The Field Almanac &nbsp;/&nbsp; No.&nbsp;01 &nbsp;/&nbsp; Writing</div>
        <h1>Writing<span class="period">.</span></h1>
        <p class="reading-lede">
          Operator notes, essays, debates, and flow logs. Anything from a
          one-line scrap to a 3,000-word essay. Newest first.
        </p>
      </header>

      {hasPosts ? (
        <ul class="entries index-entries">
          {posts.map((post) => (
            <li class="entry">
              <a href={`/writing/${post.id}/`}>
                <div class="entry-dateline">
                  <span class="entry-format">{post.data.format}</span>
                  <span class="sep">·</span>
                  <span>{dateOf(post)}</span>
                  {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
                </div>
                <div class="entry-title">{post.data.title}</div>
                {post.data.description && <div class="entry-dek">{post.data.description}</div>}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-note">
          First essay shipping soon. <a href="/#find-me">Subscribe on the home page</a> and you&rsquo;ll be first to read it.
        </p>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .reading {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(36px, 6vw, 72px) var(--pad) clamp(72px, 10vw, 120px);
  }
  .reading .back {
    display: inline-block;
    margin-bottom: clamp(28px, 5vw, 48px);
    border: 0;
    font-family: var(--mono);
    font-size: 12.5px;
    color: var(--ink-faint);
  }
  .reading .back:hover { color: var(--oxblood); }

  .reading-head { margin-bottom: clamp(28px, 4vw, 44px); }
  .reading-head .dateline { padding-bottom: 16px; }
  .reading-head h1 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(52px, 10vw, 104px);
    letter-spacing: -0.035em;
    line-height: 0.92;
    color: var(--ink);
    border-bottom: 1px solid var(--rule-ink);
    padding-bottom: 18px;
  }
  .reading-head h1 .period { color: var(--oxblood); }
  .reading-lede {
    font-family: var(--serif);
    font-size: clamp(18px, 2.1vw, 22px);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 52ch;
    margin-top: 20px;
  }

  /* index entries — a touch larger than the homepage teaser */
  .index-entries .entry > a { padding: 26px 0; }
  .index-entries .entry-title { font-size: clamp(23px, 3vw, 31px); }
  .index-entries .entry-dek { font-size: 16.5px; max-width: 60ch; }

  .empty-note {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--ink-soft);
    padding: 24px 0;
    border-top: 1px solid var(--rule);
  }
  .empty-note a { color: var(--oxblood); border-bottom: 1px solid var(--oxblood-soft); }
</style>
