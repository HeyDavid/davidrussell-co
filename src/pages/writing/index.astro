---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short" }).toUpperCase();

const hasPosts = posts.length > 0;
---

<BaseLayout
  title="Writing — David Russell"
  description="Short, occasional, never spam. Operator notes on small ventures, AI tooling, and what marketing actually moves the needle."
>
  <Header />
  <main>
    <section class="essay">
      <a href="/" class="back">← Back to home</a>
      <h1>Writing.</h1>
      <p class="lede">
        Operator notes on small ventures, AI tooling, what marketing actually moves the needle. Short, occasional, never spam.
      </p>

      {!hasPosts && (
        <p class="empty-note">
          First essay shipping soon. <a href="/#hero-subscribe">Subscribe on the home page</a> and you will be first to read it.
        </p>
      )}

      {hasPosts && (
        <ul class="writing-list">
          {posts.map((post) => (
            <li>
              <a href={`/writing/${post.id}/`}>
                <div class="post-title">{post.data.title}</div>
                <div class="post-meta">{formatDate(post.data.publishDate)}</div>
                {post.data.description && <div class="post-dek">{post.data.description}</div>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .empty-note {
    font-size: 17px;
    color: var(--ink-soft);
    padding: 24px 0;
    border-top: 1px solid var(--rule);
  }
  .empty-note a {
    border-bottom: 1px solid var(--rule-strong);
  }
</style>
