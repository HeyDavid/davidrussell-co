---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("writing", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const dateOf = (post: (typeof posts)[number]) =>
  post.data.status === "coming-soon" ? "coming soon" : formatDate(post.data.publishDate);

const hasPosts = posts.length > 0;
---

<BaseLayout
  title="Writing — David Russell"
  description="Operator notes, essays, and flow logs. Short, occasional, never spam — and every piece ends with a sharper question."
>
  <Header />
  <main>
    <article class="reading">
      <a href="/" class="back">← Home</a>

      <header class="reading-head">
        <div class="w-eyebrow">Operator notes &amp; essays</div>
        <h1>Writing<span class="d">.</span></h1>
        <p class="reading-lede">
          Short, occasional, never spam. Anything from a one-line scrap to a
          3,000-word essay — newest first. Reply to any of them.
        </p>
      </header>

      {hasPosts ? (
        <ul class="entries index-entries">
          {posts.map((post) => (
            <li class="entry">
              <a href={`/writing/${post.id}/`}>
                <div class="entry-dateline">
                  <span class="entry-format">{post.data.format}</span>
                  <span class="sep">·</span>
                  <span>{dateOf(post)}</span>
                  {post.data.readTime && <><span class="sep">·</span><span>{post.data.readTime}</span></>}
                </div>
                <div class="entry-title">{post.data.title}</div>
                {post.data.description && <div class="entry-dek">{post.data.description}</div>}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-note">
          First essay shipping soon. <a href="/#subscribe">Subscribe on the home page</a> and you&rsquo;ll be first to read it.
        </p>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .reading{max-width:760px;margin:0 auto;padding:clamp(34px,6vw,72px) var(--pad) clamp(72px,10vw,120px)}
  .reading-head{margin-bottom:clamp(28px,4vw,44px)}
  .w-eyebrow{font-size:14px;font-weight:600;color:var(--cobalt);margin-bottom:14px}
  .reading-head h1{font-family:var(--disp);font-weight:700;font-size:clamp(48px,9vw,96px);letter-spacing:-.04em;line-height:.95;color:var(--ink);border-bottom:1px solid var(--line);padding-bottom:18px}
  .reading-head h1 .d{color:var(--cobalt)}
  .reading-lede{font-family:var(--grot);font-size:clamp(18px,2vw,21px);line-height:1.55;color:var(--ink-soft);max-width:54ch;margin-top:18px}
  .index-entries .entry>a{padding:26px 0}
  .empty-note{font-size:18px;color:var(--ink-soft);padding:24px 0;border-top:1px solid var(--line)}
  .empty-note a{color:var(--cobalt);border-bottom:1px solid rgba(47,43,240,.3)}
</style>
