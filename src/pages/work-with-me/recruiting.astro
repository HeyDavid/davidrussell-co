---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const lookingFor = [
  {
    role: "Marketing-led operator role",
    detail: "Founding / very-early team at a company where I can run the marketing function end-to-end and have real ownership over outcome.",
  },
  {
    role: "Fractional CMO / Head of Marketing",
    detail: "For 2–3 companies at once where I can do the actual work, not just advise. Ideally companies where I already use or believe in the product.",
  },
  {
    role: "Co-founder partnership",
    detail: "If you're a technical founder with a real product and a real problem and you need someone to figure out how it gets sold, talk to me.",
  },
];

const whatItsLike = [
  "I move fast and ship without ceremony.",
  "I'd rather be told the truth than be made comfortable.",
  "I believe in writing things down. Decisions, tradeoffs, lessons. The work compounds when it's documented.",
  "I default to being on the line for outcomes, not just tasks.",
  "I'm in South Florida (ET). Remote-first, occasional travel fine, full relocation usually not.",
];
---

<BaseLayout
  title="Work with me (recruiting) — David Russell"
  description="Open to a few collaborations and full-time roles where I can make a real difference. Marketing-led operator roles especially."
>
  <Header />
  <main>
    <article class="wwm-page">
      <a href="/" class="wwm-back">← Home</a>

      <header class="wwm-hero">
        <div class="section-kicker">Recruiting</div>
        <h1>If you need a marketing brain that also <em>ships</em>.</h1>
        <p class="wwm-lede">
          I'm open to a small number of full-time or fractional roles where the
          work is real and the leverage is high. I'm not chasing titles or
          checking a network-status box. I'm looking for the kind of company
          where I can move the needle and be proud of how it was moved.
        </p>
        <a class="wwm-cta-primary" href="mailto:david@letschatmarketing.com?subject=Work+with+me">
          <span>Email me directly</span>
          <span class="arrow">→</span>
        </a>
      </header>

      <section class="wwm-block">
        <h2>What I'm looking for.</h2>
        <ul class="wwm-deliverables">
          {lookingFor.map((item) => (
            <li>
              <h3>{item.role}</h3>
              <p>{item.detail}</p>
            </li>
          ))}
        </ul>
      </section>

      <section class="wwm-block">
        <h2>What working with me looks like.</h2>
        <ul class="wwm-list">
          {whatItsLike.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="wwm-block">
        <h2>Background.</h2>
        <p class="wwm-prose">
          A decade of marketing across dozens of industries. Grew a Wix site
          into a marketplace doing $400K+ a year. Built several startups under
          my own name. Currently running Let's Chat (productized agency) plus
          the writing and a couple of side projects.
        </p>
        <p class="wwm-prose">
          The longer version lives on <a href="https://www.linkedin.com/in/heydavidr/">LinkedIn</a>
          and the <a href="/background/">background page</a>.
        </p>
      </section>

      <section class="wwm-cta-block">
        <h2>How to reach me.</h2>
        <p>
          Best path: a one-paragraph email about the role and why you think
          it's a fit. Skip the recruiter intro, send it directly. I read every
          one.
        </p>
        <a class="wwm-cta-primary" href="mailto:david@letschatmarketing.com?subject=Work+with+me">
          <span>david@letschatmarketing.com</span>
          <span class="arrow">→</span>
        </a>
      </section>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Reuses .wwm-* classes from the marketing page — these styles are
     intentionally duplicated per file for component independence. */
  .wwm-page {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 96px) clamp(20px, 4vw, 28px) clamp(80px, 12vw, 140px);
  }
  .wwm-back { display: inline-block; margin-bottom: 48px; color: var(--mist); font-size: 14px; border: 0; }
  .wwm-back:hover { color: var(--signal); }
  .wwm-hero { margin-bottom: clamp(56px, 8vw, 88px); }
  .wwm-hero h1 {
    font-family: var(--serif); font-style: italic; font-weight: 400;
    font-size: clamp(40px, 6vw, 64px); letter-spacing: -0.02em; line-height: 1.05;
    color: var(--star); margin: 8px 0 22px; max-width: 22ch;
  }
  .wwm-hero h1 em { font-style: italic; color: var(--signal); }
  .wwm-lede { font-size: clamp(18px, 2vw, 22px); line-height: 1.55; color: var(--mist); margin-bottom: 32px; max-width: 56ch; }
  .wwm-cta-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 22px; border-radius: 999px;
    border: 1px solid rgba(91, 141, 239, 0.4); background: rgba(91, 141, 239, 0.10);
    color: var(--star); font-family: var(--sans); font-size: 15px; font-weight: 500;
    transition: background 220ms ease, border-color 220ms ease;
  }
  .wwm-cta-primary:hover { background: rgba(91, 141, 239, 0.20); border-color: rgba(91, 141, 239, 0.6); }
  .wwm-cta-primary .arrow { transition: transform 200ms var(--ease-out); }
  .wwm-cta-primary:hover .arrow { transform: translateX(3px); }
  .wwm-block { margin-bottom: clamp(48px, 7vw, 80px); }
  .wwm-block h2 {
    font-family: var(--serif); font-style: italic; font-weight: 400;
    font-size: clamp(28px, 3.6vw, 40px); letter-spacing: -0.02em; line-height: 1.1;
    color: var(--star); margin-bottom: 24px;
  }
  .wwm-prose { font-size: 17px; line-height: 1.7; color: var(--mist); margin-bottom: 18px; max-width: 56ch; }
  .wwm-prose a { color: var(--star); border-bottom: 1px solid rgba(91, 141, 239, 0.35); }
  .wwm-prose a:hover { color: var(--signal); border-bottom-color: var(--signal); }
  .wwm-deliverables { list-style: none; padding: 0; margin: 0; display: grid; gap: 0; }
  .wwm-deliverables li { padding: 22px 0; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .wwm-deliverables li:first-child { border-top: 0; padding-top: 8px; }
  .wwm-deliverables h3 {
    font-family: var(--sans); font-size: 19px; font-weight: 500;
    letter-spacing: -0.015em; color: var(--star); margin-bottom: 6px;
  }
  .wwm-deliverables p { color: var(--mist); font-size: 15px; line-height: 1.55; max-width: 54ch; }
  .wwm-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 14px; }
  .wwm-list li {
    padding-left: 24px;
    position: relative;
    font-size: 16px;
    line-height: 1.6;
    color: var(--mist);
    max-width: 60ch;
  }
  .wwm-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--signal);
  }
  .wwm-cta-block {
    padding: clamp(36px, 5vw, 56px) clamp(28px, 4vw, 44px);
    border: 1px solid rgba(91, 141, 239, 0.15); border-radius: 16px;
    background: rgba(91, 141, 239, 0.04);
  }
  .wwm-cta-block h2 {
    font-family: var(--serif); font-style: italic; font-weight: 400;
    font-size: clamp(28px, 3.6vw, 40px); letter-spacing: -0.02em;
    color: var(--star); margin-bottom: 14px;
  }
  .wwm-cta-block p { color: var(--mist); font-size: 16px; line-height: 1.6; margin-bottom: 22px; max-width: 52ch; }
</style>
