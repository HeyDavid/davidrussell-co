---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const lookingFor = [
  { role: "Marketing-led operator role", detail: "Founding / very-early team at a company where I can run the marketing function end-to-end and have real ownership over outcome." },
  { role: "Fractional CMO / Head of Marketing", detail: "For 2–3 companies at once where I can do the actual work, not just advise. Ideally companies where I already use or believe in the product." },
  { role: "Co-founder partnership", detail: "If you're a technical founder with a real product and a real problem and you need someone to figure out how it gets sold, talk to me." },
];

const whatItsLike = [
  "I move fast and ship without ceremony.",
  "I'd rather be told the truth than be made comfortable.",
  "I believe in writing things down. Decisions, tradeoffs, lessons. The work compounds when it's documented.",
  "I default to being on the line for outcomes, not just tasks.",
  "I'm in South Florida (ET). Remote-first, occasional travel fine, full relocation usually not.",
];
---

<BaseLayout
  title="Work with me (recruiting) — David Russell"
  description="Open to a few collaborations and full-time roles where I can make a real difference. Marketing-led operator roles especially."
>
  <Header />
  <main>
    <article class="work">
      <a href="/" class="back">← Home</a>
      <div class="work-grid">
        <header class="work-head">
          <div class="dateline">The doors &nbsp;/&nbsp; <b>Recruiting</b></div>
          <h1>If you need a marketing brain that also <em>ships</em>.</h1>
          <p class="work-lede">
            I&rsquo;m open to a small number of full-time or fractional roles where the
            work is real and the leverage is high. I&rsquo;m not chasing titles or
            checking a network-status box. I&rsquo;m looking for the kind of company
            where I can move the needle and be proud of how it was moved.
          </p>
          <a class="work-cta" href="mailto:david@letschatmarketing.com?subject=Work+with+me">Email me directly →</a>
        </header>

        <div class="work-body">
          <section class="work-block">
            <h2>What I&rsquo;m looking for.</h2>
            <ul class="record">
              {lookingFor.map((item) => (
                <li class="record-row">
                  <div class="record-name">{item.role}</div>
                  <div class="record-why">{item.detail}</div>
                </li>
              ))}
            </ul>
          </section>

          <section class="work-block">
            <h2>What working with me looks like.</h2>
            <ul class="work-list">
              {whatItsLike.map((item) => (<li>{item}</li>))}
            </ul>
          </section>

          <section class="work-block">
            <h2>Background.</h2>
            <p class="work-prose">
              A decade of marketing across dozens of industries. Grew a Wix site
              into a marketplace doing $400K+ a year. Built several startups under
              my own name. Currently running Let&rsquo;s Chat (an AI voice studio)
              plus a few smaller ventures. More on the
              <a href="/background/"> background page</a>.
            </p>
          </section>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
