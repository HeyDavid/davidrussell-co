---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const businessTypes = [
  "Solo / freelance",
  "Pet services",
  "Creative / artist",
  "Coach / therapist",
  "Photography",
  "Home services",
  "Trades",
  "Medical / dental",
  "Law",
  "Other",
];

// Slot scarcity. Updated monthly. Keep honest: David sets this manually.
const monthName = new Date().toLocaleString("en-US", { month: "long" });
const slotsRemaining = 10;

const portfolio = [
  {
    name: "Maker Margin",
    type: "Etsy fees calculator, solo product",
    url: "https://makermargin.com",
    domain: "makermargin.com",
  },
  {
    name: "Thomas Steed",
    type: "PI and collections attorney",
    url: "https://thomassteed.com",
    domain: "thomassteed.com",
  },
  {
    name: "David Russell",
    type: "Studio site, editorial layout",
    url: "https://davidrussell.co",
    domain: "davidrussell.co",
  },
];

const steps = [
  {
    num: "01",
    day: "Day 1",
    label: "Submit the form",
    desc: "Tell us about your business. We respond within 24 hours with a deposit invoice ($249, half upfront) and any clarifying questions.",
    deliverable: "A clarifying call (optional) and the deposit invoice.",
  },
  {
    num: "02",
    day: "Days 2 to 5",
    label: "We build",
    desc: "Real copy, written for your business. Real photos, sourced or placed. Real layout, designed for what you actually want a visitor to do.",
    deliverable: "A live preview link to click through.",
  },
  {
    num: "03",
    day: "Days 5 to 7",
    label: "Two revision rounds",
    desc: "You ask for changes. We make them. Up to two rounds. After that we ship. Not unlimited revisions. That is how we stay fast.",
    deliverable: "A site you have signed off on.",
  },
  {
    num: "04",
    day: "Day 7 to 10",
    label: "Live on your domain",
    desc: "Domain, hosting, SSL, all handled on our side. We point everything to your new site and you go live.",
    deliverable: "A real website at your domain. Maintenance kicks in at $15 a month.",
  },
];

const comparison = [
  {
    label: "Do it yourself",
    tag: "Wix, Squarespace, Webflow",
    price: "$200 to $500 a year",
    time: "Weeks of fiddling",
    bullets: [
      "You write the copy",
      "You guess at the photos",
      "You fix it when it breaks",
      "Looks like every other template",
    ],
    summary: "A site that exists. Maybe.",
  },
  {
    label: "Spark (us)",
    tag: "Concierge, limited slots",
    price: "$499 setup, $15 a month",
    time: "7 days",
    bullets: [
      "Real copy, written for you",
      "Real photos, sourced or curated",
      "Hosting, SSL, uptime, handled",
      "You text us. We answer.",
    ],
    summary: "A site that earns your first call.",
    featured: true,
  },
  {
    label: "Big agency",
    tag: "Black box build",
    price: "$5,000 to $50,000",
    time: "1 to 3 months",
    bullets: [
      "Discovery deck, kickoff deck, SOW",
      "Long email chains",
      "You meet your account manager, not your builder",
      "Retainer lock-in",
    ],
    summary: "A site, eventually. With invoices.",
  },
];

const addons = [
  { label: "Email list and automation", desc: "Beehiiv-powered list, signup forms, welcome sequence." },
  { label: "Social content", desc: "Monthly posts, scheduling, light community management." },
  { label: "Smart automations and AI tools", desc: "Booking chatbot, content drafts, follow-up sequences. Quietly in the background." },
  { label: "Custom integrations", desc: "Stripe, calendars, CRMs, whatever your tool stack already uses." },
];

const comingSoon = [
  "Voice receptionist (early access)",
  "Built-in scheduling heat map",
  "Same-day publish for emergency updates",
];
---

<BaseLayout
  title="Spark — a real one-page website. Built in a week. $499."
  description="A concierge one-page website for the dog walker, the artist, the solopreneur. $499 setup. $15 a month maintenance. Done in seven days. Limited slots."
>
  <main class="spark-page">

    <!-- Nav -->
    <Header />

    <!-- Hero -->
    <section class="hero wrap" id="top">
      <div class="hero-orb" aria-hidden="true"></div>
      <div class="hero-orb hero-orb--two" aria-hidden="true"></div>

      <div class="hero-status" aria-label="Slot availability">
        <span class="status-dot" aria-hidden="true"></span>
        <span><strong>{slotsRemaining} slots open</strong> for {monthName}</span>
      </div>

      <p class="eyebrow">Spark · The starting line</p>
      <h1>A modern website.<br>Done in a week.<br>$499.</h1>
      <p class="lede">
        Built for the dog walker, the artist, the solopreneur. Spark is where great businesses start showing up online. We write the copy, ship the site, and keep it running. AI tools are quietly built in, never in your face.
      </p>
      <div class="hero-actions">
        <a class="btn-primary" href="#intake-form">Start my site →</a>
        <a class="btn-ghost" href="#portfolio">See examples</a>
      </div>
      <p class="hero-meta">
        <span>7 days to launch</span>
        <span aria-hidden="true">·</span>
        <span>Mobile-perfect</span>
        <span aria-hidden="true">·</span>
        <span>Concierge, by text</span>
        <span aria-hidden="true">·</span>
        <span>{slotsRemaining} slots a month</span>
      </p>
    </section>

    <!-- How it works -->
    <section class="how-band wrap" id="how-it-works">
      <div class="how-head">
        <p class="section-eyebrow">How it works</p>
        <h2>From intake form to a live website. In a week.</h2>
        <p class="how-lede">
          No discovery decks. No drawn-out kickoff calls. We learn the shape of your business, build the page, and move quickly enough that the result still feels current when it launches.
        </p>
      </div>

      <ol class="how-steps">
        {steps.map((step) => (
          <li class="how-step">
            <div class="how-step-head">
              <span class="step-num">{step.num}</span>
              <span class="step-day">{step.day}</span>
            </div>
            <h3>{step.label}</h3>
            <p>{step.desc}</p>
            <p class="step-deliverable"><strong>You get:</strong> {step.deliverable}</p>
          </li>
        ))}
      </ol>

      <p class="how-foot">
        Concierge, not committee. You text one person, you get one answer. We only take {slotsRemaining} new builds a month so we can actually keep that promise.
      </p>
    </section>

    <!-- Portfolio -->
    <section class="portfolio-band wrap" id="portfolio">
      <p class="section-eyebrow">Proof</p>
      <h2>Sites we've shipped</h2>
      <div class="portfolio-grid">
        {portfolio.map((site) => (
          <a class="portfolio-card" href={site.url} target="_blank" rel="noopener noreferrer">
            <div class="portfolio-frame" aria-hidden="true">
              <iframe src={site.url} title={`${site.name} site preview`} loading="lazy"></iframe>
            </div>
            <div class="portfolio-meta">
              <strong>{site.name}</strong>
              <span>{site.type}</span>
              <span class="portfolio-domain">{site.domain}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Comparison: DIY vs. Spark vs. Big Agency -->
    <section class="compare-band wrap" id="comparison">
      <div class="compare-head">
        <p class="section-eyebrow">Why Spark</p>
        <h2>The three ways to get a website. Pick the one that fits.</h2>
        <p class="compare-lede">
          Most small businesses end up choosing between a templated DIY site or a five-figure agency engagement. Spark exists for the gap in the middle. Concierge work, real deliverables, honest pricing, limited slots.
        </p>
      </div>

      <div class="compare-grid">
        {comparison.map((col) => (
          <article class={`compare-card${col.featured ? " compare-card--featured" : ""}`}>
            {col.featured && <p class="compare-badge">Recommended</p>}
            <h3>{col.label}</h3>
            <p class="compare-tag">{col.tag}</p>
            <div class="compare-meta">
              <div>
                <span class="compare-meta-label">Cost</span>
                <strong>{col.price}</strong>
              </div>
              <div>
                <span class="compare-meta-label">Time to launch</span>
                <strong>{col.time}</strong>
              </div>
            </div>
            <ul class="compare-bullets">
              {col.bullets.map((b) => <li>{b}</li>)}
            </ul>
            <p class="compare-summary">{col.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Pricing -->
    <section class="pricing-band wrap" id="pricing">
      <p class="section-eyebrow">Pricing</p>
      <h2>Everything visible. No surprises.</h2>
      <div class="pricing-grid">
        <div class="price-card price-card--main">
          <div class="price-top">
            <p class="price-label">Setup</p>
            <p class="price-amount">$499</p>
            <p class="price-sub">one-time</p>
          </div>
          <ul class="price-includes">
            <li>Single-page website built for your business</li>
            <li>Copy written for you</li>
            <li>Photos sourced or placed</li>
            <li>Domain transfer or purchase handled</li>
            <li>SSL and hosting configured</li>
            <li>2 revision rounds during build</li>
            <li>Launch on your domain</li>
          </ul>
        </div>
        <div class="price-card">
          <div class="price-top">
            <p class="price-label">Maintenance</p>
            <p class="price-amount">$15<span>/mo</span></p>
            <p class="price-sub">after launch</p>
          </div>
          <ul class="price-includes">
            <li>Hosting and uptime monitoring</li>
            <li>SSL and security patches</li>
            <li>24-hour async support response</li>
            <li>Customization billed separately, by the hour</li>
          </ul>
        </div>
        <div class="price-card price-card--addons">
          <div class="price-top">
            <p class="price-label">Add-ons</p>
            <p class="price-sub">Optional. Quoted based on scope.</p>
          </div>
          <ul class="addon-list">
            {addons.map((addon) => (
              <li>
                <strong>{addon.label}</strong>
                <span>{addon.desc}</span>
              </li>
            ))}
          </ul>
          <div class="coming-soon">
            <p class="coming-soon-label">Coming soon</p>
            <ul>
              {comingSoon.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Intake form -->
    <section class="form-band wrap" id="intake-form">
      <div class="form-intro">
        <p class="section-eyebrow">Get started</p>
        <h2>Start my site</h2>
        <p class="form-lede">Fill this out. We'll respond within 24 hours with a deposit invoice and any clarifying questions.</p>
      </div>
      <form class="spark-form" id="spark-form">
        <label>
          <span>Business name</span>
          <input name="businessName" type="text" placeholder="Acme Plumbing" required />
        </label>
        <label>
          <span>Business type</span>
          <select name="businessType" required>
            <option value="" disabled selected>Select one</option>
            {businessTypes.map((t) => <option value={t}>{t}</option>)}
          </select>
        </label>
        <label>
          <span>Current website URL <em>(if any)</em></span>
          <input name="currentUrl" type="url" placeholder="https://oldsite.com" />
        </label>
        <label>
          <span>Your email</span>
          <input name="email" type="email" inputmode="email" placeholder="you@business.com" required />
        </label>
        <label>
          <span>Your phone <em>(optional, for a 15-minute discovery call)</em></span>
          <input name="phone" type="tel" inputmode="tel" placeholder="(555) 000-0000" />
        </label>
        <label>
          <span>Referred by, or how did you hear about us? <em>(optional)</em></span>
          <input name="referredBy" type="text" placeholder="Tom Steed, a Google search, a friend, etc." />
        </label>
        <label class="label-tall">
          <span>Tell us about your business <em>(3 to 5 sentences)</em></span>
          <textarea name="brief" rows="5" placeholder="What your business does, who you want to reach, and what you want visitors to do first." required></textarea>
        </label>
        <button class="submit-button" type="submit">Send my intake →</button>
        <p class="form-note" id="spark-status" aria-live="polite">Async only. We reply within 24 hours.</p>
      </form>
    </section>

    <!-- Tom referral banner (shown only with ?ref=tom-steed) -->
    <div class="referral-banner" id="referral-banner" style="display:none" aria-hidden="true">
      <p>Referred by Tom Steed? You get a complimentary domain transfer + $25 off setup. Just mention it on the intake form.</p>
    </div>

    <!-- Footer -->
    <Footer />
  </main>

  <script>
    // Tom referral banner
    const ref = new URLSearchParams(window.location.search).get("ref");
    if (ref === "tom-steed") {
      const banner = document.getElementById("referral-banner");
      if (banner) {
        banner.style.display = "block";
        banner.removeAttribute("aria-hidden");
      }
    }

    // Intake form
    const form = document.querySelector("#spark-form");
    const status = document.querySelector("#spark-status");
    const button = form instanceof HTMLFormElement ? form.querySelector("button") : null;

    form?.addEventListener("submit", async (event) => {
      if (!(form instanceof HTMLFormElement)) return;
      event.preventDefault();

      const data = Object.fromEntries(new FormData(form));
      const ref = new URLSearchParams(window.location.search).get("ref");
      if (ref) data.ref = ref;

      if (button) { button.disabled = true; button.textContent = "Sending..."; }
      if (status) status.textContent = "Submitting your intake...";

      try {
        const response = await fetch("/api/spark-intake", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result.error || "Something went sideways. Try again in a minute.");
        }

        window.location.href = `/spark/thanks/?ref=${ref || ""}`;
      } catch (error) {
        if (status) status.textContent = error instanceof Error ? error.message : "Something went sideways. Try again in a minute.";
        if (button) { button.disabled = false; button.textContent = "Send my intake →"; }
      }
    });
  </script>

  <style>
    :global(body) {
      margin: 0;
      background:
        radial-gradient(circle at 10% 8%, rgba(6, 182, 212, 0.22), transparent 32%),
        radial-gradient(circle at 88% 20%, rgba(255, 107, 53, 0.18), transparent 28%),
        #0d1117;
      color: #f1f5f9;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
    }

    .spark-page {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
    }

    .wrap {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 clamp(20px, 5vw, 56px);
      box-sizing: border-box;
    }

    /* Nav */
    .spark-nav {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 24px;
      max-width: 1120px;
      margin: 0 auto;
      padding: 18px clamp(20px, 5vw, 56px);
    }

    .brand {
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: 1.5rem;
      font-style: italic;
      font-weight: 700;
      color: #f1f5f9;
      text-decoration: none;
    }
    .brand span { color: #2563eb; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 28px;
      justify-content: center;
    }
    .nav-links a {
      color: #94a3b8;
      font-size: 0.92rem;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.18s;
    }
    .nav-links a:hover { color: #f1f5f9; }

    .nav-cta {
      border: 1px solid rgba(6, 182, 212, 0.5);
      border-radius: 999px;
      padding: 10px 18px;
      color: #3b82f6;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.18s;
    }
    @media (hover: hover) { .nav-cta:hover { background: rgba(6, 182, 212, 0.1); } }

    /* Shared */
    .section-eyebrow {
      margin: 0 0 12px;
      color: #3b82f6;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    h2 {
      margin: 0 0 40px;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.1;
    }

    /* Hero */
    .hero {
      position: relative;
      padding: clamp(48px, 10vw, 100px) 0 clamp(64px, 10vw, 120px);
      isolation: isolate;
    }

    /* Soft fade at the hero bottom, bridges into the next section without a hard line */
    .hero::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 120px;
      background: linear-gradient(to bottom, transparent, rgba(13, 17, 23, 0.6) 60%, #0d1117);
      pointer-events: none;
      z-index: -1;
    }

    /* Soft glowing orbs behind the hero, warmer, less "tech bro" */
    .hero-orb {
      position: absolute;
      top: 8%;
      right: -10%;
      width: 520px;
      height: 520px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 138, 92, 0.32), transparent 65%);
      filter: blur(60px);
      z-index: -1;
      animation: orbDrift 22s ease-in-out infinite alternate;
      pointer-events: none;
    }
    .hero-orb--two {
      top: 60%;
      right: auto;
      left: -8%;
      width: 480px;
      height: 480px;
      background: radial-gradient(circle, rgba(6, 182, 212, 0.28), transparent 65%);
      animation: orbDrift 28s ease-in-out infinite alternate-reverse;
    }
    @keyframes orbDrift {
      0% { transform: translate(0, 0) scale(1); }
      100% { transform: translate(40px, -30px) scale(1.08); }
    }

    /* Scarcity pill */
    .hero-status {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 8px 14px;
      margin-bottom: 28px;
      border: 1px solid rgba(255, 138, 92, 0.32);
      border-radius: 999px;
      background: rgba(255, 138, 92, 0.08);
      font-size: 0.84rem;
      color: #fbd5b8;
    }
    .hero-status strong { color: #fff7ed; font-weight: 700; }
    .hero-status .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #5BD7AE;
      box-shadow: 0 0 0 0 rgba(91, 215, 174, 0.7);
      animation: pulseDot 2s ease-in-out infinite;
    }
    @keyframes pulseDot {
      0%, 100% { box-shadow: 0 0 0 0 rgba(91, 215, 174, 0.6); }
      50% { box-shadow: 0 0 0 7px rgba(91, 215, 174, 0); }
    }

    .hero-meta {
      margin-top: 32px;
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      color: #64748b;
      font-size: 0.88rem;
    }
    .hero-meta span { color: #94a3b8; }

    .eyebrow {
      margin: 0 0 20px;
      color: #3b82f6;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: clamp(3rem, 9vw, 7.5rem);
      font-weight: 700;
      line-height: 0.95;
      letter-spacing: -0.01em;
    }

    .lede {
      margin: 28px 0 0;
      color: #94a3b8;
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      line-height: 1.5;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 36px;
    }

    .btn-primary {
      display: inline-block;
      padding: 16px 28px;
      background: #2563eb;
      color: #041014;
      font-weight: 900;
      font-size: 1rem;
      border-radius: 8px;
      text-decoration: none;
      transition: transform 0.18s, background 0.18s;
    }
    @media (hover: hover) { .btn-primary:hover { transform: translateY(-2px); background: #3b82f6; } }

    .btn-ghost {
      display: inline-block;
      padding: 16px 28px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 8px;
      color: #cbd5e1;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: border-color 0.18s, color 0.18s;
    }
    .btn-ghost:hover { border-color: rgba(255, 255, 255, 0.36); color: #f1f5f9; }

    /* How it works (merged what-you-get + process) */
    .how-band {
      padding: clamp(56px, 9vw, 112px) 0;
    }

    .how-head {
      margin-bottom: 48px;
      max-width: 60ch;
    }

    .how-head h2 {
      margin: 0 0 16px;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: clamp(1.9rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.1;
    }

    .how-lede {
      margin: 0;
      color: #94a3b8;
      font-size: 1.02rem;
      line-height: 1.6;
    }

    .how-steps {
      list-style: none;
      margin: 0 0 32px;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    .how-step {
      padding: 26px 26px 24px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.015));
      transition: border-color 0.2s, transform 0.2s;
    }
    @media (hover: hover) { .how-step:hover { border-color: rgba(6, 182, 212, 0.32); transform: translateY(-2px); } }

    .how-step-head {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 14px;
    }

    .how-step .step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(6, 182, 212, 0.12);
      border: 1px solid rgba(6, 182, 212, 0.42);
      color: #3b82f6;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
    }

    .how-step .step-day {
      color: #fbd5b8;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .how-step h3 {
      margin: 0 0 8px;
      font-family: "Plus Jakarta Sans", system-ui, sans-serif;
      font-size: 1.32rem;
      font-weight: 700;
      color: #f1f5f9;
      line-height: 1.2;
    }

    .how-step p {
      margin: 0 0 14px;
      color: #cbd5e1;
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .step-deliverable {
      margin: 14px 0 0 !important;
      padding-top: 14px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      color: #94a3b8 !important;
      font-size: 0.88rem !important;
