---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const deliverables = [
  { name: "A site that earns the click", detail: "Strategy + copy + design + build. Best-in-class typography, real motion, performance budget under 1s LCP." },
  { name: "Funnels with the math in plain sight", detail: "From landing page through email + retargeting to conversion. Every step measured. No vanity metrics." },
  { name: "Brand language you can actually use", detail: "Voice, positioning, key messages. Documented so your team writes consistently without me in the room." },
  { name: "An operating partner during launch", detail: "I stay close while it goes live. Daily check-ins. Fast iteration on real data, not opinions." },
];

const faq = [
  { q: "What does an engagement actually cost?", a: "Full site builds run $1,500–$12,000 depending on scope, with a care plan from $49–$299/mo if you want it kept fast and current after launch. Consulting is $175/hr, or $1,500/mo on retainer. I'll quote a fixed price once we've talked. No surprises after." },
  { q: "How long do you take?", a: "A site rebuild typically lands in 3–5 weeks. A funnel build inside 2–3. I move faster than that when the brief is clean." },
  { q: "Do you work with agencies or only directly with founders?", a: "Both. Most often I'm the marketing brain for a small operating team — founder, ops, and me — but agency-side white-label is fine if the brief is right." },
  { q: "What's the right kind of business for this?", a: "Service businesses, local operators, B2B SaaS, and creator-led companies — any size where the website has a real job to do. Not sure you're ready? Book the call anyway and I'll tell you straight, or start with the newsletter." },
];
---

<BaseLayout
  title="Hire me for marketing — David Russell"
  description="Best-in-class websites and marketing funnels for service businesses, B2B SaaS, and operator-led companies. By David Russell, South Florida."
>
  <Header />
  <main>
    <article class="work">
      <a href="/" class="back">← Home</a>
      <div class="work-grid">
        <header class="work-head">
          <div class="dateline">The doors &nbsp;/&nbsp; <b>Marketing</b></div>
          <h1>Better websites. Better funnels. <em>Built by an operator.</em></h1>
          <p class="work-lede">
            Most marketing sites are decoration. The work I do is structural —
            the page, the copy, the funnel underneath, and the math that proves
            it&rsquo;s earning. For service businesses and operator-led companies
            who want the math to actually work.
          </p>
          <a class="work-cta" href="https://cal.com/letschatmarketing/30min">Tell me about your project →</a>
        </header>

        <div class="work-body">
          <section class="work-block">
            <h2>What you&rsquo;re getting.</h2>
            <ul class="record">
              {deliverables.map((d) => (
                <li class="record-row">
                  <div class="record-name">{d.name}</div>
                  <div class="record-why">{d.detail}</div>
                </li>
              ))}
            </ul>
          </section>

          <section class="work-block">
            <h2>Common questions.</h2>
            <div class="qa">
              {faq.map((f) => (
                <div class="qa-row">
                  <div class="qa-q">{f.q}</div>
                  <div class="qa-a">{f.a}</div>
                </div>
              ))}
            </div>
          </section>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
