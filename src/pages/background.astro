---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout
  title="Background - David Russell"
  description="The short background on David Russell: marketing operator, founder, publisher, and builder in South Florida."
>
  <Header />
  <main>
    <section class="essay">
      <a href="/" class="back">Back to home</a>
      <h1>Background.</h1>
      <p class="lede">
        Ten years in marketing, plus a few small ventures that taught the parts you only learn by shipping.
      </p>
      <div class="post-body">
        <p>
          I built and sold Moolaguides, co-founded Syllble Publishing House, helped publish more than 115 novels with authors around the world, and now run experiments around service businesses, seller tools, and practical AI.
        </p>
        <p>
          The through-line is simple: useful offers, clean execution, and fewer decorative activities.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
