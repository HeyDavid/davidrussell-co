---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout
  title="Let's Chat - David Russell"
  description="David Russell's founder lane: Let's Chat, productized marketing systems, and small business AI."
>
  <Header />
  <main>
    <section class="essay">
      <a href="/" class="back">Back to home</a>
      <h1>Founder.</h1>
      <p class="lede">
        Let's Chat is where I package marketing work into clear systems for service businesses: better websites, sharper offers, and AI-enabled intake that does not feel like a science fair project.
      </p>
      <div class="post-body">
        <p>
          The public home for that work is <a href="https://letschatmarketing.com">letschatmarketing.com</a>. This lane exists here so the personal site has a clean path into the operating company without turning the whole homepage into a storefront.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
