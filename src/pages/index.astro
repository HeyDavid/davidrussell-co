<script is:inline>
(function(){
  var fine = window.matchMedia('(pointer:fine)').matches;
  var cur = document.getElementById('cur'), aura = document.getElementById('aura');
  if(fine){
    var x=innerWidth/2,y=innerHeight/2,cx=x,cy=y;
    addEventListener('mousemove',function(e){x=e.clientX;y=e.clientY;aura.style.setProperty('--mx',x+'px');aura.style.setProperty('--my',y+'px');});
    (function loop(){cx+=(x-cx)*.2;cy+=(y-cy)*.2;cur.style.transform='translate('+cx+'px,'+cy+'px) translate(-50%,-50%)';requestAnimationFrame(loop);})();
    document.querySelectorAll('[data-c],a,button').forEach(function(el){el.addEventListener('mouseenter',function(){cur.classList.add('big');});el.addEventListener('mouseleave',function(){cur.classList.remove('big');});});
  }
  var menu=document.getElementById('menu'),nav=document.getElementById('nav');
  menu.addEventListener('click',function(){menu.classList.toggle('open');nav.classList.toggle('open');});
  nav.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){menu.classList.remove('open');nav.classList.remove('open');});});
  var posts=document.getElementById('posts'),peek=document.getElementById('peek');
  function show(id){peek.querySelectorAll('.pk').forEach(function(r){r.classList.toggle('on',id?r.getAttribute('data-for')===id:r.classList.contains('pk-default'));});}
  posts.querySelectorAll('[data-pk]').forEach(function(a){a.addEventListener('mouseenter',function(){show(a.getAttribute('data-pk'));});});
  posts.addEventListener('mouseleave',function(){show(null);});
  var bar=document.getElementById('bar');addEventListener('scroll',function(){bar.classList.toggle('scrolled',scrollY>8);},{passive:true});
  var ups=document.querySelectorAll('.up');
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.08});
    ups.forEach(function(el){io.observe(el);});
    setTimeout(function(){ups.forEach(function(el){el.classList.add('in');});},4000);
  } else { ups.forEach(function(el){el.classList.add('in');}); }

  // Beehiiv subscribe
  function wire(formId, medium){
    var f=document.getElementById(formId); if(!f) return;
    f.addEventListener('submit',function(ev){
      ev.preventDefault();
      var input=f.querySelector('input'), btn=f.querySelector('button'), cap=f.querySelector('.cap');
      var email=(input.value||'').trim(); if(!email) return;
      btn.disabled=true; var old=btn.textContent; btn.textContent='Sending…';
      var d=new FormData();
      d.set('email',email); d.set('utm_source','davidrussell.co'); d.set('utm_medium',medium); d.set('tags','dr-subscriber'); d.set('referring_site','davidrussell.co');
      fetch('https://embeds.beehiiv.com/pub_ed495df0-b44a-47ba-939c-eeb46089e27b',{method:'POST',mode:'no-cors',body:d}).finally(function(){
        f.reset(); btn.disabled=false; btn.textContent=old;
        if(cap){ cap.textContent='Got it. Check your inbox to confirm.'; cap.classList.add('done'); }
      });
    });
  }
  wire('sub1','hero'); wire('sub2','footer');

  // Lightweight WebGL gradient (capped res, ~30fps, pauses offscreen/hidden, reduced-motion safe)
  (function(){
    var c=document.getElementById('herogl'); if(!c) return;
    var hero=c.closest('.hero');
    if(window.matchMedia('(prefers-reduced-motion: reduce)').matches){ hero.classList.add('nogl'); return; }
    var gl=null; try{ gl=c.getContext('webgl',{antialias:false,alpha:true,depth:false,powerPreference:'low-power'}); }catch(e){}
    if(!gl){ hero.classList.add('nogl'); return; }
    var coarse=window.matchMedia('(pointer:coarse)').matches;
    var dpr=Math.min(window.devicePixelRatio||1, coarse?1:1.4);
    var vs='attribute vec2 p;void main(){gl_Position=vec4(p,0.0,1.0);}';
    var fs='precision mediump float;uniform float t;uniform vec2 r;'+
      'void main(){vec2 uv=gl_FragCoord.xy/r;'+
      'float a=sin(uv.x*3.0+t)*0.5+sin(uv.y*2.6-t*1.15)*0.5+sin((uv.x+uv.y)*2.0+t*0.8)*0.5;a=a*0.5+0.5;'+
      'vec3 cream=vec3(0.984,0.961,0.918);vec3 cob=vec3(0.184,0.169,0.941);vec3 lil=vec3(0.74,0.68,1.0);vec3 sky=vec3(0.58,0.72,1.0);'+
      'vec3 col=mix(cream,lil,smoothstep(0.15,0.7,a));col=mix(col,cob,smoothstep(0.62,1.0,a)*0.45);col=mix(col,sky,smoothstep(0.0,0.45,1.0-a)*0.35);'+
      'gl_FragColor=vec4(col,1.0);}';
    function mk(ty,src){var s=gl.createShader(ty);gl.shaderSource(s,src);gl.compileShader(s);return s;}
    var pr=gl.createProgram(); gl.attachShader(pr,mk(gl.VERTEX_SHADER,vs)); gl.attachShader(pr,mk(gl.FRAGMENT_SHADER,fs)); gl.linkProgram(pr); gl.useProgram(pr);
    var b=gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER,b); gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    var lp=gl.getAttribLocation(pr,'p'); gl.enableVertexAttribArray(lp); gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    var uT=gl.getUniformLocation(pr,'t'), uR=gl.getUniformLocation(pr,'r');
    function size(){var w=hero.clientWidth,h=hero.clientHeight; var cap=Math.min(w,900),sc=cap/w; c.width=Math.max(2,Math.round(w*sc*dpr)); c.height=Math.max(2,Math.round(h*sc*dpr)); gl.viewport(0,0,c.width,c.height);}
    size(); addEventListener('resize',size);
    var vis=true;
    if('IntersectionObserver' in window){ new IntersectionObserver(function(e){vis=e[0].isIntersecting;},{threshold:0}).observe(hero); }
    var t0=performance.now(),last=0;
    function frame(now){ requestAnimationFrame(frame); if(!vis||document.hidden) return; if(now-last<33) return; last=now; gl.uniform1f(uT,(now-t0)*0.001); gl.uniform2f(uR,c.width,c.height); gl.drawArrays(gl.TRIANGLES,0,3); }
    requestAnimationFrame(frame);
  })();
})();
</script>
