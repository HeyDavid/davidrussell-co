---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import WritingTeaser from "@/components/WritingTeaser.astro";
import Building from "@/components/Building.astro";
import WorkWithMe from "@/components/WorkWithMe.astro";
import Background from "@/components/Background.astro";
import GetInTouch from "@/components/GetInTouch.astro";
import IndexRail from "@/components/IndexRail.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout
  title="David Russell — Operator, builder, writer"
  description="Solo founder in South Florida. Marketer for a decade. Grew a Wix site into a $400K+ marketplace. Building Let's Chat and a few smaller ventures."
>
  <Header />
  <main>
    <div class="almanac">
      <Hero />
      <div class="almanac-grid">
        <div class="almanac-main">
          <WritingTeaser />
          <Building />
          <WorkWithMe />
          <Background />
          <GetInTouch />
        </div>
        <IndexRail />
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
