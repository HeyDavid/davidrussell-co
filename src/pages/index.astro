---
import { getCollection } from "astro:content";

const all = await getCollection("writing", ({ data }) => !data.draft);
const posts = all
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short" });

const questions: Record<string, string> = {
  "competitive-gaming-operator-flow": "What would you remove to get two real hours of focus tomorrow?",
  "marketing-is-splitting-in-half": "Are you building the slop machine or the craft brand?",
  "sapiens-in-a-hurry": "Which fiction are you strengthening — and should you be?",
};
const peekLabel: Record<string, string> = {
  "competitive-gaming-operator-flow": "log · operator flow",
  "marketing-is-splitting-in-half": "note · the split",
  "sapiens-in-a-hurry": "note · sapiens",
};
const fallbackQ = "Reply and tell me where I'm wrong.";

const title = "David Russell — operator, writer";
const description = "I build small, useful companies and write down what I learn — then I read every reply. A decade in marketing and a $400K+ exit. South Florida.";
const canonical = "https://davidrussell.co/";
const ogImage = "https://davidrussell.co/og.png";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta property="og:type" content="website">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
<meta name="theme-color" content="#fbf5ea">
<meta name="color-scheme" content="light">
<script is:inline>document.documentElement.className += ' js';</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "374371c09f5d4d4b83fe5e0a2f55cbc6"}'></script>
<style is:global>
:root{
  --paper:#fbf5ea; --card:#fffdf8; --ink:#1b1812; --dim:#7a7264; --faint:#a99f8d;
  --cobalt:#2f2bf0; --cobalt-deep:#211ec0; --cream-on:#eceaff;
  --line:rgba(27,24,18,.13); --line-soft:rgba(27,24,18,.08);
  --disp:"Bricolage Grotesque",system-ui,sans-serif; --grot:"Hanken Grotesk",system-ui,sans-serif;
  --ease:cubic-bezier(.19,1,.22,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--paper);color:var(--ink);font-family:var(--grot);font-size:18px;line-height:1.62;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
::selection{background:var(--cobalt);color:#fff}
#aura{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.7;background:radial-gradient(460px 460px at var(--mx,50%) var(--my,36%),rgba(47,43,240,.06),transparent 70%)}
#cur{position:fixed;top:0;left:0;width:10px;height:10px;border-radius:50%;background:var(--cobalt);z-index:9999;pointer-events:none;transform:translate(-50%,-50%);transition:width .28s var(--ease),height .28s var(--ease),opacity .28s}
#cur.big{width:60px;height:60px;opacity:.18}
.inner{max-width:1140px;margin:0 auto;padding:0 clamp(22px,5vw,64px);position:relative;z-index:1}
section{position:relative;z-index:1}

.bar{position:sticky;top:0;z-index:60;background:rgba(251,245,234,.86);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid transparent;transition:border-color .3s}
.bar.scrolled{border-bottom-color:var(--line)}
.bar .in{max-width:1140px;margin:0 auto;padding:14px clamp(22px,5vw,64px);display:flex;align-items:center;justify-content:space-between;gap:20px}
.brand{display:flex;align-items:center;gap:12px}
.brand .ava{width:40px;height:40px;border-radius:50%;object-fit:cover;object-position:center 14%}
.brand .wm{font-family:var(--disp);font-weight:700;font-size:24px;letter-spacing:-.035em;line-height:1}
.brand .wm .d{color:var(--cobalt)}
.nav{display:flex;align-items:center;gap:26px;font-size:16px;font-weight:500}
.nav a{color:var(--dim);transition:color .3s}.nav a:hover{color:var(--ink)}
.nav .cta{color:#fff;background:var(--cobalt);padding:9px 18px;border-radius:100px;font-weight:600;font-size:15px;transition:background .3s}
.nav .cta:hover{background:var(--cobalt-deep)}
.menu{display:none;border:0;background:transparent;cursor:pointer;font-family:var(--grot);font-weight:600;font-size:15px;color:var(--ink);align-items:center;gap:8px}
.menu .ic{display:block;width:20px;height:2px;background:var(--ink);position:relative;transition:.3s}
.menu .ic::before,.menu .ic::after{content:"";position:absolute;left:0;width:20px;height:2px;background:var(--ink);transition:.3s}
.menu .ic::before{top:-6px}.menu .ic::after{top:6px}
.menu.open .ic{background:transparent}
.menu.open .ic::before{top:0;transform:rotate(45deg)}.menu.open .ic::after{top:0;transform:rotate(-45deg)}
@media(max-width:720px){
  .menu{display:flex}
  .nav{position:fixed;top:68px;left:0;right:0;flex-direction:column;align-items:flex-start;gap:0;background:var(--card);border-bottom:1px solid var(--line);padding:8px 0;transform:translateY(-12px);opacity:0;pointer-events:none;transition:.3s var(--ease);box-shadow:0 24px 50px rgba(27,24,18,.12)}
  .nav.open{transform:none;opacity:1;pointer-events:auto}
  .nav a{width:100%;padding:14px clamp(22px,5vw,64px);font-size:18px}
  .nav .cta{background:transparent;color:var(--cobalt);border-radius:0;padding:14px clamp(22px,5vw,64px)}
}

.hero{padding:clamp(36px,7vh,84px) 0 clamp(46px,7vw,90px);position:relative}
#herogl{position:absolute;inset:0;width:100%;height:100%;z-index:0;opacity:.62;pointer-events:none;
  -webkit-mask-image:radial-gradient(125% 105% at 72% 26%,#000 26%,transparent 74%);mask-image:radial-gradient(125% 105% at 72% 26%,#000 26%,transparent 74%)}
.hero.nogl #herogl{background:radial-gradient(60% 80% at 75% 22%,rgba(47,43,240,.16),transparent 60%),radial-gradient(55% 65% at 22% 85%,rgba(120,110,255,.13),transparent 62%)}
.hero .grid{display:grid;grid-template-columns:1.32fr .88fr;gap:clamp(30px,5vw,70px);align-items:center;position:relative;z-index:1}
.hero .ey{font-size:15px;font-weight:600;color:var(--cobalt);margin-bottom:22px}
.js .hero .ey{animation:rise 1s var(--ease) .05s both}
.hero h1{font-family:var(--disp);font-weight:700;font-size:clamp(44px,6.6vw,92px);line-height:.96;letter-spacing:-.035em}
.js .hero h1{animation:rise 1.1s var(--ease) .12s both}
.hero h1 .c{color:var(--cobalt)}
@keyframes rise{from{opacity:0;transform:translateY(34px)}to{opacity:1;transform:none}}
.hero .sub{margin-top:28px;max-width:46ch;font-size:clamp(18px,1.9vw,21px);color:var(--ink);line-height:1.55}
.js .hero .sub{animation:rise 1.1s var(--ease) .45s both}
.hero .sub b{font-weight:700;color:var(--cobalt)}
.signup{margin-top:34px;max-width:460px}
.js .hero .signup{animation:rise 1.1s var(--ease) .68s both}
.field{display:flex;background:var(--card);border:1.5px solid var(--line);border-radius:100px;padding:6px 6px 6px 22px;transition:border-color .3s}
.field:focus-within{border-color:var(--cobalt)}
.field input{flex:1;min-width:0;border:0;background:transparent;outline:none;font-family:var(--grot);font-size:16px;color:var(--ink)}
.field input::placeholder{color:var(--faint)}
.field button{border:0;background:var(--ink);color:var(--paper);border-radius:100px;padding:11px 22px;cursor:pointer;font-family:var(--grot);font-weight:600;font-size:15px;white-space:nowrap;transition:background .3s}
.field button:hover{background:var(--cobalt)}
.field button:disabled{opacity:.6;cursor:default}
.signup .cap{font-size:14.5px;color:var(--dim);margin-top:12px;padding-left:4px}
.signup .cap.done{color:var(--cobalt);font-weight:600}
.por{position:relative;justify-self:center;width:100%;max-width:380px}
.js .por{animation:rise 1.2s var(--ease) .32s both}
.por .block{position:absolute;left:-22px;bottom:-22px;width:88%;height:84%;background:var(--cobalt);z-index:0}
.por .frame{position:relative;z-index:1;aspect-ratio:4/5;border-radius:230px 230px 14px 14px;overflow:hidden;box-shadow:0 30px 60px rgba(27,24,18,.16)}
.por .frame img{width:100%;height:100%;object-fit:cover;object-position:center 12%}
.por .cap{position:absolute;z-index:2;right:-10px;top:24px;background:var(--ink);color:var(--paper);font-size:12px;font-weight:600;padding:7px 13px;border-radius:100px;transform:rotate(3deg)}

.strip{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:18px 0;overflow:hidden;white-space:nowrap}
.strip .track{display:inline-block;animation:scroll 30s linear infinite;font-family:var(--disp);font-weight:600;font-size:22px}
.strip .track span{margin:0 24px;color:var(--dim)}.strip .track .dot{color:var(--cobalt)}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.sec{padding:clamp(58px,8vw,112px) 0}
.sec-h{display:flex;align-items:baseline;justify-content:space-between;gap:20px;margin-bottom:14px}
.sec-h h2{font-family:var(--disp);font-weight:700;font-size:clamp(34px,5vw,66px);line-height:1;letter-spacing:-.03em}
.sec-h h2 .c{color:var(--cobalt)}
.sec-h .all{font-size:16px;font-weight:600;color:var(--cobalt);white-space:nowrap}
.sec-note{color:var(--dim);font-size:17px;max-width:58ch;line-height:1.55;margin-bottom:42px}

.blog{display:grid;grid-template-columns:1fr .82fr;gap:48px;align-items:start}
.posts{list-style:none}
.post a{display:block;position:relative;padding:26px 0;border-top:1px solid var(--line-soft);transition:padding-left .5s var(--ease),opacity .4s}
.post:first-child a{border-top:0}
.posts:hover .post a{opacity:.4}.posts .post a:hover{opacity:1;padding-left:16px}
.post .pt{font-family:var(--disp);font-weight:600;font-size:clamp(25px,2.9vw,38px);line-height:1.06;letter-spacing:-.02em}
.post .pm{font-size:14.5px;color:var(--faint);margin-top:8px;font-weight:500}
.peek{position:sticky;top:110px}
.pkbox{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:30px 34px;min-height:240px;position:relative;overflow:hidden}
.pkbox::before{content:"";position:absolute;left:0;top:0;bottom:0;width:5px;background:var(--cobalt)}
.pk{position:absolute;inset:0;padding:30px 34px;opacity:0;transform:translateY(12px);transition:opacity .5s var(--ease),transform .6s var(--ease)}
.pk.on{opacity:1;transform:none}
.pk .pkk{font-size:13.5px;color:var(--cobalt);font-weight:700;margin-bottom:13px;text-transform:lowercase}
.pk .pkd{font-family:var(--disp);font-weight:500;font-size:clamp(21px,2.2vw,27px);line-height:1.2;letter-spacing:-.01em}
.pk .q{margin-top:20px;padding-top:16px;border-top:1px solid var(--line-soft)}
.pk .q .ql{font-size:13px;color:var(--dim);margin-bottom:6px;font-weight:500}
.pk .q .qt{font-weight:600;font-size:clamp(17px,1.8vw,20px);line-height:1.32}
.pk-default .pkd{color:var(--dim)}

.lead-line{font-family:var(--disp);font-weight:600;font-size:clamp(24px,3.2vw,40px);line-height:1.1;letter-spacing:-.02em;max-width:20ch;margin-bottom:48px}
.lead-line .c{color:var(--cobalt)}
.mode{display:grid;grid-template-columns:minmax(0,auto) 1fr;gap:clamp(20px,4vw,52px);align-items:center;padding:clamp(20px,2.6vw,30px) 0;border-top:1px solid var(--line)}
.mode .verb{font-family:var(--disp);font-weight:800;font-size:clamp(52px,10vw,138px);line-height:.82;letter-spacing:-.045em;color:var(--cobalt);transition:transform .5s var(--ease)}
.mode:hover .verb{transform:translateX(10px)}
.mode .body .pn{font-family:var(--disp);font-weight:700;font-size:clamp(22px,2.4vw,32px);letter-spacing:-.02em;display:inline-flex;align-items:baseline;gap:10px}
.mode .body .pn .ar{color:var(--cobalt);font-size:.7em;transition:transform .4s var(--ease)}
.mode:hover .body .pn .ar{transform:translate(6px,-6px)}
.mode .body .ps{color:var(--dim);font-size:17px;line-height:1.5;margin-top:8px;max-width:46ch}
@media(max-width:720px){.mode{grid-template-columns:1fr;gap:8px}.mode .verb{font-size:clamp(60px,20vw,90px)}}

.desk{background:var(--cobalt);color:#fff}
.desk .grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(34px,5vw,72px);align-items:center}
.desk h2{font-family:var(--disp);font-weight:700;font-size:clamp(34px,4.8vw,64px);line-height:1.0;letter-spacing:-.03em;max-width:15ch}
.desk .bd{color:var(--cream-on);font-size:17.5px;line-height:1.6;margin-top:22px;max-width:46ch}
.desk .rule{margin-top:22px;font-family:var(--disp);font-weight:600;font-size:18px;color:#fff;opacity:.92}
.desk .cta{margin-top:28px;display:inline-block;background:var(--paper);color:var(--ink);font-weight:600;font-size:16px;padding:13px 26px;border-radius:100px;transition:transform .3s var(--ease)}
.desk .cta:hover{transform:translateY(-2px)}
.slips{display:flex;flex-direction:column;gap:16px}
.slip{background:var(--card);color:var(--ink);border-radius:12px;padding:20px 24px;box-shadow:0 16px 40px rgba(17,15,80,.22)}
.slip:nth-child(1){transform:rotate(-1.4deg)}.slip:nth-child(2){transform:rotate(.8deg)}.slip:nth-child(3){transform:rotate(-.6deg)}
.slip .sl{font-size:12.5px;color:var(--cobalt);font-weight:700;margin-bottom:7px}
.slip .sq{font-family:var(--disp);font-weight:600;font-size:21px;line-height:1.18;letter-spacing:-.01em}
.desk .note{margin-top:22px;color:var(--cream-on);font-size:14.5px;opacity:.85}
@media(max-width:720px){.desk .grid{grid-template-columns:1fr}}

.aboutgrid{display:grid;grid-template-columns:.7fr 1.3fr;gap:clamp(30px,5vw,64px);align-items:start}
.aboutimg{width:100%;max-width:280px;aspect-ratio:1/1;border-radius:18px;object-fit:cover;object-position:center 14%}
.about p{font-size:clamp(19px,2vw,23px);line-height:1.5;font-family:var(--disp);font-weight:500;letter-spacing:-.01em}
.about p+p{margin-top:18px;font-size:18px;font-family:var(--grot);font-weight:400;color:var(--dim);letter-spacing:0;line-height:1.6}
.about .more{margin-top:24px;font-size:16px;font-weight:600;color:var(--cobalt);display:inline-block}
@media(max-width:720px){.aboutgrid{grid-template-columns:1fr}}

.close{padding:clamp(70px,9vw,140px) 0}
.talk{font-family:var(--disp);font-weight:800;font-size:clamp(56px,11vw,150px);line-height:.9;letter-spacing:-.04em}
.talk .c{color:var(--cobalt)}
.cmeta{display:flex;flex-wrap:wrap;gap:16px 30px;margin-top:36px;font-size:17px;font-weight:500}
.cmeta a{color:var(--ink);border-bottom:2px solid var(--line);padding-bottom:3px;transition:border-color .3s,color .3s}
.cmeta a:hover{color:var(--cobalt);border-color:var(--cobalt)}
.colophon{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:14px;color:var(--faint);padding:34px 0;border-top:1px solid var(--line-soft);margin-top:56px}

.up{}
.js .up{opacity:0;transform:translateY(28px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.js .up.in{opacity:1;transform:none}
@media(pointer:coarse){#cur,#aura{display:none}}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}.js .up{opacity:1;transform:none}.strip .track{animation:none}}
</style>
</head>
<body>
<div id="aura"></div><div id="cur"></div>

<header class="bar" id="bar"><div class="in">
  <a class="brand" href="#top" data-c><img class="ava" src="/assets/headshot.jpg" alt="david russell"><span class="wm">david <span class="d">russell</span></span></a>
  <button class="menu" id="menu" aria-label="Menu"><span class="ic"></span></button>
  <nav class="nav" id="nav"><a href="#writing" data-c>Writing</a><a href="#built" data-c>Work</a><a href="#about" data-c>About</a><a href="#subscribe" class="cta" data-c>Subscribe</a></nav>
</div></header>

<div id="top"></div>
<section class="hero"><canvas id="herogl"></canvas><div class="inner">
  <div class="grid">
    <div>
      <div class="ey">david russell · operator &amp; writer · south florida</div>
      <h1>I build small companies and <span class="c">write down</span> what I learn.</h1>
      <p class="sub">A decade in marketing and a <b>$400K+ exit</b> behind me. I publish in the open — then I read every reply. Read along, and push back.</p>
      <form class="signup" id="sub1">
        <div class="field"><input type="email" name="email" placeholder="your email" autocomplete="email" required><button type="submit" data-c>Subscribe</button></div>
        <div class="cap">A few notes a month. No spam — and every issue is a conversation.</div>
      </form>
    </div>
    <figure class="por">
      <div class="block"></div>
      <div class="frame"><img src="/assets/headshot.jpg" alt="David Russell" width="600" height="750"></div>
      <figcaption class="cap">Coral Springs, FL</figcaption>
    </figure>
  </div>
</div></section>

<div class="strip"><div class="track">
  <span>Marketing that earns trust</span><span class="dot">&bull;</span><span>Building in plain sight</span><span class="dot">&bull;</span><span>Operator notes</span><span class="dot">&bull;</span><span>Craft over slop</span><span class="dot">&bull;</span><span>Small, useful companies</span><span class="dot">&bull;</span><span>Marketing that earns trust</span><span class="dot">&bull;</span><span>Building in plain sight</span><span class="dot">&bull;</span><span>Operator notes</span><span class="dot">&bull;</span><span>Craft over slop</span><span class="dot">&bull;</span><span>Small, useful companies</span><span class="dot">&bull;</span>
</div></div>

<section class="sec up" id="writing"><div class="inner">
  <div class="sec-h"><h2>The <span class="c">writing.</span></h2><a class="all" href="/writing/" data-c>Read everything →</a></div>
  <p class="sec-note">Operator notes, the odd argument, a flow log when something works. Every piece ends with a question — hover one to see what it leaves you with.</p>
  <div class="blog">
    <ul class="posts" id="posts">
      {posts.map((post) => (
        <li class="post"><a href={`/writing/${post.id}/`} data-pk={post.id} data-c><div class="pt">{post.data.title}</div><div class="pm">{post.data.format} · {fmt(post.data.publishDate)}{post.data.readTime ? ` · ${post.data.readTime}` : ""}</div></a></li>
      ))}
    </ul>
    <div class="peek"><div class="pkbox" id="peek">
      <div class="pk pk-default on"><div class="pkk">the writing</div><div class="pkd">Short, occasional, never spam. The point isn&rsquo;t the post — it&rsquo;s the argument it starts.</div></div>
      {posts.map((post) => (
        <div class="pk" data-for={post.id}>
          <div class="pkk">{peekLabel[post.id] ?? post.data.format}</div>
          <div class="pkd">{post.data.description}</div>
          <div class="q"><div class="ql">Leaves you with</div><div class="qt">&ldquo;{questions[post.id] ?? fallbackQ}&rdquo;</div></div>
        </div>
      ))}
    </div></div>
  </div>
</div></section>

<section class="sec up" id="built"><div class="inner">
  <p class="lead-line">I don&rsquo;t have one neat job title. I <span class="c">build around the problems</span> I keep seeing.</p>
  <div class="modes">
    <a class="mode" href="https://letschatmarketing.com" target="_blank" rel="noopener" data-c>
      <div class="verb">Serve.</div>
      <div class="body"><div class="pn">Let&rsquo;s Chat <span class="ar">&#8599;</span></div><div class="ps">The practical marketing shop — websites, content, search, and systems for businesses that need someone accountable.</div></div>
    </a>
    <a class="mode" href="https://makermargin.co" target="_blank" rel="noopener" data-c>
      <div class="verb">Make.</div>
      <div class="body"><div class="pn">Maker Margin <span class="ar">&#8599;</span></div><div class="ps">A free tool that does the Etsy-fee math sellers dread. Built small, kept useful.</div></div>
    </a>
    <a class="mode" href="https://scamcapital.com" target="_blank" rel="noopener" data-c>
      <div class="verb">Warn.</div>
      <div class="body"><div class="pn">ScamCapital <span class="ar">&#8599;</span></div><div class="ps">Turns confusing scams into clear, plain-English warnings regular people can act on.</div></div>
    </a>
  </div>
</div></section>

<section class="sec desk up"><div class="inner">
  <div class="grid">
    <div>
      <h2>The best part is usually in <span style="opacity:.6">the replies.</span></h2>
      <p class="bd">I read every one — not because it scales, but because it keeps the writing honest. Send the thought you almost didn&rsquo;t send: the pushback, the example, the better question.</p>
