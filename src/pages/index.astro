<script is:inline>
(function(){
  var fine = window.matchMedia('(pointer:fine)').matches;
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var cur = document.getElementById('cur'), aura = document.getElementById('aura');
  window.__pointer = { x: innerWidth*0.72, y: innerHeight*0.30, active:false };
  if(fine && !reduce){
    var x=innerWidth/2,y=innerHeight/2,cx=x,cy=y;
    addEventListener('mousemove',function(e){x=e.clientX;y=e.clientY;window.__pointer.x=x;window.__pointer.y=y;window.__pointer.active=true;aura.style.setProperty('--mx',x+'px');aura.style.setProperty('--my',y+'px');},{passive:true});
    (function loop(){cx+=(x-cx)*.2;cy+=(y-cy)*.2;cur.style.transform='translate('+cx+'px,'+cy+'px) translate(-50%,-50%)';requestAnimationFrame(loop);})();
    // hover-grow on EVERY section via delegation — no per-node binding, catches dynamically considered targets too
    var HOT='a,button,input,label,summary,[data-c],[role="button"],.mode,.wrow,.work-cta,.back,.brand';
    document.addEventListener('mouseover',function(e){var el=e.target;cur.classList.toggle('big', !!(el&&el.closest&&el.closest(HOT)));},{passive:true});
    document.addEventListener('mouseleave',function(){cur.classList.remove('big');});
  } else if(cur){ cur.style.display='none'; if(aura) aura.style.display='none'; }

  // accessible mobile menu
  var menu=document.getElementById('menu'),nav=document.getElementById('nav');
  function setMenu(open){menu.classList.toggle('open',open);nav.classList.toggle('open',open);menu.setAttribute('aria-expanded',String(open));menu.setAttribute('aria-label',open?'Close menu':'Open menu');}
  menu.addEventListener('click',function(){setMenu(!nav.classList.contains('open'));});
  nav.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')setMenu(false);});

  var bar=document.getElementById('bar');addEventListener('scroll',function(){bar.classList.toggle('scrolled',scrollY>8);},{passive:true});

  var ups=document.querySelectorAll('.up');
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.08});
    ups.forEach(function(el){io.observe(el);});
    setTimeout(function(){ups.forEach(function(el){el.classList.add('in');});},4000);
  } else { ups.forEach(function(el){el.classList.add('in');}); }

  // Beehiiv subscribe
  function wire(formId, medium){
    var f=document.getElementById(formId); if(!f) return;
    f.addEventListener('submit',function(ev){
      ev.preventDefault();
      var input=f.querySelector('input'), btn=f.querySelector('button'), cap=f.querySelector('.cap');
      var email=(input.value||'').trim(); if(!email) return;
      btn.disabled=true; var old=btn.textContent; btn.textContent='Sending…';
      var d=new FormData();
      d.set('email',email); d.set('utm_source','davidrussell.co'); d.set('utm_medium',medium); d.set('tags','dr-subscriber'); d.set('referring_site','davidrussell.co');
      fetch('https://embeds.beehiiv.com/pub_ed495df0-b44a-47ba-939c-eeb46089e27b',{method:'POST',mode:'no-cors',body:d}).finally(function(){
        f.reset(); btn.disabled=false; btn.textContent=old;
        if(cap){ cap.textContent='Submitted. Check your inbox to confirm.'; cap.classList.add('done'); }
      });
    });
  }
  wire('sub1','hero'); wire('sub2','footer');

  // "Signal" — animated, cursor-reactive flow field (cobalt ink on paper). Canvas2D, no WebGL.
  // Drifts on layered sines; the lines dimple around the pointer. Throttled, pauses offscreen, static under reduced-motion.
  (function(){
    var c=document.getElementById('herogl'); if(!c) return;
    var hero=c.closest('.hero'); if(!hero) return;
    var ctx=c.getContext('2d',{alpha:true,desynchronized:true});
    if(!ctx){ hero.classList.add('nogl'); return; }
    var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var coarse=window.matchMedia('(pointer: coarse)').matches;
    var INK='27,24,18', COB='47,43,240';
    var dprCap=coarse?1:1.6;
    var W=1,H=1,dpr=1,sc=1;
    var LINES=coarse?10:16, STEP=coarse?24:16, R=coarse?170:230;
    var t=0, raf=0, last=0, minDT=coarse?1000/30:1000/60, running=false, inView=true, pageVis=true;
    var px=0.66, py=0.32, tx=0.66, ty=0.32; // pointer, normalized to hero, eased
    var ppx=px, ppy=py, pl=0, tw=0;          // prev pointer + pluck energy + twang phase

    function resize(){
      var r=hero.getBoundingClientRect();
      W=Math.max(1,Math.round(r.width)); H=Math.max(1,Math.round(r.height));
      dpr=Math.min(window.devicePixelRatio||1,dprCap);
      sc=Math.min(1,1100/W);
      c.width=Math.round(W*sc*dpr); c.height=Math.round(H*sc*dpr);
      c.style.width='100%'; c.style.height='100%';
      ctx.setTransform(sc*dpr,0,0,sc*dpr,0,0);
    }
    function syncPointer(){
      var p=window.__pointer; if(!p) return;
      var r=hero.getBoundingClientRect();
      tx=Math.min(1.2,Math.max(-0.2,(p.x-r.left)/Math.max(1,r.width)));
      ty=Math.min(1.2,Math.max(-0.2,(p.y-r.top)/Math.max(1,r.height)));
    }
    function render(){
      ctx.clearRect(0,0,W,H);
      var cx=px*W, cy=py*H, R2=R*R;
      // cobalt wash, nudged toward the pointer
      var gx=(0.58+px*0.20)*W, gy=(0.22+py*0.18)*H;
      var g=ctx.createRadialGradient(gx,gy,0,gx,gy,Math.max(W,H)*0.72);
      g.addColorStop(0,'rgba('+COB+',.13)'); g.addColorStop(.45,'rgba('+COB+',.04)'); g.addColorStop(1,'rgba('+COB+',0)');
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
      ctx.lineCap='round'; ctx.lineJoin='round';
      var top=H*0.05, span=H*0.92;
      for(var i=0;i<LINES;i++){
        var ly=top+span*(i/(LINES-1));
        var ph=t+i*0.40, accent=(i%4===2);
        ctx.beginPath();
        for(var x=-24, first=1; x<=W+24; x+=STEP){
          var base=Math.sin(x*0.0040+ph)*20 + Math.sin(x*0.0115-ph*1.25)*8;
          var ddx=x-cx, ddy=ly-cy, d2=ddx*ddx+ddy*ddy;
          var gauss=Math.exp(-d2/(2*R2));
          var dimple=gauss*(34+pl*52)*(ddy>=0?1:-1);  // press deepens with pointer speed
          var twang=Math.sin(x*0.045+tw)*pl*7*gauss;   // localized string vibration on a fast pass
          var y=ly+base+dimple+twang;
          if(first){ctx.moveTo(x,y);first=0;} else ctx.lineTo(x,y);
        }
        ctx.strokeStyle=accent?'rgba('+COB+',.42)':'rgba('+INK+',.10)';
        ctx.lineWidth=accent?1.45:0.9;
        ctx.stroke();
      }
      // one crisp dashed "scan" line for the signal read
      ctx.beginPath();
      for(var x2=-24, f2=1; x2<=W+24; x2+=STEP){
        var ys=H*0.20 + Math.sin(x2*0.006+t*1.5)*6;
        if(f2){ctx.moveTo(x2,ys);f2=0;} else ctx.lineTo(x2,ys);
      }
      ctx.setLineDash([1,9]); ctx.strokeStyle='rgba('+COB+',.5)'; ctx.lineWidth=1.1; ctx.stroke(); ctx.setLineDash([]);
    }
    function frame(now){
      if(!running) return;
      raf=requestAnimationFrame(frame);
      if(now-last<minDT) return; last=now;
      syncPointer();
      ppx=px; ppy=py;
      px+=(tx-px)*0.10; py+=(ty-py)*0.10;
      var sp=Math.hypot(px-ppx,py-ppy)*W;       // pointer speed in px/frame
      pl=Math.max(pl*0.90, Math.min(1, sp/38)); // pluck energy — spikes on a fast pass, then rings down
      tw+=0.85;                                  // fast clock for the string vibration
      t+=0.0065;
      render();
    }
    function start(){ if(running||reduce) return; running=true; last=0; raf=requestAnimationFrame(frame); }
    function stop(){ if(!running) return; running=false; cancelAnimationFrame(raf); }
    function sync(){ (inView && pageVis && !reduce) ? start() : stop(); }

    resize();
    if(reduce){ syncPointer(); px=tx; py=ty; render(); } else { start(); }

    if('ResizeObserver' in window){ new ResizeObserver(function(){ resize(); if(reduce||!running) render(); }).observe(hero); }
    else { window.addEventListener('resize',function(){ resize(); if(reduce||!running) render(); },{passive:true}); }
    if('IntersectionObserver' in window){
      new IntersectionObserver(function(es){ es.forEach(function(e){ inView=e.isIntersecting; }); sync(); },{threshold:0}).observe(hero);
    }
    document.addEventListener('visibilitychange',function(){ pageVis=!document.hidden; sync(); });
  })();
})();
</script>
</body>
