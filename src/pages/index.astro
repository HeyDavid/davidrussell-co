<style is:global>
:root{
  --paper:#fbf5ea; --card:#fffdf8; --ink:#1b1812; --dim:#675f52; --faint:#817867;
  --cobalt:#2f2bf0; --cobalt-deep:#211ec0; --cream-on:#eceaff;
  --line:rgba(27,24,18,.13); --line-soft:rgba(27,24,18,.08);
  --disp:"Bricolage Grotesque",system-ui,sans-serif; --grot:"Hanken Grotesk",system-ui,sans-serif;
  --ease:cubic-bezier(.19,1,.22,1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--paper);color:var(--ink);font-family:var(--grot);font-size:18px;line-height:1.62;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:inherit;text-decoration:none}
::selection{background:var(--cobalt);color:#fff}
:where(a,button,input,textarea,select):focus-visible{outline:3px solid rgba(47,43,240,.55);outline-offset:4px;border-radius:8px}
.nav a:focus-visible,.brand:focus-visible,.mode:focus-visible,.wrow a:focus-visible{outline-offset:6px}
#aura{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.7;background:radial-gradient(460px 460px at var(--mx,50%) var(--my,36%),rgba(47,43,240,.06),transparent 70%)}
#cur{position:fixed;top:0;left:0;width:10px;height:10px;border-radius:50%;background:var(--cobalt);z-index:9999;pointer-events:none;transform:translate(-50%,-50%);transition:width .28s var(--ease),height .28s var(--ease),opacity .28s}
#cur.big{width:60px;height:60px;opacity:.18}
.inner{max-width:1280px;margin:0 auto;padding:0 clamp(22px,5vw,64px);position:relative;z-index:1}
section{position:relative;z-index:1}

.bar{position:sticky;top:0;z-index:60;background:rgba(251,245,234,.86);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid transparent;transition:border-color .3s}
.bar.scrolled{border-bottom-color:var(--line)}
.bar .in{max-width:1280px;margin:0 auto;padding:14px clamp(22px,5vw,64px);display:flex;align-items:center;justify-content:space-between;gap:20px}
.brand{display:flex;align-items:center;gap:12px}
.brand .ava{width:40px;height:40px;object-fit:contain}
.brand .wm{font-family:var(--disp);font-weight:700;font-size:24px;letter-spacing:-.035em;line-height:1}
.brand .wm .d{color:var(--cobalt)}
.nav{display:flex;align-items:center;gap:26px;font-size:16px;font-weight:500}
.nav a{color:var(--dim);transition:color .3s}.nav a:hover{color:var(--ink)}
.nav .cta{color:#fff;background:var(--cobalt);padding:9px 18px;border-radius:100px;font-weight:600;font-size:15px;transition:background .3s}
.nav .cta:hover{background:var(--cobalt-deep)}
.menu{display:none;border:0;background:transparent;cursor:pointer;font-family:var(--grot);font-weight:600;font-size:15px;color:var(--ink);align-items:center;gap:8px}
.menu .ic{display:block;width:20px;height:2px;background:var(--ink);position:relative;transition:.3s}
.menu .ic::before,.menu .ic::after{content:"";position:absolute;left:0;width:20px;height:2px;background:var(--ink);transition:.3s}
.menu .ic::before{top:-6px}.menu .ic::after{top:6px}
.menu.open .ic{background:transparent}
.menu.open .ic::before{top:0;transform:rotate(45deg)}.menu.open .ic::after{top:0;transform:rotate(-45deg)}
@media(max-width:720px){
  .menu{display:flex}
  .nav{position:fixed;top:68px;left:0;right:0;flex-direction:column;align-items:flex-start;gap:0;background:var(--card);border-bottom:1px solid var(--line);padding:8px 0;transform:translateY(-12px);opacity:0;pointer-events:none;transition:.3s var(--ease);box-shadow:0 24px 50px rgba(27,24,18,.12)}
  .nav.open{transform:none;opacity:1;pointer-events:auto}
  .nav a{width:100%;padding:14px clamp(22px,5vw,64px);font-size:18px}
  .nav .cta{background:transparent;color:var(--cobalt);border-radius:0;padding:14px clamp(22px,5vw,64px)}
}

.hero{padding:clamp(36px,7vh,84px) 0 clamp(46px,7vw,90px);position:relative}
#herogl{position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:.95;mix-blend-mode:multiply;
  -webkit-mask-image:radial-gradient(125% 100% at 66% 34%,#000 0 48%,rgba(0,0,0,.78) 64%,transparent 86%);
  mask-image:radial-gradient(125% 100% at 66% 34%,#000 0 48%,rgba(0,0,0,.78) 64%,transparent 86%)}
.hero.nogl #herogl{background:radial-gradient(56% 62% at 76% 28%,rgba(47,43,240,.095),transparent 68%),linear-gradient(110deg,transparent 0 48%,rgba(27,24,18,.05) 48.1% 48.4%,transparent 48.5%)}
@media(max-width:720px){#herogl{opacity:.55;-webkit-mask-image:radial-gradient(105% 82% at 80% 22%,#000 0 32%,transparent 72%);mask-image:radial-gradient(105% 82% at 80% 22%,#000 0 32%,transparent 72%)}}
.hero .grid{display:grid;grid-template-columns:1.32fr .88fr;gap:clamp(30px,5vw,70px);align-items:center;position:relative;z-index:1}
.hero .ey{font-size:15px;font-weight:600;color:var(--cobalt);margin-bottom:22px}
.js .hero .ey{animation:rise 1s var(--ease) .05s both}
.hero h1{font-family:var(--disp);font-weight:600;font-size:clamp(42px,6.2vw,84px);line-height:1.0;letter-spacing:-.022em}
.js .hero h1{animation:rise 1.1s var(--ease) .12s both}
.hero h1 .c{color:var(--cobalt)}
@keyframes rise{from{opacity:0;transform:translateY(34px)}to{opacity:1;transform:none}}
.hero .sub{margin-top:28px;max-width:46ch;font-size:clamp(18px,1.9vw,21px);color:var(--ink);line-height:1.55}
.js .hero .sub{animation:rise 1.1s var(--ease) .45s both}
.hero .sub b{font-weight:700;color:var(--cobalt)}
.signup{margin-top:34px;max-width:460px}
.js .hero .signup{animation:rise 1.1s var(--ease) .68s both}
.field{display:flex;background:var(--card);border:1.5px solid var(--line);border-radius:100px;padding:6px 6px 6px 22px;transition:border-color .3s,box-shadow .3s}
.field:focus-within{border-color:var(--cobalt);box-shadow:0 0 0 4px rgba(47,43,240,.12)}
.field input{flex:1;min-width:0;border:0;background:transparent;outline:none;font-family:var(--grot);font-size:16px;color:var(--ink)}
.field input::placeholder{color:var(--faint)}
.field button{border:0;background:var(--ink);color:var(--paper);border-radius:100px;padding:11px 22px;cursor:pointer;font-family:var(--grot);font-weight:600;font-size:15px;white-space:nowrap;transition:background .3s}
.field button:hover{background:var(--cobalt)}
.field button:disabled{opacity:.6;cursor:default}
.signup .cap{font-size:14.5px;color:var(--dim);margin-top:12px;padding-left:4px}
.signup .cap.done{color:var(--cobalt);font-weight:600}
.por{position:relative;justify-self:end;width:100%;max-width:392px}
.js .por{animation:rise 1.2s var(--ease) .32s both}
.por .block{position:absolute;left:-22px;bottom:-22px;width:88%;height:84%;background:var(--cobalt);z-index:0}
.por .frame{position:relative;z-index:1;aspect-ratio:4/5;border-radius:230px 230px 14px 14px;overflow:hidden;box-shadow:0 30px 60px rgba(27,24,18,.16)}
.por .frame img{width:100%;height:100%;object-fit:cover;object-position:center 12%}
.por .cap{position:absolute;z-index:2;right:-10px;top:24px;background:var(--ink);color:var(--paper);font-size:12px;font-weight:600;padding:7px 13px;border-radius:100px;transform:rotate(3deg)}
@media(max-width:720px){
  .hero .grid{grid-template-columns:1fr;gap:30px}
  .por{justify-self:start;max-width:280px;margin-top:6px}
  .por .cap{right:8px;top:14px}
}

.strip{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:18px 0;overflow:hidden;white-space:nowrap}
.strip .track{display:inline-block;animation:scroll 30s linear infinite;font-family:var(--disp);font-weight:600;font-size:22px}
.strip .track span{margin:0 24px;color:var(--dim)}.strip .track .dot{color:var(--cobalt)}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.sec{padding:clamp(58px,8vw,112px) 0}
.sec-h{display:flex;align-items:baseline;justify-content:space-between;gap:20px;margin-bottom:14px}
.sec-h h2{font-family:var(--disp);font-weight:600;font-size:clamp(34px,5vw,64px);line-height:1.02;letter-spacing:-.018em}
.sec-h h2 .c{color:var(--cobalt)}
.sec-h .all{font-size:16px;font-weight:600;color:var(--cobalt);white-space:nowrap}
.sec-note{color:var(--dim);font-size:17px;max-width:58ch;line-height:1.55;margin-bottom:42px}

.wrows{list-style:none;border-top:1px solid var(--line)}
.wrow{border-bottom:1px solid var(--line)}
.wrow a{display:grid;grid-template-columns:150px 1fr minmax(240px,300px);gap:clamp(20px,3.4vw,52px);padding:clamp(26px,3.2vw,42px) 0;align-items:baseline;transition:opacity .4s}
.wrows:hover .wrow a{opacity:.45}.wrows .wrow a:hover{opacity:1}
.wrow .wmeta{font-size:14px;font-weight:700;color:var(--cobalt);text-transform:lowercase}
.wrow .wmeta .wd{display:block;color:var(--dim);font-weight:500;margin-top:6px;font-size:13.5px;text-transform:none}
.wrow .wt{font-family:var(--disp);font-weight:600;font-size:clamp(26px,3.4vw,44px);line-height:1.04;letter-spacing:-.014em;transition:color .3s}
.wrow a:hover .wt{color:var(--cobalt)}
.wrow .wdesc{font-size:16px;color:var(--dim);line-height:1.5;margin-top:10px;max-width:62ch}
.wrow .wq{font-size:15.5px;line-height:1.45;color:var(--ink);font-weight:500;border-left:3px solid var(--cobalt);padding-left:16px}
.wrow .wq .ql{display:block;font-size:12px;color:var(--dim);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:7px}
@media(max-width:860px){.wrow a{grid-template-columns:1fr;gap:12px}.wrow .wq{margin-top:4px}}

.modes{border-bottom:1px solid var(--line)}
.mode .body .chip{display:inline-block;font-family:var(--grot);font-size:11.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--cobalt);border:1.5px solid currentColor;border-radius:100px;padding:3px 11px;margin-left:12px;position:relative;top:-4px}
.mode .body .chip.fam{color:var(--faint)}
.mode{display:grid;grid-template-columns:minmax(0,auto) 1fr;gap:clamp(20px,4vw,56px);align-items:center;padding:clamp(28px,3.6vw,46px) 0;border-top:1px solid var(--line)}
.mode .verb{font-family:var(--disp);font-weight:700;font-size:clamp(48px,8.4vw,116px);line-height:.86;letter-spacing:-.028em;color:var(--cobalt);transition:transform .5s var(--ease)}
.mode:hover .verb{transform:translateX(10px)}
.mode .body .pn{font-family:var(--disp);font-weight:700;font-size:clamp(22px,2.4vw,32px);letter-spacing:-.02em;display:inline-flex;align-items:baseline;gap:10px}
.mode .body .pn .ar{color:var(--cobalt);font-size:.7em;transition:transform .4s var(--ease)}
.mode:hover .body .pn .ar{transform:translate(6px,-6px)}
.mode .body .ps{color:var(--dim);font-size:17px;line-height:1.5;margin-top:8px;max-width:46ch}
@media(max-width:720px){.mode{grid-template-columns:1fr;gap:8px}.mode .verb{font-size:clamp(60px,20vw,90px)}}

.desk{background:var(--cobalt);color:#fff}
.desk .grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(34px,5vw,72px);align-items:center}
.desk h2{font-family:var(--disp);font-weight:600;font-size:clamp(33px,4.6vw,60px);line-height:1.04;letter-spacing:-.018em;max-width:15ch}
.desk .bd{color:var(--cream-on);font-size:17.5px;line-height:1.6;margin-top:22px;max-width:46ch}
.desk .rule{margin-top:22px;font-family:var(--disp);font-weight:600;font-size:18px;color:#fff;opacity:.92}
.desk .cta{margin-top:28px;display:inline-block;background:var(--paper);color:var(--ink);font-weight:600;font-size:16px;padding:13px 26px;border-radius:100px;transition:transform .3s var(--ease)}
.desk .cta:hover{transform:translateY(-2px)}
.acts{display:flex;flex-direction:column;gap:16px}
.act-card{display:block;background:var(--card);color:var(--ink);border-radius:14px;padding:22px 26px;box-shadow:0 16px 40px rgba(17,15,80,.22);transition:transform .35s var(--ease),box-shadow .35s var(--ease)}
.act-card:hover{transform:translateY(-3px);box-shadow:0 22px 54px rgba(17,15,80,.3)}
.act-card .ac-k{font-size:12px;font-weight:700;color:var(--cobalt);letter-spacing:.04em;text-transform:uppercase;margin-bottom:9px}
.act-card .ac-t{font-family:var(--disp);font-weight:600;font-size:clamp(20px,2.1vw,25px);line-height:1.12;letter-spacing:-.012em}
.act-card .ac-d{font-size:15px;line-height:1.5;color:var(--dim);margin-top:9px}
.act-card .ac-go{margin-top:14px;font-size:14.5px;font-weight:600;color:var(--cobalt)}
.act-card.cause{background:rgba(255,255,255,.08);color:#fff;box-shadow:none;border:1px solid rgba(255,255,255,.24)}
.act-card.cause .ac-d{color:var(--cream-on)}
.act-card.cause .ac-k,.act-card.cause .ac-go{color:#fff}
.desk .note{margin-top:22px;color:var(--cream-on);font-size:14.5px;opacity:.85}
@media(max-width:720px){.desk .grid{grid-template-columns:1fr}}

.aboutgrid{display:grid;grid-template-columns:.7fr 1.3fr;gap:clamp(30px,5vw,64px);align-items:start}
.aboutimg{width:100%;max-width:280px;aspect-ratio:1/1;border-radius:18px;object-fit:cover;object-position:center 14%}
.aboutimg.mark{object-fit:contain;border-radius:0;background:transparent;padding:10px}
.about p{font-size:clamp(19px,2vw,23px);line-height:1.5;font-family:var(--disp);font-weight:500;letter-spacing:-.01em}
.about p+p{margin-top:18px;font-size:18px;font-family:var(--grot);font-weight:400;color:var(--dim);letter-spacing:0;line-height:1.6}
.about .more{margin-top:24px;font-size:16px;font-weight:600;color:var(--cobalt);display:inline-block}
@media(max-width:720px){.aboutgrid{grid-template-columns:1fr}}

.close{padding:clamp(64px,8vw,120px) 0 clamp(30px,4vw,52px)}
.talk{font-family:var(--disp);font-weight:700;font-size:clamp(48px,8.6vw,116px);line-height:.96;letter-spacing:-.022em}
.talk .c{color:var(--cobalt)}
.labrow{margin-top:30px}
.labrow .ll{display:block;font-size:12.5px;letter-spacing:.07em;text-transform:uppercase;font-weight:700;color:var(--cobalt);margin-bottom:12px}
.labrow .lk{display:inline-block;font-size:16px;font-weight:600;color:var(--ink);border-bottom:2px solid var(--line);padding-bottom:2px;margin:0 22px 10px 0;transition:color .3s,border-color .3s}
.labrow .lk:hover{color:var(--cobalt);border-color:var(--cobalt)}
.cmeta{display:flex;flex-wrap:wrap;gap:16px 30px;margin-top:34px;font-size:17px;font-weight:500}
.cmeta a{color:var(--ink);border-bottom:2px solid var(--line);padding-bottom:3px;transition:border-color .3s,color .3s}
.cmeta a:hover{color:var(--cobalt);border-color:var(--cobalt)}
.colophon{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:14px;color:var(--dim);padding:24px 0 0;border-top:1px solid var(--line-soft);margin-top:36px}

.up{}
.js .up{opacity:0;transform:translateY(28px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.js .up.in{opacity:1;transform:none}
@media(pointer:coarse){#cur,#aura{display:none}}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}.js .up{opacity:1;transform:none}.strip .track{animation:none}#cur,#aura{display:none}}
</style>
</head>
<body>
<div id="aura"></div><div id="cur"></div>

<header class="bar" id="bar"><div class="in">
  <a class="brand" href="#top" data-c><img class="ava" src="/assets/david-portrait-mark.png" alt="" width="40" height="40" decoding="async"><span class="wm">david <span class="d">russell</span></span></a>
  <button class="menu" id="menu" type="button" aria-label="Open menu" aria-controls="nav" aria-expanded="false"><span class="ic" aria-hidden="true"></span></button>
  <nav class="nav" id="nav" aria-label="Primary"><a href="#writing" data-c>Writing</a><a href="#built" data-c>Work</a><a href="#about" data-c>About</a><a href="#subscribe" class="cta" data-c>Subscribe</a></nav>
</div></header>

<div id="top"></div>
<section class="hero"><canvas id="herogl" aria-hidden="true"></canvas><div class="inner">
  <div class="grid">
    <div>
      <div class="ey">david russell · operator &amp; writer · south florida</div>
      <h1>I build small companies and <span class="c">write down</span> what I learn.</h1>
      <p class="sub">A decade in marketing and a <b>$400K+ exit</b> behind me. I publish in the open — then I read every reply. Follow along, and tell me where I&rsquo;m wrong.</p>
      <form class="signup" id="sub1">
        <div class="field"><input type="email" name="email" placeholder="your email" autocomplete="email" aria-label="Email address" required><button type="submit" data-c>Subscribe</button></div>
        <div class="cap">A few notes a month. No spam — and every issue is a conversation.</div>
      </form>
    </div>
    <figure class="por">
      <div class="block"></div>
      <div class="frame"><img src="/assets/headshot.jpg" alt="David Russell" width="600" height="750" fetchpriority="high" decoding="async" sizes="(max-width: 720px) 72vw, 380px"></div>
      <figcaption class="cap">South Florida</figcaption>
    </figure>
  </div>
</div></section>

<div class="strip"><div class="track">
  <span>Marketing that earns trust</span><span class="dot">&bull;</span><span>Building in plain sight</span><span class="dot">&bull;</span><span>Operator notes</span><span class="dot">&bull;</span><span>Craft over slop</span><span class="dot">&bull;</span><span>Small, useful companies</span><span class="dot">&bull;</span><span>Marketing that earns trust</span><span class="dot">&bull;</span><span>Building in plain sight</span><span class="dot">&bull;</span><span>Operator notes</span><span class="dot">&bull;</span><span>Craft over slop</span><span class="dot">&bull;</span><span>Small, useful companies</span><span class="dot">&bull;</span>
