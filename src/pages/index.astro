---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import Building from "@/components/Building.astro";
import Background from "@/components/Background.astro";
import WritingTeaser from "@/components/WritingTeaser.astro";
import GetInTouch from "@/components/GetInTouch.astro";
import Footer from "@/components/Footer.astro";
import Starfield from "@/components/Starfield.astro";
import DeepOcean from "@/components/DeepOcean.astro";
---

<BaseLayout
  title="David Russell — Best-in-class websites and marketing funnels"
  description="Operator notes, debates, and flow logs from David Russell. Grew a Wix site into a $400K marketplace, decade of marketing across dozens of industries. South Florida."
>
  <Starfield />
  <DeepOcean />
  <div class="scene-frame" aria-hidden="true"></div>
  <Header />
  <main>
    <Hero />
    <WritingTeaser />
    <Building />
    <Background />
    <GetInTouch />
  </main>
  <Footer />
</BaseLayout>
