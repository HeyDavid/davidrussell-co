---
import { getCollection } from "astro:content";

const all = await getCollection("writing", ({ data }) => !data.draft);
const posts = all
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) => d.toLocaleDateString("en-US", { year: "numeric", month: "short" });

const questions: Record<string, string> = {
  "competitive-gaming-operator-flow": "What would you remove to get two real hours of focus tomorrow?",
  "marketing-is-splitting-in-half": "Are you building the slop machine or the craft brand?",
  "sapiens-in-a-hurry": "Which fiction are you strengthening — and should you be?",
};
const fallbackQ = "Reply and tell me where I'm wrong.";

const title = "David Russell — operator, writer";
const description = "I build small, useful companies and write down what I learn — then I read every reply. A decade in marketing and a $400K+ exit. South Florida.";
const canonical = "https://davidrussell.co/";
const ogImage = "https://davidrussell.co/og-2026.png";
---

