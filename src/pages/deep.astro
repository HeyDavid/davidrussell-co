---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Starfield from "@/components/Starfield.astro";
import DeepOcean from "@/components/DeepOcean.astro";
import AsteroidField from "@/components/AsteroidField.astro";
import KelpForest from "@/components/KelpForest.astro";
---

<BaseLayout
  title="Going deeper — David Russell"
  description="An experiment. Scroll down through space and into the ocean. Click the asteroids. Feed the kelp. Stay a while."
  noindex={true}
>
  <Starfield />
  <AsteroidField />
  <DeepOcean />
  <KelpForest />

  <div class="deep-frame" aria-hidden="true"></div>

  <div class="hud" id="hud" aria-live="polite">
    <div class="hud-row">
      <span class="hud-label">Discoveries</span>
      <span class="hud-value" id="hud-count">0</span>
    </div>
    <div class="hud-row">
      <span class="hud-label">Depth</span>
      <span class="hud-value" id="hud-depth">surface</span>
    </div>
  </div>

  <Header />
  <main class="deep-main">
    <article class="deep-essay">
      <a href="/" class="back">← Home</a>

      <header class="deep-hero">
        <p class="deep-kicker">An experiment</p>
        <h1>Going deeper.</h1>
        <p class="deep-lede">
          A page that doesn't behave. Scroll down through space and into the ocean.
          Click the asteroids. Feed the kelp. Stay a while.
        </p>
      </header>

      <section class="deep-section deep-section-space">
        <h2>You start in orbit.</h2>
        <p>
          Most of the web is documents. Pages that load fast, work everywhere,
          and get out of the way. That is good — it is the right shape for
          almost everything.
        </p>
        <p>
          But occasionally the right shape is a <em>place</em>. A scene you sit
          inside for a minute before reading what is there. Worth building,
          even if you only get to use it a few times.
        </p>
        <p class="deep-prompt">
          Try clicking one of the asteroids drifting overhead.
        </p>
      </section>

      <section class="deep-section deep-section-mid">
        <h2>Falling through.</h2>
        <p>
          The gradient is doing the work here. No teleporters, no transitions,
          no "next chapter" page. Just a long descent. You are passing through
          atmosphere, through cloud, through the surface, into water.
        </p>
        <p>
          Most websites are afraid of long pages. They cram everything above
          the fold. This one expects you to scroll, and rewards you for it.
        </p>
      </section>

      <section class="deep-section deep-section-deep">
        <h2>The deep.</h2>
        <p>
          Below the photic zone the light fails. The animals down here make
          their own. Kelp does not actually grow this deep — but the metaphor
          is more important than the marine biology, and besides, it is my
          ocean.
        </p>
        <p class="deep-prompt">
          Click a kelp frond. Tadpoles will come.
        </p>
        <p>
          The point of the page is itself. There is no upsell, no funnel, no
          gated content at the bottom. If you got to here you got the thing.
        </p>
        <p class="deep-sig">— D.</p>
      </section>

      <a href="/" class="deep-return">← Back to the surface</a>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* Deep page only — content sits in a narrow editorial column over the
     cosmic scene. */
  .deep-main {
    position: relative;
    z-index: 4;
  }
  .deep-essay {
    max-width: 640px;
    margin: 0 auto;
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 32px) clamp(160px, 20vw, 240px);
    color: var(--star);
  }
  .deep-essay .back {
    display: inline-block;
    margin-bottom: 60px;
    color: var(--mist);
    font-size: 14px;
    border: 0;
  }
  .deep-essay .back:hover { color: var(--signal); }

  .deep-hero {
    margin-bottom: clamp(80px, 12vw, 140px);
  }
  .deep-kicker {
    font-family: var(--serif);
    font-style: italic;
    color: var(--signal);
    font-size: clamp(22px, 2.4vw, 28px);
    margin-bottom: 16px;
  }
  .deep-hero h1 {
    font-family: var(--serif);
    font-size: clamp(56px, 9vw, 96px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.02;
    margin-bottom: 24px;
    color: var(--star);
  }
  .deep-lede {
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.55;
    color: var(--mist);
    max-width: 36ch;
  }

  /* Section spacing creates the "depth zones" via long vertical breaks */
  .deep-section {
    margin-bottom: clamp(100px, 15vw, 180px);
  }
  .deep-section h2 {
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 22px;
    color: var(--star);
  }
  .deep-section p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--mist);
    margin-bottom: 18px;
    max-width: 56ch;
  }
  .deep-section em {
    font-family: var(--serif);
    font-style: italic;
    color: var(--star);
  }
  .deep-prompt {
    color: var(--signal);
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    margin-top: 22px;
  }
  .deep-sig {
    margin-top: 40px;
    font-family: var(--hand);
    color: var(--star);
    font-size: 28px;
  }
  .deep-return {
    display: inline-block;
    margin-top: 40px;
    color: var(--mist);
    font-size: 14px;
    border: 0;
  }
  .deep-return:hover { color: var(--signal); }

  /* Subtle vignette + box frame for the immersive feel */
  .deep-frame {
    position: fixed;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    box-shadow:
      inset 0 0 0 1px rgba(91, 141, 239, 0.06),
      inset 0 0 200px rgba(0, 0, 0, 0.5);
  }

  /* Game HUD — small, top-right, monospace-ish */
  .hud {
    position: fixed;
    top: 76px;
    right: clamp(16px, 3vw, 32px);
    z-index: 11;
    padding: 14px 16px;
    background: rgba(20, 21, 24, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: grid;
    gap: 6px;
    min-width: 168px;
    font-family: var(--sans);
    color: var(--star);
  }
  .hud-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 18px;
    font-size: 13px;
  }
  .hud-label {
    color: var(--mist);
    font-size: 12px;
    letter-spacing: -0.005em;
  }
  .hud-value {
    color: var(--star);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }
  .hud-count-pop {
    animation: count-pop 380ms var(--ease-out);
  }
  @keyframes count-pop {
    0% { transform: scale(1); color: var(--signal); }
    50% { transform: scale(1.25); color: var(--spark); }
    100% { transform: scale(1); color: var(--star); }
  }

  @media (max-width: 640px) {
    .hud {
      top: 64px;
      right: 12px;
      min-width: 140px;
      padding: 10px 12px;
    }
  }
</style>

<script>
  /* Game HUD: count discoveries (asteroid shatters + kelp feeds) and report
     the current depth zone based on scroll progress. */
  (() => {
    const countEl = document.getElementById("hud-count");
    const depthEl = document.getElementById("hud-depth");
    if (!countEl || !depthEl) return;

    let count = 0;
    window.addEventListener("discovery", (e: Event) => {
      count += 1;
      countEl.textContent = String(count);
      countEl.classList.remove("hud-count-pop");
      // Re-trigger animation
      void countEl.offsetWidth;
      countEl.classList.add("hud-count-pop");
    });

    const zoneFor = (p: number) => {
      if (p < 0.18) return "orbit";
      if (p < 0.38) return "atmosphere";
      if (p < 0.55) return "surface";
      if (p < 0.78) return "twilight";
      return "abyssal";
    };

    const onScroll = () => {
      const doc = document.documentElement;
      const total = Math.max(1, doc.scrollHeight - window.innerHeight);
      const p = Math.max(0, Math.min(1, window.scrollY / total));
      depthEl.textContent = zoneFor(p);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  })();
</script>
